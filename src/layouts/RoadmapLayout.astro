---
/**
 * RoadmapLayout — the shared Tufte-serif "frame" for the 5 README/roadmap pages
 * (<track>/README.html). Authoring a page means writing ONLY a typed frontmatter
 * block + the roadmap Markdown body; the serif chrome (the inline skin, the fixed
 * theme button, the hubbar, the masthead) lives here exactly once.
 *
 * These are STATIC indexes — no quiz, no interview, no pager, no feedback. So it
 * wraps BaseLayout with:
 *   • extraCss={[]}     — tokens.css ONLY. Deliberately NO lesson.css /
 *                         interview.css (either would clobber the bespoke serif skin).
 *   • bodyScripts={[]}  — NO interview.js / reading-progress.js. Nothing to enhance.
 * BaseLayout still links tokens.css + the shared analytics.js and emits the <head>
 * + the leading skip-link.
 *
 * The Tufte serif skin (Palatino, the --paper/--rule token aliases, the h2
 * underline, the task-list checkboxes, .wrap ~46rem) is lifted VERBATIM from the
 * live README pages and injected via is:inline. The .ltags chip block is
 * appended, but STANDARDIZED on the indigo brand (var(--accent)) — the stale
 * per-chip rainbow nth-child(6n…) rules the live READMEs still carry are dropped
 * (the rest of the site already moved to indigo).
 *
 * accentVar drives the per-track :root{--accent}, kept as the first line of the
 * inline skin (matching the live pages, where there is no separate accent <style>
 * tag) — so it is NOT forwarded to BaseLayout's own accentVar prop (which would
 * emit a second redundant <style>).
 *
 * The body's leading <h1> is stripped by the rehypeHeadingIds plugin (scoped to
 * src/content/roadmaps in astro.config.mjs); the layout renders the canonical H1
 * from `title` so the kicker → h1 → chips → body order matches the live page and
 * the H1 isn't doubled.
 *
 * There is deliberately NO jsonLd: these pages are passive indexes (no FAQPage).
 */
import BaseLayout from './BaseLayout.astro';
import { roadmapSchema } from '../schema/roadmap';
import PageDates from '../components/PageDates.astro';

// Validate the contract at build time — bad/missing metadata fails the build.
const m = roadmapSchema.parse(Astro.props.meta);
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/'); // normalize to one trailing slash
const keywords = m.keywords.join(', ');

// pandoc-style id for the canonical H1 (matches the rehype slug used on the body
// headings, so deep-links resolve consistently). Reproduces the inline
// pandocSlug from astro.config.mjs.
const h1Id = m.title
    .replace(/[^\p{L}\p{N}_\-.\s]/gu, '')
    .replace(/\s+/g, '-')
    .toLowerCase()
    .replace(/^[^a-z]+/, '');

// —— The Tufte serif skin, lifted VERBATIM from the live README pages, then
// parameterized only by accentVar (the first :root line). The trailing .ltags
// chip block is STANDARDIZED on the indigo brand (no rainbow nth-child rules).
const skinCss = `
:root{--ink:#111110;--paper:#fffff8;--muted:#6b675f;--rule:#d8d4c8;--accent:var(${m.accentVar});--good:#2f5d3a;--blue:#1f3a5a;--chip:#f1eee2;}
*{box-sizing:border-box}html{font-size:18px}
body{margin:0;background:var(--paper);color:var(--ink);font-family:"Palatino Linotype",Palatino,"Iowan Old Style",Georgia,serif;line-height:1.6}
.wrap{max-width:46rem;margin:0 auto;padding:3rem 1.4rem 6rem}
h1{font-size:2.1rem;line-height:1.1;margin:.4rem 0 .6rem;font-weight:600;letter-spacing:-.01em}
h2{font-size:1.4rem;margin:2.2rem 0 .5rem;font-weight:600;border-bottom:1px solid var(--rule);padding-bottom:.2rem}
h3{font-size:1.1rem;margin:1.6rem 0 .3rem;font-weight:600}
h4{font-family:ui-sans-serif,system-ui,sans-serif;font-size:.95rem;margin:1.2rem 0 .3rem}
p,li{font-size:1.02rem}
a{color:var(--accent)}
em{color:#3a372f}
strong{font-weight:700}
code{background:var(--chip);padding:.05rem .3rem;border-radius:3px;font-size:.86em;font-family:ui-monospace,SFMono-Regular,Menlo,monospace}
pre{background:#fbfaf2;border:1px solid var(--rule);border-radius:8px;padding:.9rem 1rem;overflow-x:auto;font-size:.82rem;line-height:1.45}
pre code{background:none;padding:0;font-size:1em}
blockquote{margin:1.2rem 0;padding:.3rem 0 .3rem 1.1rem;border-left:3px solid var(--rule);color:#3a372f;font-style:italic}
hr{border:0;border-top:1px solid var(--rule);margin:2.2rem 0}
table{border-collapse:collapse;width:100%;margin:1rem 0;font-size:.9rem;font-family:ui-sans-serif,system-ui,sans-serif}
th,td{border:1px solid var(--rule);padding:.4rem .55rem;text-align:left;vertical-align:top}
th{background:#f1eee2;font-size:.78rem;text-transform:uppercase;letter-spacing:.03em;color:var(--muted)}
figure{margin:1.6rem 0;text-align:center}
img{max-width:100%;height:auto}
figcaption{font-family:ui-sans-serif,system-ui,sans-serif;font-size:.8rem;color:var(--muted);margin-top:.4rem;line-height:1.4}
ul,ol{padding-left:1.3rem}
ul.contains-task-list{list-style:none;padding-left:.2rem}
ul.contains-task-list li input[type=checkbox]{margin-right:.5rem}
.themebtn{font-family:ui-sans-serif,system-ui,sans-serif;cursor:pointer;background:transparent;border:1px solid var(--rule);border-radius:6px;padding:.1rem .45rem;line-height:1.4;font-size:.9rem;color:var(--ink);}
.themebtn:hover{background:var(--chip)}
html[data-theme="dark"]{--ink:#e9e3d6;--paper:#15140f;--muted:#9c968a;--rule:#39342a;--good:#86c08f;--blue:#9cc0e0;--chip:#252118;}
html[data-theme="dark"] body{background:#15140f;color:#e9e3d6}
html[data-theme="dark"] em{color:#c7c0b0}
html[data-theme="dark"] pre{background:#1b1811}
html[data-theme="dark"] th{background:#252118;color:#9c968a}
html[data-theme="dark"] blockquote{color:#c7c0b0}
html[data-theme="dark"] img{background:#fbfaf2;border:1px solid #d8d4c8;border-radius:10px;padding:.4rem}
html[data-theme="dark"] #hubbar{background:rgba(21,20,15,.92)!important;border-bottom-color:#39342a!important}
html[data-theme="dark"] #hubbar a{color:var(--accent)!important}
html[data-theme="dark"] #hubbar span{color:#9c968a!important}
@media print{html[data-theme="dark"]{--paper:#fff;--ink:#111110}html[data-theme="dark"] body{background:#fff;color:#000}html[data-theme="dark"] img{background:none;border:0}.themebtn,#hubbar{display:none!important}}
/* topic chips + kicker — match lessons/reference, STANDARDIZED on the indigo brand */
.kicker{font-family:ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;font-size:.7rem;letter-spacing:.16em;text-transform:uppercase;color:var(--accent);font-weight:700;margin-bottom:.1rem}
.ltags{display:flex;flex-wrap:wrap;gap:.4rem;margin:.7rem 0 .2rem}
.ltags .lt{font-family:ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,sans-serif;font-size:.7rem;font-weight:600;line-height:1;white-space:nowrap;padding:.32rem .56rem;border-radius:6px;color:color-mix(in srgb,var(--lt-c,var(--text-muted)) 88%,var(--ink));background:color-mix(in srgb,var(--lt-c,var(--border)) 55%,transparent);border:1px solid var(--line)}
:focus-visible{outline:2px solid var(--accent); outline-offset:2px}
`;
---

<BaseLayout
    title={m.title}
    description={m.description}
    keywords={keywords}
    path={m.path}
    ogImage={m.ogImage}
    ogImageAlt={m.ogImageAlt}
    extraCss={[]}
    bodyScripts={[]}
    skipTarget="#main"
>
    <style is:inline set:html={skinCss}></style>

    <button
        class="themebtn"
        onclick="toggleTheme()"
        aria-label="Toggle dark mode"
        title="Toggle dark / light"
        style="position:fixed;top:.8rem;right:.9rem;z-index:60;background:var(--paper)"
        >&#127763;</button
    >
    <div class="wrap">
        <nav
            id="hubbar"
            style="position:sticky;top:0;z-index:50;display:flex;justify-content:space-between;align-items:center;gap:1rem;margin:-3rem -1.4rem 1.4rem;padding:.6rem 1.4rem;background:rgba(255,255,248,.94);-webkit-backdrop-filter:blur(6px);backdrop-filter:blur(6px);border-bottom:1px solid #d8d4c8;font-family:ui-sans-serif,system-ui,sans-serif;font-size:.8rem"
        >
            <a
                href={`${base}index.html`}
                style="color:var(--accent);text-decoration:none;font-weight:600"
                >&#8592; Engineering Vault</a
            ><span style="color:var(--muted)">{m.trackLabel}</span>
        </nav>
        <main id="main" tabindex="-1">
            <div class="kicker">{m.kicker}</div>
            <h1 id={h1Id} set:html={m.title} />
            <div class="ltags">{m.chips.map((c) => <span class="lt" set:html={c} />)}</div>
            <PageDates publishedAt={m.publishedAt} updatedAt={m.updatedAt} />

            <slot />
        </main>
    </div>
</BaseLayout>
