---
/**
 * 404 — branded not-found page.
 *
 * Astro always emits this as /404.html regardless of build.format, and GitHub
 * Pages serves it (with a real 404 status) for any unmatched path under the
 * project base. It is marked noindex and is excluded from the sitemap + the
 * indexable-SEO gate (see scripts/validate-content.cjs isIndexable()).
 *
 * Links/assets are base-absolute (BaseLayout's url()/base convention) because a
 * 404 can be served at ANY URL depth — relative paths would resolve wrong.
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<BaseLayout
    title="Page not found"
    description="That page doesn't exist or has moved. Head back to the Engineering Vault hub to keep exploring."
    keywords="404, page not found, Engineering Vault"
    path="404.html"
    ogType="website"
    robots="noindex, follow"
    extraCss={['assets/lesson.css']}
    skipTarget="#nf"
>
    <main id="nf" class="nf">
        <p class="nf-kicker">Engineering Vault</p>
        <p class="nf-code">404</p>
        <h1 class="nf-title">This page took a wrong turn</h1>
        <p class="nf-msg">
            The page you're looking for doesn't exist, has moved, or the link was mistyped.
        </p>
        <div class="nf-actions">
            <a class="nf-btn nf-btn--primary" href={base}>← Back to the Vault</a>
            <a class="nf-btn" href={`${base}#grid`}>Browse all tracks</a>
        </div>
    </main>

    <style is:inline>
        .nf {
            max-width: 42rem;
            margin: 0 auto;
            padding: clamp(4rem, 12vh, 9rem) 1.25rem;
            text-align: center;
        }
        .nf-kicker {
            text-transform: uppercase;
            letter-spacing: 0.14em;
            font-size: 0.78rem;
            font-weight: 600;
            color: var(--accent);
            margin: 0 0 0.75rem;
        }
        .nf-code {
            font-size: clamp(4.5rem, 18vw, 8rem);
            line-height: 0.9;
            font-weight: 800;
            margin: 0;
            color: color-mix(in srgb, var(--accent) 24%, var(--ink));
        }
        .nf-title {
            font-size: clamp(1.4rem, 4vw, 2rem);
            margin: 0.4rem 0 0.5rem;
        }
        .nf-msg {
            color: var(--muted);
            font-size: 1.02rem;
            margin: 0 auto 1.75rem;
            max-width: 32rem;
        }
        .nf-actions {
            display: flex;
            gap: 0.75rem;
            justify-content: center;
            flex-wrap: wrap;
        }
        .nf-btn {
            display: inline-block;
            padding: 0.65rem 1.1rem;
            border-radius: 0.6rem;
            border: 1px solid var(--line);
            background: var(--chip);
            color: var(--ink);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.95rem;
        }
        .nf-btn:hover {
            border-color: var(--accent);
        }
        .nf-btn--primary {
            background: var(--accent);
            border-color: var(--accent);
            color: #fff;
        }
        .nf-btn--primary:hover {
            background: color-mix(in srgb, var(--accent) 88%, #000);
        }
    </style>
</BaseLayout>
