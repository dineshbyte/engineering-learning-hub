    .filters{flex-wrap:nowrap; overflow-x:auto; margin:1rem -.1rem .2rem; padding-bottom:.25rem; scrollbar-width:none}
    .filters::-webkit-scrollbar{display:none}
    .fchip{flex:none}
    /* compact track cards so ~3 fit on small screens: drop the prose (kept in
       the DOM for SEO) and lean on the header + keyword tags + Lessons toggle */
    .grid{grid-template-columns:1fr; margin-top:1rem}
    .tile{padding:.7rem .85rem .75rem; gap:.45rem}
    .tdesc{font-size:.82rem}
    .tags{gap:.28rem}
    .tag{font-size:.64rem}
    a.lchip{padding:.28rem .35rem; font-size:.82rem; gap:.45rem}
