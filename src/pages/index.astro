    .tfoot{gap:.35rem; padding-top:.6rem}
    /* footer: single column, centered */
    .fgrid{grid-template-columns:1fr; gap:1.4rem} .soc-hdr{display:none}
    /* hide the Quick links column on mobile — the header/cards already cover it */
    .fquick{display:none}
    .fcol{text-align:center}
    .fbrand{flex-direction:column; align-items:center; text-align:center}
  }

  /* dark theme — color tokens live in tokens.css; only component overrides here */
  html[data-theme="dark"] .topbar{background:rgba(19,18,16,.82)}
  html[data-theme="dark"] a.epub{color:#15140f}
  @media print{.topbar,.themebtn,.search{display:none!important}}

  /* ---- card detail sheet (dialog) ---- */
  dialog.cardsheet{border:0; padding:0; margin:auto; max-width:520px; width:calc(100% - 2rem);
    background:var(--card); color:var(--ink); border-radius:14px;
    box-shadow:0 20px 60px rgba(0,0,0,.28)}
  dialog.cardsheet::backdrop{background:rgba(0,0,0,.45)}
  .cs-inner{padding:1.1rem 1.15rem 1.25rem; position:relative}
  .cs-close{position:absolute; top:.55rem; right:.55rem; border:0; background:var(--chip); color:var(--ink);
    width:2rem; height:2rem; border-radius:50%; font-size:.95rem; line-height:1; cursor:pointer}
  .cs-close:hover{background:var(--line)}
  .cs-name{font-weight:700; font-size:1.15rem; letter-spacing:-.01em; padding-right:2rem; line-height:1.15}
  .cs-tag{font-size:.63rem; letter-spacing:.11em; text-transform:uppercase; color:var(--muted); margin-top:.12rem}
  .cs-meta{font-size:.75rem; color:var(--muted); margin-top:.35rem}
  .cs-lessons{list-style:none; margin:.9rem 0 0; padding:0; display:flex; flex-direction:column; gap:.6rem;
    max-height:52vh; overflow:auto}
  .cs-lessons li{display:flex; gap:.6rem; align-items:flex-start}
  .cs-n{flex:none; min-width:1.6rem; height:1.6rem; padding:0 .35rem; border-radius:6px; display:grid;
    place-items:center; font-size:.78rem; font-weight:700; background:var(--chip); color:var(--ink)}
  a.cs-lt{text-decoration:none; color:var(--ink); font-weight:600; font-size:.9rem; line-height:1.25}
  a.cs-lt:hover{color:var(--accent)}
  .cs-d{display:block; font-weight:400; font-size:.8rem; color:var(--muted); margin-top:.14rem; line-height:1.4}
  .cs-foot{display:flex; flex-wrap:wrap; gap:.45rem; align-items:center; margin-top:1rem;
    padding-top:.85rem; border-top:1px solid var(--line)}
  dialog.cardsheet[open]{animation:cs-pop .16s ease-out}
  @keyframes cs-pop{from{opacity:0; transform:translateY(8px) scale(.985)} to{opacity:1; transform:none}}
  @media (max-width:640px){
    dialog.cardsheet{inset:auto 0 0 0; margin:0; width:100%; max-width:none; border-radius:16px 16px 0 0}
    dialog.cardsheet[open]{animation:cs-up .2s ease-out}
    @keyframes cs-up{from{transform:translateY(100%)} to{transform:translateY(0)}}
    .cs-lessons{max-height:60vh}
  }
  @media (prefers-reduced-motion:reduce){
    html{scroll-behavior:auto}
    dialog.cardsheet[open]{animation:none}
    *,*::before,*::after{animation-duration:.01ms!important; animation-iteration-count:1!important; transition-duration:.01ms!important}
  }
`}
    ></style>

    <SiteHeader />
    <Hero trackCount={tracks.length} />
    <WhatIsBand />

    <div class="wrap">
        <FilterChips tracks={tracks} />
        <SearchResults />
        <TrackGrid tracks={tracks} />
        <SiteFooter />
    </div>

    <CardSheet />

    {
        /* window.SEARCH_INDEX — loaded from the build-generated asset. A plain
        (non-defer, non-async) inline-src script placed BEFORE the IIFE script
        guarantees SEARCH_INDEX is defined when run() executes. The endpoint
        (src/pages/assets/search-index.js.ts) owns this file now — FULL-TEXT,
        from the lessons collection. */
    }
    <script src={`${base}assets/search-index.js`} is:inline></script>

    {
        /* window.CARD_DETAIL — still derived inline from `tracks` (ONE source).
        Emitted before the IIFE so it is set when the script runs. */
    }
    <script is:inline set:html={`window.CARD_DETAIL=${JSON.stringify(cardDetail)};`} />

    {
        /* Ported client IIFE from docs/index.html — kept VERBATIM (search/run,
        keyboard nav, filter, progress→Continue, NEW pill, card sheet) so the
        analytics hooks + imperative ARIA stay intact. is:inline so it is NOT
        bundled/deferred (it reads window.SEARCH_INDEX/CARD_DETAIL set above and
        runs after the DOM it queries is in document order).

        CHANGES vs the source IIFE (intentional, all flagged in comments below):
        • REMOVED the .lvl difficulty-dots + ★ START HERE .badge injection — those
          are now SERVER-RENDERED by TrackCard.astro; re-injecting would double them.
        • REMOVED the `heroCount.textContent = tiles.length` write — Hero.astro now
          renders #hero-count server-side. (The `heroCount` lookup is dropped.)
        • Audit fix #1: the per-card Reset no longer calls window.gtag('progress_reset')
          inline — analytics.js's delegated `button.creset` router fires it once.
        • The dead p.empty#empty is NOT in the DOM (search uses renderEmpty into
          #results); nothing references it, so it is omitted. */
    }
    <script is:inline>
        (function () {
            var q = document.getElementById('q'),
                grid = document.getElementById('grid'),
                results = document.getElementById('results'),
                filters = document.getElementById('filters'),
                idx = window.SEARCH_INDEX || [];
            // (The old hardcoded TOK group→color map was removed: each
            // SEARCH_INDEX entry now carries its track color in `d.c`, derived
            // from tracks[].colorVar — see the frontmatter. This fixes the
            // result-row dot color for REST + the 6 newer AI-eng tracks.)
            function esc(s) {
                return s.replace(/[&<>"']/g, function (c) {
                    return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[
                        c
                    ];
                });
            }
            function reEsc(s) {
                return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
            }
            function setStatus(msg) {
                var s = document.getElementById('q-status');
                if (s) s.textContent = msg;
            }
            function run() {
                var raw = q.value.trim(),
                    term = raw.toLowerCase();
                if (!term) {
                    results.style.display = 'none';
                    results.innerHTML = '';
                    grid.style.display = '';
                    filters.style.display = '';
                    q.setAttribute('aria-expanded', 'false');
                    q.removeAttribute('aria-activedescendant');
                    setStatus('');
                    applyFilter();
                    return;
                }
                // Word-boundary matching: a token must START a word in the title or body.
                // (Plain substring made "rag" match "sto-rag-e" and rank Storage above RAG.)
                var toks = term.split(/\s+/).filter(Boolean);
                var pre = toks.map(function (t) {
                    return new RegExp('\\b' + reEsc(t));
                });
                var whole = toks.map(function (t) {
                    return new RegExp('\\b' + reEsc(t) + '\\b');
                });
                var hits = [];
                idx.forEach(function (d) {
                    var tl = d.t.toLowerCase(),
                        xb = d.x,
                        score = 0,
                        ok = true;
                    for (var i = 0; i < toks.length; i++) {
                        var inT = pre[i].test(tl),
                            inX = pre[i].test(xb);
                        if (!inT && !inX) {
                            ok = false;
                            break;
                        }
                        if (inT) {
                            score += 10;
                            if (whole[i].test(tl)) score += 8;
                        } // title hit, exact-word bonus
                        if (inX) score += 2; // body hit
                    }
                    if (ok) hits.push({ d: d, s: score });
                });
                hits.sort(function (a, b) {
                    return b.s - a.s || a.d.t.length - b.d.t.length;
                });
                // filter chips don't apply to search results — hide them so their track
                // counts don't read as conflicting with the result count
                grid.style.display = 'none';
                filters.style.display = 'none';
                results.style.display = 'block'; // '' would fall back to the .results{display:none} default
                if (!hits.length) {
                    results.innerHTML = renderEmpty(raw);
                    q.setAttribute('aria-expanded', 'false');
                    q.removeAttribute('aria-activedescendant');
                    setStatus('No results for ' + raw);
                    return;
                }
                var html =
                    '<p class="rhead">' +
                    hits.length +
                    ' result' +
                    (hits.length > 1 ? 's' : '') +
                    '</p>';
                hits.slice(0, 25).forEach(function (h, i) {
                    var d = h.d,
                        tk = d.c || '--accent'; // per-entry track color (was TOK[d.g])
                    html +=
                        '<a class="ritem' +
                        (i === 0 ? ' sel' : '') +
                        '" id="ropt' +
                        i +
                        '" role="option" aria-selected="' +
                        (i === 0 ? 'true' : 'false') +
                        '" href="' +
                        d.u +
                        '" style="--rtc:var(' +
                        tk +
                        ')">' +
                        '<span class="rdot"></span><span class="rcol"><span class="rt">' +
                        esc(d.t) +
                        '</span>' +
                        '<span class="rg">' +
                        esc(d.g) +
                        '</span></span><span class="rkind">' +
                        d.k +
                        '</span></a>';
                });
                results.innerHTML = html;
                q.setAttribute('aria-expanded', 'true');
                q.setAttribute('aria-activedescendant', 'ropt0');
                setStatus(hits.length + ' result' + (hits.length > 1 ? 's' : '') + ' found');
            }

            /* Empty state: instead of a dead end, show the full catalog grouped by the
               topic categories (read live from the track cards) plus a few popular
               searches — so "no results" still tells the user what IS here. */
            var CATS = [
                { id: 'ai', label: 'AI & LLMs' },
                { id: 'ai-eng', label: 'AI Engineering' },
                { id: 'distributed', label: 'Distributed' },
                { id: 'data', label: 'Data & storage' },
                { id: 'design', label: 'APIs & design' },
            ];
            var SUGGEST = [
                'RAG',
                'Idempotency',
                'Caching',
                'Bloom filters',
                'Auth',
                'Pagination',
                'Kafka',
                'System design',
            ];
            function catalog() {
                return [].slice.call(grid.querySelectorAll('.tile')).map(function (t) {
                    var s = t.querySelector('.start'),
                        nm = t.querySelector('.tname');
                    return {
                        name: nm ? nm.textContent : '',
                        cat: t.getAttribute('data-cat'),
                        href: s ? s.getAttribute('href') : '#',
                        tc: t.style.getPropertyValue('--tc') || 'var(--accent)',
                        lessons: t.querySelectorAll('.lchip').length,
                    };
                });
            }
            function renderEmpty(raw) {
                var tracks = catalog();
                var h =
                    '<div class="nr"><div class="nr-ic" aria-hidden="true">🔍</div>' +
                    '<p class="nr-h">No matches for <b>“' +
                    esc(raw) +
                    '”</b></p>' +
                    '<p class="nr-sub">Nothing in the catalog matches that yet. Try a popular search, or jump into any of the ' +
                    tracks.length +
                    ' tracks below.</p>' +
                    '<div class="nr-sugg">' +
                    SUGGEST.map(function (s) {
                        return (
                            '<button type="button" data-q="' + esc(s) + '">' + esc(s) + '</button>'
                        );
                    }).join('') +
                    '</div>' +
                    '<p class="nr-cap">Browse all ' +
                    tracks.length +
                    ' tracks</p><div class="nr-cats">';
                CATS.forEach(function (c) {
                    var inCat = tracks.filter(function (t) {
                        return t.cat === c.id;
                    });
                    if (!inCat.length) return;
                    h +=
                        '<div class="nr-grp"><div class="nr-glab">' +
                        esc(c.label) +
                        ' <i>' +
                        inCat.length +
                        '</i></div>' +
                        inCat
                            .map(function (t) {
                                return (
                                    '<a class="nr-trk" href="' +
                                    esc(t.href) +
                                    '" style="--c:' +
                                    t.tc +
                                    '">' +
                                    '<span class="d"></span>' +
                                    esc(t.name) +
                                    '<em>' +
                                    t.lessons +
                                    ' lesson' +
                                    (t.lessons === 1 ? '' : 's') +
                                    '</em></a>'
                                );
                            })
                            .join('') +
                        '</div>';
                });
                return h + '</div></div>';
            }
            // popular-search chips re-run the search in place
            results.addEventListener('click', function (e) {
                var b = e.target.closest('.nr-sugg button');
                if (!b) return;
                q.value = b.getAttribute('data-q');
                run();
                q.focus();
            });
            function sel(items, n) {
                items.forEach(function (it, j) {
                    var on = j === n;
                    it.classList.toggle('sel', on);
                    it.setAttribute('aria-selected', on ? 'true' : 'false');
                });
                if (items[n]) {
                    items[n].scrollIntoView({ block: 'nearest' });
                    if (items[n].id) q.setAttribute('aria-activedescendant', items[n].id);
                }
            }
            q.addEventListener('input', run);
            q.addEventListener('keydown', function (e) {
                var items = results.querySelectorAll('.ritem');
                if (!items.length) return;
                var cur = -1;
                for (var i = 0; i < items.length; i++) {
                    if (items[i].classList.contains('sel')) {
                        cur = i;
                        break;
                    }
                }
                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    sel(items, Math.min(cur + 1, items.length - 1));
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    sel(items, Math.max(cur - 1, 0));
                } else if (e.key === 'Enter') {
                    if (cur >= 0) {
                        e.preventDefault();
                        window.location = items[cur].getAttribute('href');
                    }
                } else if (e.key === 'Escape') {
                    q.value = '';
                    run();
                    q.blur();
                }
            });

            /* topic filter: chips show/hide track cards by data-cat */
            var chips = [].slice.call(document.querySelectorAll('.fchip')),
                tiles = [].slice.call(grid.querySelectorAll('.tile')),
                activeCat = 'all';
            // NOTE: #hero-count is now SERVER-RENDERED by Hero.astro; the old
            // `heroCount.textContent = tiles.length` write was removed.
            function applyFilter() {
                tiles.forEach(function (t) {
                    t.style.display =
                        activeCat === 'all' || t.getAttribute('data-cat') === activeCat
                            ? ''
                            : 'none';
                });
            }
            chips.forEach(function (c) {
                // NOTE: the .fcount badge is now SERVER-RENDERED by FilterChips.astro;
                // the old runtime badge-append was removed (it would double the count).
                var cat = c.getAttribute('data-cat');
                c.addEventListener('click', function () {
                    activeCat = cat;
                    chips.forEach(function (x) {
                        var on = x === c;
                        x.classList.toggle('is-active', on);
                        x.setAttribute('aria-pressed', on ? 'true' : 'false');
                    });
                    if (q.value) {
                        q.value = '';
                        results.style.display = 'none';
                        results.innerHTML = '';
                    }
                    grid.style.display = '';
                    applyFilter();
                });
            });

            /* Start -> Continue + in-card progress. Started tracks (localStorage
               'sd:progress', kept current by interview.js) turn the card into the
               resume element: Continue button, a 'Lesson N of M' progress bar (in place
               of the read-time line), an eyebrow label, and the card floats to the top. */
            var PKEY = 'sd:progress';
            function getProg() {
                try {
                    return JSON.parse(localStorage.getItem(PKEY)) || {};
                } catch (e) {
                    return {};
                }
            }
            var prog = getProg();
            var last = null;
            try {
                last = localStorage.getItem('sd:last');
            } catch (e) {}
            [].slice.call(document.querySelectorAll('.start')).forEach(function (a) {
                var slug = a.getAttribute('data-track'),
                    resume = prog[slug];
                var tile = a.closest('.tile');
                if (slug && resume && tile) {
                    var firstHref = a.getAttribute('href'); // original "Start" target (first lesson)
                    a.setAttribute('href', resume);
                    var lbl = a.querySelector('.start-label');
                    if (lbl) lbl.textContent = 'Continue';
                    tile.classList.add('is-started');
                    // progress: index of the resume lesson among this track's lessons
                    var hrefs = [].slice.call(tile.querySelectorAll('.lchip')).map(function (l) {
                        return l.getAttribute('href');
                    });
                    var idx = hrefs.indexOf(resume),
                        total = hrefs.length;
                    var rt = tile.querySelector('.rtime');
                    // in-progress block: step label + a Reset link, plus the bar when known
                    var prog2 = document.createElement('div');
                    prog2.className = 'cprog';
                    var stepTxt =
                        idx >= 0 && total ? 'Lesson ' + (idx + 1) + ' of ' + total : 'In progress';
                    var barHtml =
                        idx >= 0 && total
                            ? '<span class="cbar"><span class="cfill" style="width:' +
                              Math.round(((idx + 1) / total) * 100) +
                              '%"></span></span>'
                            : '';
                    prog2.innerHTML =
                        '<span class="ctop"><span class="cstep">' +
                        stepTxt +
                        '</span>' +
                        '<button class="creset" type="button" aria-label="Reset progress for this track">↻ Reset</button></span>' +
                        barHtml;
                    if (rt) {
                        rt.replaceWith(prog2);
                    } else {
                        a.parentNode.insertBefore(prog2, a);
                    }
                    // Reset: clear this track's saved progress and revert the card to Start.
                    // Low-stakes + reversible (re-start recreates it), so no confirm dialog.
                    prog2.querySelector('.creset').addEventListener('click', function (e) {
                        e.preventDefault();
                        e.stopPropagation();
                        var m = getProg();
                        delete m[slug];
                        try {
                            localStorage.setItem(PKEY, JSON.stringify(m));
                            if (last === slug) localStorage.removeItem('sd:last');
                        } catch (err) {}
                        if (rt) {
                            prog2.replaceWith(rt);
                        } else if (prog2.parentNode) {
                            prog2.parentNode.removeChild(prog2);
                        }
                        tile.classList.remove('is-started');
                        a.setAttribute('href', firstHref);
                        if (lbl) lbl.textContent = 'Start';
                        // Audit fix #1: progress_reset is fired ONCE by analytics.js's
                        // delegated `button.creset` router. The old inline
                        // window.gtag('event','progress_reset',…) here double-fired it,
                        // so it was removed. Do NOT re-add a gtag call.
                    });
                }
                a.addEventListener('click', function () {
                    var m = getProg();
                    if (slug && !m[slug]) {
                        m[slug] = a.getAttribute('href');
                        try {
                            localStorage.setItem(PKEY, JSON.stringify(m));
                        } catch (e) {}
                    }
                });
            });

            /* ---- home redesign: a 'Lesson 1 of N: <title>' quick-link for
               not-yet-started tiles. NOTE: the .lvl difficulty dots and the
               ★ START HERE .badge are now SERVER-RENDERED by TrackCard.astro, so
               their old runtime injection was REMOVED here (it would double them). ---- */
            [].slice.call(grid.querySelectorAll('.tile')).forEach(function (t) {
                if (!t.classList.contains('is-started')) {
                    var chips = t.querySelectorAll('.lchip');
                    if (chips.length) {
                        var first = chips[0],
                            titleEl = first.querySelector('span');
                        var w = document.createElement('div');
                        w.className = 'cnext-wrap';
                        var lbl = document.createElement('span');
                        lbl.className = 'cnext-lbl';
                        lbl.textContent = 'Lesson 1 of ' + chips.length + ': ';
                        var a = document.createElement('a');
                        a.className = 'cnext';
                        a.href = first.getAttribute('href');
                        a.textContent = (titleEl ? titleEl.textContent : '') + ' →';
                        w.appendChild(lbl);
                        w.appendChild(a);
                        var rt = t.querySelector('.rtime');
                        if (rt && rt.parentNode) {
                            rt.parentNode.insertBefore(w, rt);
                        } else {
                            t.appendChild(w);
                        }
                    }
                }
            });

            /* "NEW" pill — shows for NEW_DAYS after data-added, then auto-expires (date-driven, no manual cleanup) */
            var NEW_DAYS = 21;
            // compare calendar days in one frame so a same-day add reads age 0 for every
            // viewer (Date.parse('YYYY-MM-DD') is UTC midnight, Date.now() is local — mixing
            // them made the pill vanish for viewers west of UTC on the day a track shipped).
            var _now = new Date(),
                NEW_TODAY = Date.UTC(_now.getFullYear(), _now.getMonth(), _now.getDate());
            [].slice.call(document.querySelectorAll('[data-added]')).forEach(function (el) {
                var m = /^(\d{4})-(\d{2})-(\d{2})/.exec(el.getAttribute('data-added') || '');
                if (!m) {
                    return;
                }
                var added = Date.UTC(+m[1], +m[2] - 1, +m[3]);
                var ageDays = Math.round((NEW_TODAY - added) / 86400000);
                if (ageDays < 0 || ageDays >= NEW_DAYS) {
                    return;
                }
                var p = document.createElement('span');
                p.className = 'newpill';
                p.textContent = 'NEW';
                if (el.classList.contains('tile')) {
                    var r = el.querySelector('.tnamerow');
                    if (r) {
                        r.appendChild(p);
                    }
                } else {
                    el.insertBefore(p, el.firstChild);
                }
            });

            /* ---- card detail sheet: tap a card (not Start / footer pills / Reset / next-lesson) to
               preview every lesson with a blurb, plus the Start CTA and reference pills ---- */
            var sheet = document.getElementById('cardsheet');
            if (sheet && grid && typeof sheet.showModal === 'function') {
                var csName = sheet.querySelector('.cs-name'),
                    csTag = sheet.querySelector('.cs-tag'),
                    csMeta = sheet.querySelector('.cs-meta'),
                    csList = sheet.querySelector('.cs-lessons'),
                    csFoot = sheet.querySelector('.cs-foot'),
                    DETAIL = window.CARD_DETAIL || {};

                function openSheet(tile) {
                    var nm = tile.querySelector('.tname'),
                        tg = tile.querySelector('.ttag'),
                        cnt = tile.querySelector('.cnt'),
                        rt = tile.querySelector('.rtime') || tile.querySelector('.cprog .cstep'),
                        tc = tile.style.getPropertyValue('--tc') || 'var(--accent)';
                    sheet.style.setProperty('--accent', tc);
                    csName.textContent = nm ? nm.textContent : '';
                    csTag.textContent = tg ? tg.textContent : '';
                    csMeta.textContent = [
                        cnt && cnt.textContent.trim(),
                        rt && rt.textContent.trim(),
                    ]
                        .filter(Boolean)
                        .join('  ·  ');

                    csList.innerHTML = '';
                    [].slice.call(tile.querySelectorAll('.lchip')).forEach(function (ch) {
                        var href = ch.getAttribute('href'),
                            num = ch.querySelector('i'),
                            title = ch.querySelector('span');
                        var li = document.createElement('li');
                        var n = document.createElement('span');
                        n.className = 'cs-n';
                        n.textContent = num ? num.textContent : '';
                        var col = document.createElement('div');
                        var a = document.createElement('a');
                        a.className = 'cs-lt';
                        a.href = href;
                        a.textContent = title ? title.textContent : href;
                        col.appendChild(a);
                        var blurb = DETAIL[href];
                        if (blurb) {
                            var d = document.createElement('span');
                            d.className = 'cs-d';
                            d.textContent = blurb;
                            col.appendChild(d);
                        }
                        li.appendChild(n);
                        li.appendChild(col);
                        csList.appendChild(li);
                    });

                    csFoot.innerHTML = '';
                    [].slice.call(tile.querySelectorAll('.tfoot a')).forEach(function (p) {
                        csFoot.appendChild(p.cloneNode(true));
                    });
                    var start = tile.querySelector('.start');
                    if (start) csFoot.appendChild(start.cloneNode(true)); // Start/Continue = prominent last element

                    sheet.showModal();
                }

                grid.addEventListener('click', function (e) {
                    if (e.target.closest('.start, .tfoot, .creset, .cnext')) return; // keep direct actions
                    var tile = e.target.closest('.tile');
                    if (!tile) return;
                    e.preventDefault(); // cancel the <details> toggle
                    openSheet(tile);
                });
                sheet.addEventListener('click', function (e) {
                    if (e.target === sheet) sheet.close();
                }); // backdrop
                var closeBtn = sheet.querySelector('.cs-close');
                if (closeBtn)
                    closeBtn.addEventListener('click', function () {
                        sheet.close();
                    });
            }
        })();
    </script>
</BaseLayout>
