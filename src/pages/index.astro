  .fcol a{display:block; color:var(--ink); text-decoration:none; font-weight:600; padding:.16rem 0; font-size:.82rem}
  .fcol a:hover{color:var(--accent)}
  /* Connect column: social links inline, wrapping, centered */
  .fconnect{text-align:center}
  /* social links as icon pills so they clearly read as clickable */
  .socrow{display:flex; flex-wrap:wrap; justify-content:center; align-items:center; gap:.5rem; margin-top:.5rem}
