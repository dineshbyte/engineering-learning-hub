  /* systematic 3-column footer */
  .fgrid{display:grid; grid-template-columns:1.6fr 1fr 1fr; gap:1.6rem; align-items:start}
  .fcol h4{margin:0 0 .55rem; font-size:.64rem; letter-spacing:.11em; text-transform:uppercase;
