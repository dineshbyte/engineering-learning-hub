---
/**
 * index.astro — the Engineering Vault hub homepage.
 *
 * Composes the server-rendered hub (SiteHeader → Hero → WhatIsBand →
 * FilterChips → SearchResults → TrackGrid → CardSheet → SiteFooter) inside the
 * shared BaseLayout (which owns the <head>), in the SAME document order as the
 * source of truth docs/index.html.
 *
 * The cards are rendered SERVER-SIDE from `tracks` (one source of truth). The
 * trailing client IIFE from docs/index.html is ported here VERBATIM (search/run,
 * keyboard nav, filter, progress→Continue, card sheet, NEW pill) so the
 * analytics hooks + imperative ARIA updates are preserved — see the porting
 * notes inline. window.SEARCH_INDEX and window.CARD_DETAIL are DERIVED from
 * `tracks` below (no separate search-index.js / card-detail.js assets), so the
 * data has exactly one source.
 *
 * The hub's page-specific CSS lives only in docs/index.html's inline <style>
 * (NOT in tokens.css / lesson.css), so it is carried here as an `is:inline`
 * <style> — emitted verbatim after BaseLayout's <head> links, so its rules
 * (e.g. wrap{max-width:84rem}) win over lesson.css on source order.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import WhatIsBand from '../components/WhatIsBand.astro';
import FilterChips from '../components/FilterChips.astro';
import SearchResults from '../components/SearchResults.astro';
import TrackGrid from '../components/TrackGrid.astro';
import CardSheet from '../components/CardSheet.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { tracks } from '../data/tracks';

// ── Head metadata ───────────────────────────────────────────────────────────
// NOTE: use a RAW "&" (not "&amp;") here. BaseLayout interpolates these via
// {title}/content={...}, and Astro HTML-escapes the value once — so a raw "&"
// renders as "&amp;" in the markup (correct), whereas a pre-encoded "&amp;"
// would double-encode to "&amp;amp;" and display the literal text "&amp;".
const title = 'Engineering Vault — Public Notes on AI Systems, Architecture & System Design';
const description =
    'Engineering Vault — a public collection of engineering lessons, architecture reviews, AI systems notes, interview topics & production learnings. Built while learning, shared so others can learn.';
const keywords =
    'system design, ai engineering, distributed systems, context engineering, rest api, bloom filters, storage engines, transactions, streaming, interview preparation, senior staff interview, engineering vault, knowledge vault, learning in public';
// Raw "&" for the same one-escape reason as title/description above.
const ogImageAlt = 'Engineering Vault — visual system design & AI engineering, 15 tracks';

// Homepage WebSite JSON-LD (verbatim from docs/index.html lines 36–47).
const jsonLd = {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'Engineering Vault',
    alternateName: ['Engineering Learning Hub', 'StackDepth'],
    url: 'https://dineshbyte.github.io/engineering-learning-hub/',
    description:
        'Engineering Vault — visual-first engineering lessons across 15 tracks: AI agents, context engineering, AI evaluation, production AI architecture, AI security, AI infrastructure, domain agent design, advanced AI systems, distributed systems, storage, transactions, streaming, and REST APIs.',
    author: {
        '@type': 'Person',
        name: 'dineshbyte',
        url: 'https://github.com/dineshbyte',
    },
    license: 'https://opensource.org/licenses/MIT',
};

// ── window.SEARCH_INDEX is now BUILD-GENERATED ───────────────────────────────
// The search index is no longer derived inline here. It is statically generated
// (FULL-TEXT, from the `lessons` content collection) by the endpoint
// src/pages/assets/search-index.js.ts → emitted as assets/search-index.js, which
// the page loads (non-defer) BEFORE the ported search IIFE runs (see below). The
// old title+blurb-only derivation lost lesson-body prose from search; the
// endpoint restores deep search. CARD_DETAIL stays derived inline from `tracks`.
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/'); // exactly one trailing slash

// ── Derive window.CARD_DETAIL from `tracks` ──────────────────────────────────
// CARD_DETAIL: { lessonHref → blurb }. The bottom sheet (openSheet) reads this
// to show a per-lesson blurb. Derived straight from lessons[].blurb (the 6
// single-lesson AI-eng tracks have no blurb, so they're simply absent — same as
// the old prebuilt map).
const cardDetail: Record<string, string> = {};
for (const track of tracks) {
    for (const lesson of track.lessons) {
        if (lesson.blurb) cardDetail[lesson.href] = lesson.blurb;
    }
}
---

<BaseLayout
    title={title}
    description={description}
    keywords={keywords}
    path="index.html"
    ogType="website"
    ogImage="assets/og-cover.png"
    ogImageAlt={ogImageAlt}
    jsonLd={jsonLd}
    skipTarget="#grid"
>
    {
        /* Hub page-specific CSS — lives ONLY here (not in tokens.css / lesson.css).
        is:inline keeps it verbatim and emits it after BaseLayout's <head> links,
        so .wrap{max-width:84rem} etc. win over lesson.css on source order. */
    }
    <style
        is:inline
        set:html={`
  /* all colors come from assets/tokens.css — change them there, once */
  *{box-sizing:border-box}
  html{font-size:17px; scroll-behavior:smooth}
  body{margin:0; background:var(--bg); color:var(--ink);
    font-family:ui-sans-serif,system-ui,-apple-system,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    line-height:1.5; -webkit-font-smoothing:antialiased}

  /* top bar */
  .topbar{position:sticky; top:0; z-index:50; display:flex; align-items:center; gap:1rem;
    padding:.7rem clamp(1rem,4vw,2rem); background:rgba(245,245,242,.82);
    -webkit-backdrop-filter:blur(10px); backdrop-filter:blur(10px); border-bottom:1px solid var(--line)}
  .brand{margin:0; display:flex; align-items:center; gap:.5rem; font-weight:800; font-size:1rem; letter-spacing:-.01em}
  .brand .logo{display:grid; place-items:center; width:1.7rem; height:1.7rem; border-radius:7px;
    background:linear-gradient(135deg,#5b54e6,#0f8a7e); color:#fff; font-size:.9rem}
  .search{margin-left:auto; flex:1; max-width:24rem}
  .search input{width:100%; font:inherit; font-size:.86rem; padding:.5rem .85rem; color:var(--ink);
    border:1px solid var(--line); border-radius:10px; background:var(--card)}
  .search input:focus{outline:2px solid var(--accent); outline-offset:0}
  .themebtn{cursor:pointer; background:var(--card); border:1px solid var(--line); border-radius:9px;
    padding:.35rem .55rem; font-size:1rem; line-height:1; color:var(--ink)}
  .themebtn:hover{background:var(--chip)}
  .ghbtn{display:inline-flex; align-items:center; gap:.4rem; text-decoration:none; font-weight:700; font-size:.8rem;
    color:#fff; background:#24292f; border:1px solid #24292f; border-radius:9px; padding:.42rem .72rem; white-space:nowrap}
  .ghbtn:hover{background:#000}
  html[data-theme="dark"] .ghbtn{background:var(--card); border-color:var(--line); color:var(--ink)}
  html[data-theme="dark"] .ghbtn:hover{background:var(--chip)}
  @media(max-width:640px){
    .ghbtn .lbl{display:none}
    /* one clean header row on phones: icon-only brand + inline search + star + theme.
       The "Engineering Vault" wordmark is hidden (the logo carries the brand) to free up
       width so the search fits in the header instead of wrapping to its own row. */
    .topbar{gap:.5rem}
    .brand{margin-right:0}
    .brandname{display:none}
    .search{flex:1; min-width:0; max-width:none; margin-left:.25rem}
  }
  /* NOTE: mobile overrides for grid/cards/filters live in the block at the END
     of this stylesheet — they must come AFTER the base component rules below to
     win on equal specificity. */

  .wrap{max-width:84rem; margin:0 auto; padding:1.6rem clamp(1rem,4vw,2rem) 5rem}
  /* hero / intro banner — full-bleed, shown on every viewport (incl. mobile) */
  .hero{background:linear-gradient(120deg,#2c3a8f,#3d54c9 60%,#4658c8); color:#fff; text-align:center; padding:1.7rem clamp(1rem,4vw,2rem)}
  .hero-in{max-width:60rem; margin:0 auto}
  .hero-h{margin:0; font-size:clamp(1.05rem,2.4vw,1.35rem); font-weight:800; line-height:1.25; letter-spacing:-.01em}
  .hero-sub{margin:.5rem 0 0; font-size:.88rem; opacity:.92}
  .hero-motto{margin:.5rem 0 0; font-size:1rem; font-weight:700; color:#9fe7da; letter-spacing:.01em}
  .hero-pick{margin:.5rem 0 0; font-size:.9rem; opacity:.96}
  .hero-pick a{color:#fff; font-weight:700; text-decoration:underline; text-underline-offset:2px}
  .hero-pick a:hover{opacity:.85}
  /* hero "Browse the vault" scroll cue — white ghost pill on the indigo gradient
     (hero is the same in both themes, so no theme-specific rule needed) */
  .start-here-link{display:inline-flex; align-items:center; gap:.4rem; margin:.7rem 0 .15rem;
    padding:.38rem .95rem; color:#fff; font-weight:700; font-size:.82rem; letter-spacing:.01em;
    text-decoration:none; border:1.5px solid color-mix(in srgb,#fff 50%,transparent);
    border-radius:999px; background:color-mix(in srgb,#fff 8%,transparent);
    transition:background .15s, border-color .15s}
  .start-here-link:hover{background:color-mix(in srgb,#fff 18%,transparent); border-color:#fff}
  .start-here-link:focus-visible{outline:2px solid #fff; outline-offset:2px}
  /* "what is this" band below the hero — subtle, on the page surface */
  .whatis{padding:1.5rem clamp(1rem,4vw,2rem) .2rem; text-align:center}
  .whatis-in{max-width:60rem; margin:0 auto}
  .whatis-h{margin:0 auto; max-width:46rem; font-size:.96rem; line-height:1.55; color:var(--ink)}
  .whatis-domains{display:flex; flex-wrap:wrap; justify-content:center; gap:.4rem; margin:.95rem 0 0}
  .whatis-domains span{font-size:.74rem; font-weight:600; color:var(--muted); border:1px solid var(--line); background:var(--card); border-radius:20px; padding:.26rem .62rem}
  .whatis-soon{margin:.95rem 0 0; font-size:.78rem; color:var(--muted)}
  .whatis-soon b{color:var(--ink); font-weight:700}
  /* footer closing CTA */
  .fstart{border-top:1px solid var(--line); margin-top:1.4rem; padding-top:1.2rem; text-align:center; font-size:.9rem; color:var(--muted)}
  .fdisc{margin:1.4rem 0 0; padding:1.2rem 1.4rem; text-align:left;
    border:1px solid var(--line); border-radius:14px; background:var(--card);
    font-size:.88rem; line-height:1.62; color:var(--muted)}
  .fdisc h3{margin:0 0 .55rem; font-size:1rem; font-weight:700; color:var(--ink)}
  .fdisc p{margin:.65rem 0 0; max-width:72ch}
  .fdisc p:first-of-type{margin-top:0}
  .fdisc a{color:var(--accent); font-weight:600; text-decoration:none}
  .fdisc a:hover{text-decoration:underline}
  .fstart a{color:var(--accent); font-weight:700; text-decoration:none}
  .fstart a:hover{text-decoration:underline}

  /* topic filter chips */
  .filters{display:flex; flex-wrap:wrap; gap:.5rem; margin:1.3rem 0 .2rem}
  .fchip{display:inline-flex; align-items:center; font:inherit; font-size:.8rem; font-weight:600;
    cursor:pointer; color:var(--muted); background:var(--card); border:1px solid var(--line);
    border-radius:20px; padding:.42rem .55rem .42rem .9rem;
    transition:background .12s, color .12s, border-color .12s, transform .08s}
  .fchip:hover{background:var(--chip); color:var(--ink)}
  .fchip:active{transform:scale(.96)}
  .fchip.is-active{background:var(--accent); color:#fff; border-color:var(--accent)}
  html[data-theme="dark"] .fchip.is-active{color:#15140f}
  /* count as a small circular badge */
  .fcount{display:inline-flex; align-items:center; justify-content:center; margin-left:.45rem;
    min-width:1.2rem; height:1.2rem; padding:0 .22rem; border-radius:999px; font-size:.66rem;
    font-weight:700; line-height:1; background:var(--chip); color:var(--muted)}
  .fchip:hover .fcount{background:var(--line)}
  .fchip.is-active .fcount{background:var(--bg); color:var(--ink)}

  /* focus-visible (keyboard) + :active (tap) interaction states */
  a:focus-visible, button:focus-visible, summary:focus-visible, input:focus-visible{
    outline:2px solid var(--accent); outline-offset:2px; border-radius:6px}
  a.lchip:active{background:var(--chip)}
  a.pill:active{background:var(--line)}
  a.ritem:active{background:var(--chip)}
  .themebtn:active, .ghbtn:active, .fpill:active, .soclink:active{transform:scale(.96)}

  /* tile grid — real CSS grid: even columns, cards top-aligned in clean rows
     (the old "columns" multicolumn packed unequal-height cards into ragged,
     unbalanced columns that read as broken). */
  /* align-items:stretch (default) → every card in a row is the same height, so
     bottoms line up; .tfoot is pinned to the bottom (margin-top:auto) to absorb
     the slack in shorter cards. */
  .grid{display:grid; grid-template-columns:repeat(auto-fill,minmax(22rem,1fr));
    gap:1rem; align-items:stretch; margin-top:1.3rem}
  .tile{background:var(--card); border:1px solid var(--line); border-left:3px solid var(--tc);
    border-radius:14px; padding:1rem 1.1rem 1.05rem; display:flex; flex-direction:column; gap:.7rem;
    margin:0; transition:box-shadow .15s, transform .15s}
  .tile:hover{box-shadow:0 12px 34px rgba(0,0,0,.09); transform:translateY(-2px)}
  .thead{display:flex; align-items:center; gap:.6rem}
  .ico{flex:none; width:2.3rem; height:2.3rem; border-radius:10px; display:grid; place-items:center;
    font-size:1.2rem; background:color-mix(in srgb, var(--tc) 16%, transparent)}
  .tname{font-weight:700; font-size:1.06rem; letter-spacing:-.01em; line-height:1.1}
  .ttag{font-size:.63rem; letter-spacing:.11em; text-transform:uppercase; color:var(--muted); margin-top:.12rem}
  .cnt{margin-left:auto; align-self:flex-start; font-size:.7rem; font-weight:700; white-space:nowrap;
    color:color-mix(in srgb, var(--tc) 70%, var(--ink));
    background:color-mix(in srgb, var(--tc) 14%, transparent); padding:.22rem .55rem; border-radius:20px}
  .tdesc{margin:0; font-size:.85rem; color:var(--muted); line-height:1.45}
  /* per-card keyword tags (scannable + indexable text for SEO) */
  .tags{display:flex; flex-wrap:wrap; gap:.3rem; margin:0}
  .tag{font-size:.66rem; font-weight:600; white-space:nowrap;
    color:color-mix(in srgb, var(--tg,var(--tc)) 70%, var(--ink));
    background:color-mix(in srgb, var(--tg,var(--tc)) 15%, transparent);
    border:1px solid color-mix(in srgb, var(--tg,var(--tc)) 34%, transparent);
    border-radius:6px; padding:.13rem .42rem}
  /* card tags use the brand indigo — --tg left unset, so it falls back to
     --tc (= var(--accent)). One recognizable identity, no per-tag rainbow. */
  /* Start CTA — brand accent (consistent across cards + the resume banner);
     white text in light theme, dark text on the lighter dark-theme accent.
     order:2 places it AFTER the footer pills so the button is the last element,
     pinned to the card bottom → Start/Continue buttons align across every row. */
  .start{order:-2; display:flex; align-items:center; justify-content:center; gap:.4rem; text-decoration:none;
    font-size:.84rem; font-weight:700; color:#fff; background:var(--accent);
    border-radius:9px; padding:.55rem .9rem; transition:filter .12s, transform .08s}
  /* dark mode: dim the bright accent fill so the CTA isn't harsh on the eyes.
     One rule covers Start (lavender) and Continue (green, via .is-started's
     --accent override); light text stays legible on the muted fill. */
  html[data-theme="dark"] .start{color:var(--ink);
    background:color-mix(in srgb, var(--accent) 60%, var(--card))}
  .start:hover{filter:brightness(1.06)}
  .start:active{transform:scale(.99)}
  /* estimated read time per track */
  .rtime{display:flex; align-items:center; gap:.34rem; font-size:.73rem; color:var(--muted)}
  .rtime::before{content:""; flex:none; width:.72rem; height:.72rem; border-radius:50%;
    border:1.5px solid currentColor; box-shadow:inset 0 -.2rem 0 -.13rem currentColor}
  /* started state: a resume glyph on the Continue button */
  .tile.is-started .start::before{content:"\\21BB"; font-weight:700; margin-right:.15rem}
  /* in-progress card: its own green "continue" accent (distinct from the indigo
     "start" cards), applied to the eyebrow, ring, progress bar, and button */
  .tile.is-started{--accent:var(--good); border-color:color-mix(in srgb, var(--accent) 45%, var(--line));
    box-shadow:0 0 0 1px color-mix(in srgb, var(--accent) 28%, transparent)}
  /* keep white-on-green Continue above AA in light theme */
  html[data-theme="light"] .tile.is-started .start{background:color-mix(in srgb, var(--good) 86%, #000)}
  .tile.is-started::before{content:"\\21BB  Continue where you left off"; order:-3;
    font-size:.62rem; letter-spacing:.07em; text-transform:uppercase; font-weight:800; color:var(--accent)}
  /* per-card progress (replaces the read-time line once a track is started) */
  .cprog{display:flex; flex-direction:column; gap:.34rem}
  .ctop{display:flex; justify-content:space-between; align-items:center; gap:.5rem}
  .cstep{font-size:.73rem; font-weight:700; color:var(--accent)}
  /* per-card reset — subtle, subordinate to the Continue CTA */
  .creset{font:inherit; font-size:.68rem; font-weight:600; cursor:pointer; background:none; border:0;
    color:var(--muted); padding:.1rem .25rem; border-radius:6px; line-height:1;
    text-decoration:underline; text-underline-offset:2px; transition:color .12s, transform .08s}
  .creset:hover{color:var(--accent)}
  .creset:active{transform:scale(.96)}
  .cbar{height:.42rem; border-radius:99px; overflow:hidden;
    background:color-mix(in srgb, var(--accent) 18%, transparent)}
  .cfill{display:block; height:100%; border-radius:99px; background:var(--accent)}
  .lessons{display:flex; flex-direction:column; gap:.18rem}
  a.lchip{display:flex; align-items:center; gap:.55rem; text-decoration:none; color:var(--ink);
    font-size:.85rem; padding:.32rem .4rem; border-radius:8px; transition:background .12s}
  a.lchip:hover{background:var(--chip)}
  a.lchip i{flex:none; font-style:normal; min-width:1.5rem; height:1.5rem; padding:0 .35rem; border-radius:6px;
    display:grid; place-items:center; font-size:.72rem; font-weight:700; color:#fff; background:var(--tc)}
  a.lchip span{line-height:1.2}
  /* lesson list collapses into a native <details>: on mobile a tap-to-expand
     summary keeps cards short; on desktop the summary is hidden and lessons
     stay visible (the open attribute is synced to viewport by a small script). */
  /* lesson list hidden from the card (kept in the DOM for SEO/crawlers);
     the header Start button is the entry point into a track now */
  .lwrap{display:none}
  .lwrap > summary{list-style:none; cursor:pointer}
  .lwrap > summary::-webkit-details-marker{display:none}
  .lsum{display:flex; align-items:center; gap:.4rem; font-size:.8rem; font-weight:700; color:var(--tc);
    padding:.45rem .6rem; border-radius:8px; user-select:none;
    background:color-mix(in srgb, var(--tc) 9%, transparent); transition:background .12s}
  .lsum::after{content:"\\25BE"; margin-left:auto; font-weight:400; transition:transform .15s}
  .lwrap[open] .lsum::after{transform:rotate(180deg)}
  .lwrap[open] > summary{margin-bottom:.3rem}
  .lsum:hover{background:color-mix(in srgb, var(--tc) 16%, transparent)}
  .lsum:active{background:color-mix(in srgb, var(--tc) 24%, transparent)}
  .tfoot{margin-top:auto; display:flex; flex-wrap:wrap; gap:.4rem; padding-top:.7rem; border-top:1px solid var(--line)}
  a.pill{font-size:.73rem; text-decoration:none; color:var(--ink); background:var(--chip);
    border:1px solid transparent; border-radius:20px; padding:.3rem .62rem; transition:filter .12s, background .12s}
  a.pill:hover{background:var(--line)}
  a.pill.md{color:var(--ink); font-weight:500}
  /* ── home redesign: name/tagline rows, START HERE badge, difficulty dots, next-lesson link ── */
  .tmeta{min-width:0}
  .tnamerow{display:flex; align-items:center; gap:.45rem; flex-wrap:wrap}
  .ttagrow{display:flex; align-items:center; gap:.45rem; flex-wrap:wrap; margin-top:.14rem}
  .badge{font-size:.6rem; font-weight:800; letter-spacing:.06em; text-transform:uppercase; white-space:nowrap;
    color:#7a5c00; background:#ffd84d; border:1px solid #e8b800; border-radius:20px; padding:.12rem .45rem}
  html[data-theme="dark"] .badge{color:#171200; background:#e6c34a; border-color:#c9a52f}
  .newpill{font-size:.6rem; font-weight:800; letter-spacing:.06em; text-transform:uppercase; white-space:nowrap;
    color:#fff; background:var(--accent); border:1px solid var(--accent); border-radius:20px; padding:.12rem .45rem}
  html[data-theme="dark"] .newpill{color:#15140f}
  .lvl{display:inline-flex; align-items:center; gap:.3rem; font-size:.6rem; font-weight:700;
    letter-spacing:.08em; text-transform:uppercase; color:var(--muted)}
  .lvl .dots{display:inline-flex; gap:.16rem}
  .lvl .dots .d{width:.4rem; height:.4rem; border-radius:50%; background:currentColor; opacity:.28}
  .lvl .dots .d.on{opacity:1; color:color-mix(in srgb, var(--tc) 80%, var(--ink))}
  .cnext-wrap{font-size:.82rem; line-height:1.45; color:var(--muted)}
  .cnext-lbl{font-weight:600}
  a.cnext{text-decoration:none; font-weight:700; color:color-mix(in srgb, var(--tc) 78%, var(--ink))}
  a.cnext:hover{text-decoration:underline}
  /* bottom sheet: Start/Continue is the prominent last element (full-width final row) */
  .cs-foot .start{order:0; flex-basis:100%; width:100%; margin-top:.15rem}
  a.epub{font-size:.73rem; font-weight:700; text-decoration:none; color:#fff; background:var(--tc);
    border-radius:20px; padding:.3rem .66rem; transition:opacity .12s}
  a.epub:hover{opacity:.88}

  .empty{display:none; text-align:center; color:var(--muted); padding:3rem 1rem; font-size:.95rem}

  /* full-text search results (replaces the grid while searching) */
  .results{display:none; margin-top:1.3rem}
  .results .rhead{font-size:.78rem; color:var(--muted); margin:0 0 .7rem}
  a.ritem{display:flex; align-items:center; gap:.7rem; text-decoration:none; color:var(--ink);
    background:var(--card); border:1px solid var(--line); border-radius:10px; padding:.6rem .8rem; margin:0 0 .5rem}
  a.ritem:hover, a.ritem.sel{border-color:var(--rtc,var(--ink)); background:var(--chip)}
  .ritem .rdot{flex:none; width:.62rem; height:.62rem; border-radius:50%; background:var(--rtc,#888)}
  .ritem .rcol{display:flex; flex-direction:column; min-width:0}
  .ritem .rt{font-weight:600; font-size:.92rem; line-height:1.25}
  .ritem .rg{font-size:.7rem; color:var(--muted); margin-top:.08rem}
  .ritem .rkind{margin-left:auto; flex:none; font-size:.62rem; letter-spacing:.08em; text-transform:uppercase;
    color:var(--muted); border:1px solid var(--line); border-radius:5px; padding:.12rem .4rem; white-space:nowrap}

  /* no-results empty state — turns a dead end into the track catalog */
  .nr{text-align:center; padding:1.6rem .2rem .4rem}
  .nr-ic{width:3rem; height:3rem; margin:0 auto .6rem; display:grid; place-items:center; border-radius:50%;
