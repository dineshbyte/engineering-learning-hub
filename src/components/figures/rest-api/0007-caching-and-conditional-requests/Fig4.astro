---
/**
 * rest-api/0007 · Figure 4 — the fresh → stale → revalidate lifecycle of a
 * stored response, ending in 304 (keep) or 200 (replace); stale-while-revalidate
 * hides the round-trip.
 *
 * Copied VERBATIM from the source HTML (figure + svg + figcaption). Lives as an
 * .astro component for the kebab-case-SVG reason. Markers (#arw, #arwG) come
 * from the source's global hidden <svg>, inlined here in a local <defs>,
 * fills/ids verbatim.
 */
---

<figure>
    <svg
        viewBox="0 0 640 150"
        role="img"
        aria-label="A cached response is fresh until max-age elapses, then goes stale; on next use the cache revalidates with a conditional request, getting either 304 to keep it or 200 to replace it"
    >
        <defs>
            <marker
                id="arw"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path></marker
            >
            <marker
                id="arwG"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#2f5d3a"></path></marker
            >
        </defs>
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <text
                x="320"
                y="18"
                text-anchor="middle"
                font-size="12"
                font-weight="700"
                fill="#111110">A STORED RESPONSE OVER ITS LIFETIME</text
            >
            <rect x="10" y="40" width="150" height="56" rx="9" fill="#eef5ee" stroke="#2f5d3a"
            ></rect>
            <text x="85" y="64" text-anchor="middle" font-size="12" font-weight="700" fill="#2f5d3a"
                >FRESH</text
            >
            <text x="85" y="81" text-anchor="middle" font-size="9" fill="#244a2e"
                >within max-age · served free</text
            >
            <line x1="160" y1="68" x2="186" y2="68" stroke="#6b675f" marker-end="url(#arw)"></line>
            <text x="173" y="58" text-anchor="middle" font-size="8" fill="#6b675f">max-age</text>
            <text x="173" y="100" text-anchor="middle" font-size="8" fill="#6b675f">elapses</text>
            <rect x="188" y="40" width="150" height="56" rx="9" fill="#f7ecea" stroke="#9a2417"
            ></rect>
            <text
                x="263"
                y="64"
                text-anchor="middle"
                font-size="12"
                font-weight="700"
                fill="#9a2417">STALE</text
            >
            <text x="263" y="81" text-anchor="middle" font-size="9" fill="#7a2218"
                >expired · must revalidate</text
            >
            <line x1="338" y1="68" x2="364" y2="68" stroke="#6b675f" marker-end="url(#arw)"></line>
            <rect x="366" y="40" width="160" height="56" rx="9" fill="#eef2f5" stroke="#1f3a5a"
            ></rect>
            <text
                x="446"
                y="64"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#1f3a5a">REVALIDATE</text
            >
            <text x="446" y="81" text-anchor="middle" font-size="9" fill="#1f3a5a"
                >conditional GET (ETag)</text
            >
            <rect x="540" y="26" width="92" height="40" rx="8" fill="#eef5ee" stroke="#2f5d3a"
            ></rect>
            <text
                x="586"
                y="44"
                text-anchor="middle"
                font-size="10"
                font-weight="700"
                fill="#2f5d3a">304 → keep</text
            >
            <text x="586" y="58" text-anchor="middle" font-size="8" fill="#244a2e"
                >reset freshness</text
            >
            <rect x="540" y="72" width="92" height="40" rx="8" fill="#fff" stroke="#1f3a5a"></rect>
            <text
                x="586"
                y="90"
                text-anchor="middle"
                font-size="10"
                font-weight="700"
                fill="#1f3a5a">200 → replace</text
            >
            <text x="586" y="104" text-anchor="middle" font-size="8" fill="#1f3a5a"
                >new body+ETag</text
            >
            <path
                d="M 526 60 C 532 52, 535 50, 540 48"
                fill="none"
                stroke="#2f5d3a"
                marker-end="url(#arwG)"></path>
            <path
                d="M 526 76 C 532 84, 535 88, 540 90"
                fill="none"
                stroke="#1f3a5a"
                marker-end="url(#arw)"></path>
            <text x="320" y="136" text-anchor="middle" font-size="9.5" fill="#2f5d3a"
                ><tspan font-weight="700">stale-while-revalidate</tspan> serves the stale copy instantly
                and revalidates in the background — hiding the round-trip from the user.</text
            >
        </g>
    </svg>
    <figcaption>
        Stale is not dead: a stale entry is revalidated, not re-downloaded. A <code>304</code> resets
        its freshness window; a <code>200</code> replaces it.
    </figcaption>
</figure>
