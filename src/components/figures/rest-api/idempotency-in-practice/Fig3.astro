---
/**
 * rest-api/0003 · Figure 3 — "the Idempotency-Key pattern": client mints a key,
 * server checks a key→response store; a NEW key executes-and-saves, a SEEN key
 * replays the saved response.
 *
 * Copied VERBATIM from the source HTML (figure + svg + figcaption). Lives as an
 * .astro component for the kebab-case-SVG reason. The markers it references
 * (#arw, #arwG) come from the source's global hidden <svg>, which does not travel
 * with the figure, so they're inlined here in a local <defs>, fills/ids verbatim.
 */
---

<figure>
    <svg
        viewBox="0 0 640 230"
        role="img"
        aria-label="Client sends an idempotency key; server checks a key-to-response store; a new key executes and saves, a seen key replays the saved response"
    >
        <defs>
            <marker
                id="arw"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path></marker
            >
            <marker
                id="arwG"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#2f5d3a"></path></marker
            >
        </defs>
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <text
                x="320"
                y="18"
                text-anchor="middle"
                font-size="12"
                font-weight="700"
                fill="#111110">THE IDEMPOTENCY-KEY PATTERN</text
            >
            <rect
                x="14"
                y="88"
                width="140"
                height="56"
                rx="9"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text
                x="84"
                y="112"
                text-anchor="middle"
                font-size="12"
                font-weight="700"
                fill="#7a1f12">Client</text
            >
            <text x="84" y="129" text-anchor="middle" font-size="9" fill="#6b675f"
                >mints key = abc (UUID)</text
            >
            <line x1="154" y1="116" x2="198" y2="116" stroke="#6b675f" marker-end="url(#arw)"
            ></line>
            <text x="176" y="108" text-anchor="middle" font-size="8.5" fill="#6b675f"
                >Idempotency-Key: abc</text
            >
            <rect x="200" y="88" width="116" height="56" rx="9" fill="#fff" stroke="#d8d4c8"></rect>
            <text x="258" y="119" text-anchor="middle" font-size="12" font-weight="700">Server</text
            >
            <line x1="316" y1="116" x2="368" y2="116" stroke="#6b675f" marker-end="url(#arw)"
            ></line>
            <rect x="370" y="88" width="150" height="56" rx="9" fill="#fff" stroke="#1f3a5a"></rect>
            <text
                x="445"
                y="111"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#1f3a5a">key → response store</text
            >
            <text x="445" y="128" text-anchor="middle" font-size="9" fill="#6b675f"
                >durable · TTL ~24h</text
            >
            <rect x="430" y="14" width="200" height="44" rx="9" fill="#eef5ee" stroke="#2f5d3a"
            ></rect>
            <text
                x="530"
                y="33"
                text-anchor="middle"
                font-size="10.5"
                font-weight="700"
                fill="#2f5d3a">NEW key</text
            >
            <text x="530" y="48" text-anchor="middle" font-size="9" fill="#244a2e"
                >execute once, then save response</text
            >
            <rect x="430" y="172" width="200" height="44" rx="9" fill="#eef2f5" stroke="#1f3a5a"
            ></rect>
            <text
                x="530"
                y="191"
                text-anchor="middle"
                font-size="10.5"
                font-weight="700"
                fill="#1f3a5a">SEEN key</text
            >
            <text x="530" y="206" text-anchor="middle" font-size="9" fill="#1f3a5a"
                >replay saved response — no re-run</text
            >
            <path
                d="M 470 88 C 480 70, 490 62, 500 58"
                fill="none"
                stroke="#2f5d3a"
                marker-end="url(#arwG)"></path>
            <path
                d="M 470 144 C 480 162, 490 168, 500 172"
                fill="none"
                stroke="#1f3a5a"
                marker-end="url(#arw)"></path>
        </g>
    </svg>
    <figcaption>
        Same key on every retry of one intent. The first executes; the rest replay — duplicate
        delivery becomes harmless.
    </figcaption>
</figure>
