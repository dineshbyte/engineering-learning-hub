---
/**
 * production-ai-architecture/0001 · Shared arrowhead marker defs.
 *
 * Copied VERBATIM from the top of <body> in
 * docs/production-ai-architecture/lessons/0001-reviewing-ai-like-a-distributed-system.html.
 * In the source this is a single 0×0 absolutely-positioned <svg> holding the four
 * <marker> defs (#arw, #arwG, #arwR, #arwM) that the figures reference via
 * marker-end="url(#…)". It lives as a component (rendered ONCE, before the
 * figures) so the marker ids resolve document-wide and the figures stay byte-
 * for-byte verbatim — inline SVG with kebab-case attrs is unreliable in MDX.
 */
---

<svg width="0" height="0" style="position:absolute" aria-hidden="true"
    ><defs>
        <marker
            id="arw"
            viewBox="0 0 10 10"
            refX="8.5"
            refY="5"
            markerWidth="7"
            markerHeight="7"
            orient="auto-start-reverse"><path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path></marker
        >
        <marker
            id="arwG"
            viewBox="0 0 10 10"
            refX="8.5"
            refY="5"
            markerWidth="7"
            markerHeight="7"
            orient="auto-start-reverse"><path d="M0,0 L10,5 L0,10 z" fill="#2f5d3a"></path></marker
        >
        <marker
            id="arwR"
            viewBox="0 0 10 10"
            refX="8.5"
            refY="5"
            markerWidth="7"
            markerHeight="7"
            orient="auto-start-reverse"><path d="M0,0 L10,5 L0,10 z" fill="#9a2417"></path></marker
        >
        <marker
