    >
        <rect width="660" height="250" fill="#fffff8"></rect>
        <text x="330" y="26" text-anchor="middle" font-size="15" fill="#0f4f47" font-weight="bold"
            >10&#215; fewer false positives &#8594; +4.8 bits/item, +3 hashes</text
        >
        <text x="16" y="74" font-size="14" fill="#111110">p = 1%</text>
        <rect x="96" y="58" width="173" height="26" rx="4" fill="#9fe7da" stroke="#0f4f47"></rect>
        <text x="104" y="76" font-size="13" fill="#0f4f47">9.6 bits/item</text>
        <rect x="290" y="58" width="86" height="26" rx="4" fill="#eef5ee" stroke="#2f5d3a"></rect>
        <text x="333" y="76" text-anchor="middle" font-size="13" fill="#2f5d3a">k = 7</text>
        <text x="16" y="134" font-size="14" fill="#111110">p = 0.1%</text>
        <rect x="96" y="118" width="259" height="26" rx="4" fill="#5fb3a6" stroke="#0f4f47"></rect>
        <text x="104" y="136" font-size="13" fill="#053b34">14.4 bits/item</text>
        <rect x="376" y="118" width="86" height="26" rx="4" fill="#eef5ee" stroke="#2f5d3a"></rect>
        <text x="419" y="136" text-anchor="middle" font-size="13" fill="#2f5d3a">k = 10</text>
