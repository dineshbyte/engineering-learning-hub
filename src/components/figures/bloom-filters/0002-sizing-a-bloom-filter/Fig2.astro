        <rect x="96" y="178" width="345" height="26" rx="4" fill="#136f63" stroke="#0f4f47"></rect>
        <text x="104" y="196" font-size="13" fill="#ffffff">19.2 bits/item</text>
        <rect x="462" y="178" width="86" height="26" rx="4" fill="#eef5ee" stroke="#2f5d3a"></rect>
