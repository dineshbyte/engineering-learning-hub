---
/**
 * bloom-filters · 0004 · Figure 1 — "The decision matrix".
 *
 * Copied VERBATIM from docs/bloom-filters/lessons/0004-variants-at-scale.html
 * (figure + svg + figcaption incl. the footnote <sup>s). It lives as an .astro
 * component, NOT inline in the MDX, because MDX's JSX parser is unreliable with
 * raw inline SVG that uses kebab-case attributes (text-anchor, font-size,
 * stroke-width, …). In an .astro file the SVG is plain HTML, so it renders
 * byte-for-byte. SVG ids are kept as-is to match the source DOM and the #s1..#s3
 * footnote anchors.
 */
---

<figure>
    <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 680 320"
        font-family="ui-sans-serif,system-ui,sans-serif"
    >
        <rect width="680" height="320" fill="#fffff8"></rect>
        <text x="340" y="26" text-anchor="middle" font-size="15" fill="#0f4f47" font-weight="bold"
            >Four filters, four answers to "what limit do I hit?"</text
        >
        <!-- column headers -->
        <rect x="206" y="44" width="112" height="30" rx="5" fill="#e8f1ef" stroke="#136f63"
        ></rect><text
            x="262"
            y="63"
            text-anchor="middle"
            font-size="11.5"
            fill="#0f4f47"
            font-weight="bold">Delete?</text
        >
        <rect x="322" y="44" width="112" height="30" rx="5" fill="#e8f1ef" stroke="#136f63"
        ></rect><text
            x="378"
            y="63"
            text-anchor="middle"
            font-size="11.5"
            fill="#0f4f47"
            font-weight="bold">Grows w/ n?</text
        >
        <rect x="438" y="44" width="112" height="30" rx="5" fill="#e8f1ef" stroke="#136f63"
        ></rect><text
            x="494"
            y="63"
            text-anchor="middle"
            font-size="11.5"
            fill="#0f4f47"
            font-weight="bold">Space</text
        >
        <rect x="554" y="44" width="112" height="30" rx="5" fill="#e8f1ef" stroke="#136f63"
        ></rect><text
            x="610"
            y="63"
            text-anchor="middle"
            font-size="11.5"
            fill="#0f4f47"
            font-weight="bold">Locality</text
        >
        <!-- row: Standard -->
        <rect x="16" y="80" width="186" height="46" rx="6" fill="#fff" stroke="#136f63"></rect><text
            x="26"
            y="100"
            font-size="13"
            fill="#0f4f47"
            font-weight="bold">Standard Bloom</text
        ><text x="26" y="118" font-size="10.5" fill="#6b675f">the baseline</text>
        <rect x="206" y="80" width="112" height="46" rx="6" fill="#f7ecea" stroke="#9a2417"
        ></rect><text x="262" y="108" text-anchor="middle" font-size="12" fill="#9a2417">no</text>
        <rect x="322" y="80" width="112" height="46" rx="6" fill="#f7ecea" stroke="#9a2417"
        ></rect><text x="378" y="108" text-anchor="middle" font-size="12" fill="#9a2417"
            >no (fixed m)</text
        >
        <rect x="438" y="80" width="112" height="46" rx="6" fill="#eef5ee" stroke="#2f5d3a"
        ></rect><text x="494" y="108" text-anchor="middle" font-size="12" fill="#2f5d3a"
            >best (1x)</text
        >
        <rect x="554" y="80" width="112" height="46" rx="6" fill="#fbf3e6" stroke="#9a7a17"
        ></rect><text x="610" y="108" text-anchor="middle" font-size="12" fill="#7a5e12"
            >k probes</text
        >
        <!-- row: Counting -->
        <rect x="16" y="130" width="186" height="46" rx="6" fill="#fff" stroke="#136f63"
        ></rect><text x="26" y="150" font-size="13" fill="#0f4f47" font-weight="bold"
            >Counting Bloom</text
        ><text x="26" y="168" font-size="10.5" fill="#6b675f">bits &#8594; counters</text>
        <rect x="206" y="130" width="112" height="46" rx="6" fill="#eef5ee" stroke="#2f5d3a"
        ></rect><text x="262" y="158" text-anchor="middle" font-size="12" fill="#2f5d3a">yes</text>
        <rect x="322" y="130" width="112" height="46" rx="6" fill="#f7ecea" stroke="#9a2417"
        ></rect><text x="378" y="158" text-anchor="middle" font-size="12" fill="#9a2417"
            >no (fixed m)</text
        >
        <rect x="438" y="130" width="112" height="46" rx="6" fill="#f7ecea" stroke="#9a2417"
        ></rect><text x="494" y="158" text-anchor="middle" font-size="12" fill="#9a2417"
            >~4x bits</text
        >
        <rect x="554" y="130" width="112" height="46" rx="6" fill="#fbf3e6" stroke="#9a7a17"
        ></rect><text x="610" y="158" text-anchor="middle" font-size="12" fill="#7a5e12"
            >k probes</text
        >
        <!-- row: Scalable -->
        <rect x="16" y="180" width="186" height="46" rx="6" fill="#fff" stroke="#136f63"
        ></rect><text x="26" y="200" font-size="13" fill="#0f4f47" font-weight="bold"
            >Scalable Bloom</text
        ><text x="26" y="218" font-size="10.5" fill="#6b675f">chain of filters</text>
        <rect x="206" y="180" width="112" height="46" rx="6" fill="#f7ecea" stroke="#9a2417"
        ></rect><text x="262" y="208" text-anchor="middle" font-size="12" fill="#9a2417">no</text>
        <rect x="322" y="180" width="112" height="46" rx="6" fill="#eef5ee" stroke="#2f5d3a"
        ></rect><text x="378" y="208" text-anchor="middle" font-size="12" fill="#2f5d3a"
            >yes (auto)</text
        >
        <rect x="438" y="180" width="112" height="46" rx="6" fill="#fbf3e6" stroke="#9a7a17"
        ></rect><text x="494" y="208" text-anchor="middle" font-size="12" fill="#7a5e12"
            >grows w/ n</text
        >
        <rect x="554" y="180" width="112" height="46" rx="6" fill="#f7ecea" stroke="#9a2417"
        ></rect><text x="610" y="208" text-anchor="middle" font-size="12" fill="#9a2417"
            >k per layer</text
        >
        <!-- row: Cuckoo -->
        <rect x="16" y="230" width="186" height="46" rx="6" fill="#fff" stroke="#136f63"
        ></rect><text x="26" y="250" font-size="13" fill="#0f4f47" font-weight="bold"
            >Cuckoo filter</text
        ><text x="26" y="268" font-size="10.5" fill="#6b675f">fingerprint buckets</text>
        <rect x="206" y="230" width="112" height="46" rx="6" fill="#eef5ee" stroke="#2f5d3a"
        ></rect><text x="262" y="258" text-anchor="middle" font-size="12" fill="#2f5d3a">yes</text>
        <rect x="322" y="230" width="112" height="46" rx="6" fill="#f7ecea" stroke="#9a2417"
        ></rect><text x="378" y="258" text-anchor="middle" font-size="12" fill="#9a2417"
            >no (fixed)</text
        >
        <rect x="438" y="230" width="112" height="46" rx="6" fill="#eef5ee" stroke="#2f5d3a"
        ></rect><text x="494" y="258" text-anchor="middle" font-size="12" fill="#2f5d3a"
            >&lt; Bloom if p&#8804;3%</text
        >
        <rect x="554" y="230" width="112" height="46" rx="6" fill="#eef5ee" stroke="#2f5d3a"
        ></rect><text x="610" y="258" text-anchor="middle" font-size="12" fill="#2f5d3a"
            >2 buckets</text
        >
        <text x="340" y="302" text-anchor="middle" font-size="12" fill="#6b675f"
            >Green = the advantage that makes you pick it. Red = the cost you pay for it.</text
        >
    </svg>
    <figcaption>
        Each variant trades one of standard Bloom's costs for relief on a different axis.<sup
            ><a href="#s1" id="r1">1</a></sup
        ><sup><a href="#s2" id="r2">2</a></sup><sup><a href="#s3" id="r3">3</a></sup>
    </figcaption>
</figure>
