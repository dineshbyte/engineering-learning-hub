---
/**
 * streaming-event-driven · streaming-event-driven-fundamentals · Figure 2 —
 * Level 2 "Kafka": key routing on produce + one-consumer-per-partition on
 * consume. Copied VERBATIM from the source page; lives as an .astro component
 * for the same reason as Fig1 (inline kebab-case SVG is unreliable in MDX).
 * References the shared #arw marker emitted by Fig1.
 */
---

<figure>
    <svg
        viewBox="0 0 600 200"
        role="img"
        aria-label="Producers hash keys to partitions; a consumer group assigns one consumer per partition with extras idle"
    >
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <text
                x="150"
                y="20"
                text-anchor="middle"
                font-size="11.5"
                font-weight="700"
                fill="#1f3a5a">PRODUCE — hash(key) % N picks the partition</text
            >
            <rect x="12" y="34" width="120" height="22" rx="6" fill="#fff" stroke="#d8d4c8"
            ></rect><text x="22" y="49" font-size="9" fill="#111110">key=acct-42 → P3</text>
            <rect x="12" y="60" width="120" height="22" rx="6" fill="#fff" stroke="#d8d4c8"
            ></rect><text x="22" y="75" font-size="9" fill="#111110">key=acct-99 → P1</text>
            <rect x="12" y="86" width="120" height="22" rx="6" fill="#eef5ee" stroke="#2f5d3a"
            ></rect><text x="22" y="101" font-size="9" fill="#244a2e">acct-42 again → P3 ✓</text>
            <text x="72" y="126" text-anchor="middle" font-size="9" fill="#2f5d3a"
                >same key → same partition → ordered</text
            >
            <line x1="300" y1="8" x2="300" y2="160" stroke="#d8d4c8" stroke-dasharray="4 4"></line>
            <text
                x="450"
                y="20"
                text-anchor="middle"
                font-size="11.5"
                font-weight="700"
                fill="#7a1f12">CONSUME — one consumer per partition</text
            >
            <g font-size="9.5" fill="#111110" text-anchor="middle">
                <rect x="320" y="36" width="64" height="20" rx="4" fill="#fff" stroke="#d8d4c8"
                ></rect><text x="352" y="50">P0</text>
                <rect x="320" y="62" width="64" height="20" rx="4" fill="#fff" stroke="#d8d4c8"
                ></rect><text x="352" y="76">P1</text>
                <rect x="320" y="88" width="64" height="20" rx="4" fill="#fff" stroke="#d8d4c8"
                ></rect><text x="352" y="102">P2</text>
            </g>
            <line x1="384" y1="46" x2="432" y2="50" stroke="#6b675f" marker-end="url(#arw)"></line>
            <line x1="384" y1="72" x2="432" y2="68" stroke="#6b675f" marker-end="url(#arw)"></line>
            <line x1="384" y1="98" x2="432" y2="92" stroke="#6b675f" marker-end="url(#arw)"></line>
            <g font-size="9.5" fill="#7a1f12" text-anchor="middle" font-weight="700">
                <rect x="434" y="40" width="56" height="20" rx="4" fill="#f1eee2" stroke="#7a1f12"
                ></rect><text x="462" y="54">C1</text>
                <rect x="434" y="78" width="56" height="20" rx="4" fill="#f1eee2" stroke="#7a1f12"
                ></rect><text x="462" y="92">C2</text>
            </g>
            <rect x="510" y="62" width="78" height="20" rx="4" fill="#f7ecea" stroke="#9a2417"
            ></rect><text x="549" y="76" text-anchor="middle" font-size="8.5" fill="#9a2417"
                >C3 — idle</text
            >
            <text x="450" y="150" text-anchor="middle" font-size="9" fill="#9a2417"
                >3 partitions cap the group at 3 active readers</text
            >
        </g>
    </svg>
    <figcaption>
        Choose the key to be the entity whose history must stay ordered (<code>accountId</code>).
        Partition count is your throughput dial <em>and</em> your consumer-parallelism ceiling.
    </figcaption>
</figure>
