---
/**
 * streaming-event-driven · streaming-event-driven-fundamentals · Figure 1 —
 * "THE SPINE — append once, read & replay forever" (the hero banner).
 *
 * Copied VERBATIM from
 * docs/streaming-event-driven/streaming-event-driven-fundamentals.html
 * (figure + svg + figcaption). It lives as an .astro component, NOT inline in
 * the MDX, because MDX's JSX parser is unreliable with raw inline SVG that uses
 * kebab-case attributes (text-anchor, font-size, stroke-width, marker-end, …)
 * and self-referential ids. In an .astro file the SVG is plain HTML, so it
 * renders byte-for-byte.
 *
 * The source page defines three arrowhead <marker>s (arw, arwA, arwG) in a
 * single shared <svg> at the top of <body>; every inline-SVG figure references
 * them by id. That shared defs block is reproduced here (rendered once, before
 * any figure) so the marker ids resolve document-wide for Fig1–Fig3. ids are
 * kept as-is (arw, arwA, arwG, s1…) to match the source DOM + #s1 anchors.
 */
---

<svg width="0" height="0" style="position:absolute" aria-hidden="true"
    ><defs>
        <marker
            id="arw"
            viewBox="0 0 10 10"
            refX="8.5"
            refY="5"
            markerWidth="7"
            markerHeight="7"
            orient="auto-start-reverse"><path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path></marker
        >
        <marker
            id="arwA"
            viewBox="0 0 10 10"
            refX="8.5"
            refY="5"
            markerWidth="7"
            markerHeight="7"
            orient="auto-start-reverse"><path d="M0,0 L10,5 L0,10 z" fill="#7a1f12"></path></marker
        >
        <marker
            id="arwG"
            viewBox="0 0 10 10"
            refX="8.5"
            refY="5"
            markerWidth="7"
            markerHeight="7"
            orient="auto-start-reverse"><path d="M0,0 L10,5 L0,10 z" fill="#2f5d3a"></path></marker
        >
    </defs></svg
>

<figure style="margin-top:1.6rem">
    <svg
        viewBox="0 0 640 220"
        role="img"
        aria-label="The streaming spine: producers append to a partitioned log; consumer groups read by offset into derived read models, state, and windows"
    >
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <text
                x="320"
                y="24"
                text-anchor="middle"
                font-size="12"
                font-weight="700"
                fill="#111110">THE SPINE — append once, read &amp; replay forever</text
            >
            <rect x="10" y="78" width="92" height="46" rx="9" fill="#fff" stroke="#d8d4c8"></rect>
            <text
                x="56"
                y="100"
                text-anchor="middle"
                font-size="12"
                font-weight="700"
                fill="#111110">producers</text
            >
            <text x="56" y="115" text-anchor="middle" font-size="9" fill="#6b675f"
                >append facts</text
            >
            <line x1="102" y1="101" x2="132" y2="101" stroke="#6b675f" marker-end="url(#arw)"
            ></line>
            <rect
                x="134"
                y="64"
                width="200"
                height="76"
                rx="10"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text
                x="234"
                y="82"
                text-anchor="middle"
                font-size="12"
                font-weight="700"
                fill="#7a1f12">PARTITIONED LOG</text
            >
            <g font-size="9" fill="#111110" text-anchor="middle">
                <rect x="146" y="92" width="176" height="14" rx="3" fill="#fff" stroke="#d8d4c8"
                ></rect><text x="234" y="102">P0 · 0 1 2 3 4 → (ordered by offset)</text>
                <rect x="146" y="110" width="176" height="14" rx="3" fill="#fff" stroke="#d8d4c8"
                ></rect><text x="234" y="120">P1 · 0 1 2 3 → immutable, retained</text>
            </g>
            <line x1="334" y1="101" x2="364" y2="101" stroke="#6b675f" marker-end="url(#arw)"
            ></line>
            <g font-size="9.5" fill="#111110">
                <rect x="366" y="60" width="120" height="22" rx="6" fill="#fff" stroke="#1f3a5a"
                ></rect><text x="376" y="75">group A → read model</text>
                <rect x="366" y="90" width="120" height="22" rx="6" fill="#fff" stroke="#2f5d3a"
                ></rect><text x="376" y="105">group B → analytics</text>
                <rect x="366" y="120" width="120" height="22" rx="6" fill="#fff" stroke="#d8d4c8"
                ></rect><text x="376" y="135">stream job → windows</text>
            </g>
            <line x1="486" y1="71" x2="516" y2="71" stroke="#1f3a5a" marker-end="url(#arw)"></line>
            <line x1="486" y1="101" x2="516" y2="101" stroke="#2f5d3a" marker-end="url(#arwG)"
            ></line>
            <line x1="486" y1="131" x2="516" y2="131" stroke="#6b675f" marker-end="url(#arw)"
            ></line>
            <rect x="518" y="60" width="112" height="82" rx="9" fill="#eef5ee" stroke="#2f5d3a"
            ></rect>
            <text
                x="574"
                y="92"
                text-anchor="middle"
                font-size="10.5"
                font-weight="700"
                fill="#2f5d3a">DERIVED VIEWS</text
            >
            <text x="574" y="108" text-anchor="middle" font-size="9" fill="#244a2e"
                >disposable,</text
            >
            <text x="574" y="120" text-anchor="middle" font-size="9" fill="#244a2e"
                >rebuilt by replay</text
            >
            <path
                d="M 574 142 C 574 196, 234 196, 234 142"
                fill="none"
                stroke="#7a1f12"
                stroke-dasharray="4 3"
                marker-end="url(#arwA)"></path>
            <text x="404" y="190" text-anchor="middle" font-size="10" fill="#7a1f12"
                >reset offset to 0 → replay history → rebuild any view</text
            >
        </g>
    </svg>
    <figcaption>
        Memorise this banner. Every level below adds or explains one box, one arrow, or the replay
        loop.
    </figcaption>
</figure>
