---
/**
 * watermarks-deep-dive · Figure 3 — Level 3: the min rule & the idle-partition stall.
 *
 * Copied VERBATIM from docs/streaming-event-driven/watermarks-deep-dive.html
 * (figure + svg + figcaption). Lives as an .astro component for the same reason as
 * Fig1: raw inline SVG with kebab-case attributes is unreliable inside MDX. This
 * figure references all three arrowhead markers (#arw / #arwA / #arwG) that the
 * source declared once in its hidden top-of-body defs; they are inlined here in a
 * local <defs> (verbatim fills) so the figure resolves standalone.
 */
---

<figure>
    <svg
        viewBox="0 0 560 180"
        role="img"
        aria-label="Three input watermarks 14:05, 14:07 and a stale 13:40 idle partition feed an operator; the output watermark is pinned to the minimum 13:40 until idleness detection excludes the idle input."
    >
        <defs>
            <marker
                id="arw"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path></marker
            >
            <marker
                id="arwA"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#7a1f12"></path></marker
            >
            <marker
                id="arwG"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#2f5d3a"></path></marker
            >
        </defs>
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <text
                x="280"
                y="16"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#111110">output W = MIN(inputs) — the slowest input governs</text
            >
            <!-- inputs -->
            <rect x="20" y="34" width="120" height="32" rx="7" fill="#fff" stroke="#2f5d3a"
            ></rect><text x="80" y="55" text-anchor="middle" font-size="10" fill="#244a2e"
                >in A · W=14:05 ▲</text
            >
            <rect x="20" y="74" width="120" height="32" rx="7" fill="#fff" stroke="#2f5d3a"
            ></rect><text x="80" y="95" text-anchor="middle" font-size="10" fill="#244a2e"
                >in B · W=14:07 ▲</text
            >
            <rect x="20" y="114" width="120" height="32" rx="7" fill="#f7ecea" stroke="#9a2417"
            ></rect><text x="80" y="131" text-anchor="middle" font-size="10" fill="#7a2218"
                >in C · W=13:40 ✗ idle</text
            >
            <!-- operator -->
            <rect
                x="220"
                y="64"
                width="120"
                height="52"
                rx="10"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text
                x="280"
                y="86"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#7a1f12">operator</text
            >
            <text x="280" y="102" text-anchor="middle" font-size="9" fill="#6b675f"
                >W = min(...)</text
            >
            <line x1="140" y1="50" x2="218" y2="78" stroke="#6b675f" marker-end="url(#arw)"></line>
            <line x1="140" y1="90" x2="218" y2="90" stroke="#6b675f" marker-end="url(#arw)"></line>
            <line x1="140" y1="130" x2="218" y2="102" stroke="#9a2417" marker-end="url(#arwA)"
            ></line>
            <!-- output -->
            <rect x="412" y="40" width="130" height="34" rx="8" fill="#f7ecea" stroke="#9a2417"
            ></rect><text x="477" y="62" text-anchor="middle" font-size="10" fill="#7a2218"
                >W pinned to 13:40 ✗</text
            >
            <text x="477" y="92" text-anchor="middle" font-size="9" fill="#9a2417"
                >downstream windows freeze</text
            >
            <line x1="340" y1="80" x2="410" y2="62" stroke="#9a2417" marker-end="url(#arwA)"></line>
            <!-- fix -->
            <rect x="412" y="112" width="130" height="48" rx="8" fill="#eef5ee" stroke="#2f5d3a"
            ></rect>
            <text
                x="477"
                y="131"
                text-anchor="middle"
                font-size="9.5"
                font-weight="700"
                fill="#244a2e">withIdleness ✓</text
            >
            <text x="477" y="146" text-anchor="middle" font-size="8.5" fill="#244a2e"
                >exclude C → W = 14:05</text
            >
            <line
                x1="340"
                y1="100"
                x2="410"
                y2="128"
                stroke="#2f5d3a"
                stroke-dasharray="4 3"
                marker-end="url(#arwG)"></line>
        </g>
    </svg>
    <figcaption>
        A quiet input's stale watermark pins the min "forever or until it gets data." The dashboard
        shows records flowing yet <em>nothing emitted</em> — stalled, no error.
    </figcaption>
</figure>
