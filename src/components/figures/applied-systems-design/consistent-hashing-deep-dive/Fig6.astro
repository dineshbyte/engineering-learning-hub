---
/**
 * consistent-hashing-deep-dive · Figure 6 — "RENDEZVOUS (HRW) vs JUMP HASH".
 *
 * Copied VERBATIM from the source HTML (figure + svg + figcaption). Isolated as
 * an .astro component. It references marker-end="url(#arw)" (fill #6b675f); that
 * arrowhead marker was declared once in the source's top-of-body <svg defs> and
 * is inlined here in a local <defs> so the figure resolves standalone.
 */
---

<figure>
    <svg
        viewBox="0 0 560 180"
        role="img"
        aria-label="Rendezvous hashing: for a key compute weight against every node and pick the argmax; jump hash maps a key to a bucket 0 to N-1"
    >
        <defs>
            <marker
                id="arw"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path></marker
            >
        </defs>
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <!-- HRW -->
            <text
                x="150"
                y="20"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#1f3a5a">RENDEZVOUS (HRW) — pick the argmax</text
            >
            <circle cx="150" cy="48" r="9" fill="#1f3a5a"></circle><text
                x="150"
                y="78"
                text-anchor="middle"
                font-size="9"
                fill="#111110">key k</text
            >
            <g font-size="9.5" fill="#111110">
                <rect x="40" y="100" width="64" height="30" rx="6" fill="#fff" stroke="#d8d4c8"
                ></rect><text x="72" y="119" text-anchor="middle">N1 .31</text>
                <rect x="118" y="100" width="64" height="30" rx="6" fill="#eef5ee" stroke="#2f5d3a"
                ></rect><text x="150" y="119" text-anchor="middle" fill="#2f5d3a">N2 .87</text>
                <rect x="196" y="100" width="64" height="30" rx="6" fill="#fff" stroke="#d8d4c8"
                ></rect><text x="228" y="119" text-anchor="middle">N3 .52</text>
            </g>
            <line x1="120" y1="56" x2="80" y2="98" stroke="#6b675f" marker-end="url(#arw)"></line>
            <line x1="150" y1="58" x2="150" y2="98" stroke="#6b675f" marker-end="url(#arw)"></line>
            <line x1="180" y1="56" x2="220" y2="98" stroke="#6b675f" marker-end="url(#arw)"></line>
            <text x="150" y="152" text-anchor="middle" font-size="9" fill="#2f5d3a"
                >highest weight wins → N2</text
            >
            <text x="150" y="168" text-anchor="middle" font-size="9" fill="#6b675f"
                >O(N) lookup · uniform argmax → no vnodes needed</text
            >
            <line x1="290" y1="10" x2="290" y2="172" stroke="#d8d4c8" stroke-dasharray="4 4"></line>
            <!-- jump hash -->
            <text
                x="430"
                y="20"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#7a1f12">JUMP HASH — key → bucket 0…N−1</text
            >
            <g font-size="9.5" fill="#111110">
                <rect x="320" y="56" width="36" height="30" rx="5" fill="#fff" stroke="#d8d4c8"
                ></rect><text x="338" y="75" text-anchor="middle">0</text>
                <rect x="360" y="56" width="36" height="30" rx="5" fill="#fff" stroke="#d8d4c8"
                ></rect><text x="378" y="75" text-anchor="middle">1</text>
                <rect x="400" y="56" width="36" height="30" rx="5" fill="#f1eee2" stroke="#7a1f12"
                ></rect><text x="418" y="75" text-anchor="middle">2</text>
                <rect x="440" y="56" width="36" height="30" rx="5" fill="#fff" stroke="#d8d4c8"
                ></rect><text x="458" y="75" text-anchor="middle">3</text>
                <rect x="480" y="56" width="36" height="30" rx="5" fill="#eef5ee" stroke="#2f5d3a"
                ></rect><text x="498" y="75" text-anchor="middle">4</text>
            </g>
            <text x="430" y="106" text-anchor="middle" font-size="9" fill="#6b675f"
                >5 lines · no memory · perfect balance</text
            >
            <text x="430" y="124" text-anchor="middle" font-size="9" fill="#2f5d3a"
                >grow/shrink only at the HIGH end ✓</text
            >
            <text x="430" y="142" text-anchor="middle" font-size="9" fill="#9a2417"
                >✗ cannot pull an arbitrary middle bucket</text
            >
            <text x="430" y="160" text-anchor="middle" font-size="9" fill="#9a2417"
                >✗ no per-node weights</text
            >
        </g>
    </svg>
    <figcaption>
        HRW: <code>argmax over nodes of hash(k, node)</code>. Jump hash: a 5-line function mapping k
        to a bucket in <code>0…N−1</code>.
    </figcaption>
</figure>
