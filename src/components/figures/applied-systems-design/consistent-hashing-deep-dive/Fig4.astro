---
/**
 * consistent-hashing-deep-dive · Figure 4 — "1 token/node uneven vs V vnodes even".
 *
 * Copied VERBATIM from the source HTML (figure + svg + figcaption). Isolated as
 * an .astro component (MDX's JSX parser mishandles kebab-case SVG attrs). This
 * figure references no arrowhead markers, so no local <defs> is needed.
 */
---

<figure>
    <svg
        viewBox="0 0 600 200"
        role="img"
        aria-label="One token per node gives wildly uneven arcs; many vnodes per node sum to an even 1/N load with variance shrinking as 1 over root V"
    >
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <!-- left: bare ring uneven -->
            <text
                x="150"
                y="20"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#9a2417">1 token / node → uneven</text
            >
            <circle cx="150" cy="110" r="64" fill="none" stroke="#6b675f" stroke-width="1.5"
            ></circle>
            <circle cx="150" cy="46" r="7" fill="#f1eee2" stroke="#7a1f12" stroke-width="1.5"
            ></circle>
            <circle cx="205" cy="92" r="7" fill="#f1eee2" stroke="#7a1f12" stroke-width="1.5"
            ></circle>
            <circle cx="190" cy="160" r="7" fill="#f1eee2" stroke="#7a1f12" stroke-width="1.5"
            ></circle>
            <circle cx="92" cy="140" r="7" fill="#f1eee2" stroke="#7a1f12" stroke-width="1.5"
            ></circle>
            <!-- big arc highlight -->
            <path
                d="M 92 140 A 64 64 0 0 1 150 46"
                fill="none"
                stroke="#9a2417"
                stroke-width="4"
                opacity="0.5"></path>
            <text x="150" y="106" text-anchor="middle" font-size="9" fill="#9a2417"
                >one node owns</text
            >
            <text x="150" y="118" text-anchor="middle" font-size="9" fill="#9a2417">a huge arc</text
            >
            <text x="150" y="192" text-anchor="middle" font-size="9" fill="#6b675f"
                >largest arc ≈ Θ((log N)/N)</text
            >
            <!-- right: vnodes even -->
            <text
                x="450"
                y="20"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#2f5d3a">V≈100–200 vnodes / node → even</text
            >
            <circle cx="450" cy="110" r="64" fill="none" stroke="#6b675f" stroke-width="1.5"
            ></circle>
            <g stroke="#7a1f12" stroke-width="1.5">
                <circle cx="450" cy="46" r="4" fill="#f1eee2"></circle><circle
                    cx="498"
                    cy="62"
                    r="4"
                    fill="#fff"></circle><circle cx="514" cy="110" r="4" fill="#1f3a5a"></circle>
                <circle cx="498" cy="158" r="4" fill="#f1eee2"></circle><circle
                    cx="450"
                    cy="174"
                    r="4"
                    fill="#fff"></circle><circle cx="402" cy="158" r="4" fill="#1f3a5a"></circle>
                <circle cx="386" cy="110" r="4" fill="#f1eee2"></circle><circle
                    cx="402"
                    cy="62"
                    r="4"
                    fill="#fff"></circle>
                <circle cx="476" cy="50" r="4" fill="#1f3a5a"></circle><circle
                    cx="510"
                    cy="84"
                    r="4"
                    fill="#f1eee2"></circle>
                <circle cx="510" cy="136" r="4" fill="#fff"></circle><circle
                    cx="476"
                    cy="170"
                    r="4"
                    fill="#1f3a5a"></circle>
                <circle cx="424" cy="170" r="4" fill="#f1eee2"></circle><circle
                    cx="390"
                    cy="136"
                    r="4"
                    fill="#fff"></circle>
                <circle cx="390" cy="84" r="4" fill="#1f3a5a"></circle><circle
                    cx="424"
                    cy="50"
                    r="4"
                    fill="#f1eee2"></circle>
            </g>
            <text x="450" y="106" text-anchor="middle" font-size="9" fill="#2f5d3a"
                >each node = sum of</text
            >
            <text x="450" y="118" text-anchor="middle" font-size="9" fill="#2f5d3a"
                >many small arcs</text
            >
            <text x="450" y="192" text-anchor="middle" font-size="9" fill="#6b675f"
                >per-node load → 1/N, std dev ~ 1/√V</text
            >
        </g>
    </svg>
    <figcaption>
        New SVG: same physical node's vnodes share a colour. Below is the source diagram of the same
        idea.
    </figcaption>
</figure>
