---
/**
 * consistent-hashing-deep-dive · Figure 2 — "hash(key) mod N, perfect until N changes".
 *
 * Copied VERBATIM from the source HTML (figure + svg + figcaption). Isolated as
 * an .astro component (MDX's JSX parser mishandles kebab-case SVG attrs). It
 * references marker-end="url(#arwA)"; that arrowhead marker (fill #7a1f12) was
 * declared once in the source's top-of-body <svg defs> and is inlined here in a
 * local <defs> so the figure resolves standalone.
 */
---

<figure>
    <svg
        viewBox="0 0 560 170"
        role="img"
        aria-label="hash(key) mod N: balanced and O(1) but adding one node remaps almost every key because mod changes for nearly all"
    >
        <defs>
            <marker
                id="arwA"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#7a1f12"></path></marker
            >
        </defs>
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <text
                x="280"
                y="20"
                text-anchor="middle"
                font-size="12"
                font-weight="700"
                fill="#9a2417">hash(key) mod N — perfect until N changes</text
            >
            <!-- before: 4 nodes -->
            <text
                x="120"
                y="46"
                text-anchor="middle"
                font-size="10"
                font-weight="700"
                fill="#111110">N = 4</text
            >
            <g font-size="9.5" fill="#111110">
                <rect x="40" y="56" width="38" height="26" rx="5" fill="#fff" stroke="#d8d4c8"
                ></rect><text x="59" y="73" text-anchor="middle">0</text>
                <rect x="86" y="56" width="38" height="26" rx="5" fill="#fff" stroke="#d8d4c8"
                ></rect><text x="105" y="73" text-anchor="middle">1</text>
                <rect x="132" y="56" width="38" height="26" rx="5" fill="#fff" stroke="#d8d4c8"
                ></rect><text x="151" y="73" text-anchor="middle">2</text>
                <rect x="178" y="56" width="38" height="26" rx="5" fill="#fff" stroke="#d8d4c8"
                ></rect><text x="197" y="73" text-anchor="middle">3</text>
            </g>
            <text x="120" y="104" text-anchor="middle" font-size="9" fill="#6b675f"
                >key 17 → 17 mod 4 = node 1</text
            >
            <!-- arrow -->
            <line x1="232" y1="70" x2="300" y2="70" stroke="#9a2417" marker-end="url(#arwA)"></line>
            <text x="266" y="60" text-anchor="middle" font-size="9" fill="#9a2417">add 1 node</text>
            <!-- after: 5 nodes -->
            <text
                x="430"
                y="46"
                text-anchor="middle"
                font-size="10"
                font-weight="700"
                fill="#111110">N = 5</text
            >
            <g font-size="9.5" fill="#111110">
                <rect x="316" y="56" width="36" height="26" rx="5" fill="#f7ecea" stroke="#9a2417"
                ></rect><text x="334" y="73" text-anchor="middle">0</text>
                <rect x="358" y="56" width="36" height="26" rx="5" fill="#f7ecea" stroke="#9a2417"
                ></rect><text x="376" y="73" text-anchor="middle">1</text>
                <rect x="400" y="56" width="36" height="26" rx="5" fill="#f7ecea" stroke="#9a2417"
                ></rect><text x="418" y="73" text-anchor="middle">2</text>
                <rect x="442" y="56" width="36" height="26" rx="5" fill="#f7ecea" stroke="#9a2417"
                ></rect><text x="460" y="73" text-anchor="middle">3</text>
                <rect x="484" y="56" width="36" height="26" rx="5" fill="#fff" stroke="#2f5d3a"
                ></rect><text x="502" y="73" text-anchor="middle">4</text>
            </g>
            <text x="430" y="104" text-anchor="middle" font-size="9" fill="#9a2417"
                >key 17 → 17 mod 5 = node 2 (moved!)</text
            >
            <text
                x="280"
                y="138"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#9a2417">≈ only 1/(N+1) keys stay — nearly ALL keys move</text
            >
            <text x="280" y="156" text-anchor="middle" font-size="9.5" fill="#6b675f"
                >cache: every lookup misses at once → DB stampede · store: re-shuffle the whole
                dataset</text
            >
        </g>
    </svg>
    <figcaption>
        Reused from the source: <code>mod N</code> vs the ring. Below is the same comparison as a single
        ring picture.
    </figcaption>
</figure>
