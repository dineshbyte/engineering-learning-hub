---
/**
 * consistent-hashing-deep-dive · Figure 5 — "CAP = (1+ε)×avg, overflow clockwise".
 *
 * Copied VERBATIM from the source HTML (figure + svg + figcaption). Isolated as
 * an .astro component. It references marker-end="url(#arw)" (fill #6b675f) AND
 * marker-end="url(#arwA)" (fill #7a1f12); both arrowhead markers were declared
 * once in the source's top-of-body <svg defs> and are inlined here in a local
 * <defs> so the figure resolves standalone.
 */
---

<figure>
    <svg
        viewBox="0 0 560 150"
        role="img"
        aria-label="A key lands on a full node and walks clockwise past full nodes until one has spare capacity"
    >
        <defs>
            <marker
                id="arw"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path></marker
            >
            <marker
                id="arwA"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#7a1f12"></path></marker
            >
        </defs>
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <text
                x="280"
                y="20"
                text-anchor="middle"
                font-size="12"
                font-weight="700"
                fill="#111110">CAP = (1+ε) × average — full node → walk clockwise to room</text
            >
            <!-- three nodes as capacity bars -->
            <g>
                <text
                    x="90"
                    y="48"
                    text-anchor="middle"
                    font-size="10"
                    font-weight="700"
                    fill="#9a2417">N1 (home)</text
                >
                <rect x="50" y="56" width="80" height="64" rx="6" fill="#fff" stroke="#9a2417"
                ></rect>
                <rect x="50" y="58" width="80" height="60" rx="5" fill="#f7ecea"></rect>
                <line x1="50" y1="62" x2="130" y2="62" stroke="#9a2417" stroke-dasharray="3 2"
                ></line>
                <text x="90" y="92" text-anchor="middle" font-size="9" fill="#9a2417">FULL</text>
            </g>
            <g>
                <text
                    x="260"
                    y="48"
                    text-anchor="middle"
                    font-size="10"
                    font-weight="700"
                    fill="#9a2417">N2</text
                >
                <rect x="220" y="56" width="80" height="64" rx="6" fill="#fff" stroke="#9a2417"
                ></rect>
                <rect x="220" y="60" width="80" height="58" rx="5" fill="#f7ecea"></rect>
                <line x1="220" y1="62" x2="300" y2="62" stroke="#9a2417" stroke-dasharray="3 2"
                ></line>
                <text x="260" y="92" text-anchor="middle" font-size="9" fill="#9a2417">FULL</text>
            </g>
            <g>
                <text
                    x="430"
                    y="48"
                    text-anchor="middle"
                    font-size="10"
                    font-weight="700"
                    fill="#2f5d3a">N3</text
                >
                <rect x="390" y="56" width="80" height="64" rx="6" fill="#fff" stroke="#2f5d3a"
                ></rect>
                <rect x="390" y="92" width="80" height="26" rx="5" fill="#eef5ee"></rect>
                <line x1="390" y1="62" x2="470" y2="62" stroke="#2f5d3a" stroke-dasharray="3 2"
                ></line>
                <text x="430" y="108" text-anchor="middle" font-size="9" fill="#2f5d3a"
                    >has room ✓</text
                >
            </g>
            <!-- key + walk arrows -->
            <circle cx="20" cy="88" r="5" fill="#1f3a5a"></circle><text
                x="20"
                y="74"
                text-anchor="middle"
                font-size="9"
                fill="#1f3a5a">key</text
            >
            <line x1="26" y1="88" x2="48" y2="88" stroke="#1f3a5a" marker-end="url(#arw)"></line>
            <line
                x1="132"
                y1="100"
                x2="218"
                y2="100"
                stroke="#7a1f12"
                stroke-dasharray="4 3"
                marker-end="url(#arwA)"></line>
            <line
                x1="302"
                y1="100"
                x2="388"
                y2="100"
                stroke="#7a1f12"
                stroke-dasharray="4 3"
                marker-end="url(#arwA)"></line>
            <text x="280" y="140" text-anchor="middle" font-size="9.5" fill="#6b675f"
                >small ε = tight balance, more overflow churn · large ε = looser, cheaper</text
            >
        </g>
    </svg>
    <figcaption>
        New SVG: the overflow walk. The guarantee — <em
            >no node ever exceeds <code>(1+ε)×</code> average</em
        > — holds while a membership change still moves only a bounded fraction of keys.
    </figcaption>
</figure>
