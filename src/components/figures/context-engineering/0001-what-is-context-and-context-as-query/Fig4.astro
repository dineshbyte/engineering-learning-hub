---
/**
 * context-engineering 0001 ┬Ę Figure 4 ŌĆö the classic requestŌåÆSQLŌåÆdatabaseŌåÆresponse
 * pipeline beside questionŌåÆretrievalŌåÆLLMŌåÆresponse.
 *
 * Copied VERBATIM from the source HTML (figure + svg + figcaption incl. footnote
 * <sup>). Lives as an .astro component so the kebab-case SVG attributes render
 * byte-for-byte. The source defined arrowhead markers once in a shared <defs> in
 * the document <body>; this figure references arw and arwM, inlined here.
 */
---

<figure>
    <svg
        viewBox="0 0 640 270"
        role="img"
        aria-label="Classic request-SQL-database-response pipeline beside question-retrieval-LLM-response."
    >
        <defs>
            <marker
                id="arw"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path></marker
            >
            <marker
                id="arwM"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#b5179e"></path></marker
            >
        </defs>
        <!-- headers -->
        <text x="160" y="20" text-anchor="middle" font-size="12" font-weight="700" fill="#1f3a5a"
            >Classic software</text
        >
        <text x="480" y="20" text-anchor="middle" font-size="12" font-weight="700" fill="#b5179e"
            >AI system</text
        >

        <!-- left pipeline -->
        <rect x="80" y="32" width="160" height="38" rx="7" fill="#eef2f7" stroke="#1f3a5a"
        ></rect><text
            x="160"
            y="56"
            text-anchor="middle"
            font-size="10.5"
            font-weight="700"
            fill="#111110">Request</text
        >
        <rect x="80" y="92" width="160" height="38" rx="7" fill="#eef2f7" stroke="#1f3a5a"
        ></rect><text
            x="160"
            y="116"
            text-anchor="middle"
            font-size="10.5"
            font-weight="700"
            fill="#1f3a5a">SQL query</text
        >
        <rect x="80" y="152" width="160" height="38" rx="7" fill="#eef2f7" stroke="#1f3a5a"
        ></rect><text
            x="160"
            y="170"
            text-anchor="middle"
            font-size="10.5"
            font-weight="700"
            fill="#111110">Database</text
        ><text x="160" y="183" text-anchor="middle" font-size="8" fill="#6b675f"
            >source of truth ┬Ę swappable engine</text
        >
        <rect x="80" y="212" width="160" height="38" rx="7" fill="#eef2f7" stroke="#1f3a5a"
        ></rect><text
            x="160"
            y="236"
            text-anchor="middle"
            font-size="10.5"
            font-weight="700"
            fill="#111110">Response</text
        >
        <line x1="160" y1="70" x2="160" y2="90" stroke="#6b675f" marker-end="url(#arw)"></line>
        <line x1="160" y1="130" x2="160" y2="150" stroke="#6b675f" marker-end="url(#arw)"></line>
        <line x1="160" y1="190" x2="160" y2="210" stroke="#6b675f" marker-end="url(#arw)"></line>

        <!-- right pipeline -->
        <rect x="400" y="32" width="160" height="38" rx="7" fill="#f6eef7" stroke="#b5179e"
        ></rect><text
            x="480"
            y="56"
            text-anchor="middle"
            font-size="10.5"
            font-weight="700"
            fill="#111110">Question</text
        >
        <rect
            x="400"
            y="92"
            width="160"
            height="38"
            rx="7"
            fill="#f6eef7"
            stroke="#b5179e"
            stroke-width="2"></rect><text
            x="480"
            y="110"
            text-anchor="middle"
            font-size="10.5"
            font-weight="700"
            fill="#b5179e">Context retrieval</text
        ><text x="480" y="123" text-anchor="middle" font-size="8" fill="#6b675f"
            >&larr; the new query lives here</text
        >
        <rect x="400" y="152" width="160" height="38" rx="7" fill="#f6eef7" stroke="#b5179e"
        ></rect><text
            x="480"
            y="170"
            text-anchor="middle"
            font-size="10.5"
            font-weight="700"
            fill="#111110">LLM</text
        ><text x="480" y="183" text-anchor="middle" font-size="8" fill="#6b675f"
            >fixed ┬Ę commodity ┬Ę same for everyone</text
        >
        <rect x="400" y="212" width="160" height="38" rx="7" fill="#f6eef7" stroke="#b5179e"
        ></rect><text
            x="480"
            y="236"
            text-anchor="middle"
            font-size="10.5"
            font-weight="700"
            fill="#111110">Answer</text
        >
        <line x1="480" y1="70" x2="480" y2="90" stroke="#6b675f" marker-end="url(#arw)"></line>
        <line x1="480" y1="130" x2="480" y2="150" stroke="#6b675f" marker-end="url(#arw)"></line>
        <line x1="480" y1="190" x2="480" y2="210" stroke="#6b675f" marker-end="url(#arw)"></line>

        <!-- the swap annotation -->
        <line
            x1="248"
            y1="111"
            x2="392"
            y2="111"
            stroke="#b5179e"
            stroke-dasharray="4 3"
            marker-end="url(#arwM)"></line>
        <text x="320" y="105" text-anchor="middle" font-size="8.5" font-weight="700" fill="#b5179e"
            >same role</text
        >
    </svg>
    <figcaption>
        Map the two pipelines row-for-row. <b>SQL query &harr; context retrieval</b>; <b
            >database &harr; LLM</b
        >. The cleverness that used to live in the query and schema now lives in <em
            >what you retrieve and assemble</em
        >.<sup><a href="#s4" id="r4">4</a></sup>
    </figcaption>
</figure>
