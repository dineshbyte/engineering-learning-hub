---
/**
 * context-engineering/0007 · Figure 2 — Module 1 "Insert a transform step BEFORE
 * retrieval". Copied VERBATIM from the source HTML (figure + svg + figcaption
 * incl. the footnote <sup>). Carries its own <defs> for the arrowhead markers the
 * shared top-of-body <svg> provided in the source.
 */
---

<figure>
    <svg
        viewBox="0 0 640 180"
        role="img"
        aria-label="A pre-retrieval transformation stage inserted between the question and retrieval, turning one raw query into several better ones."
    >
        <defs>
            <marker
                id="arw"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path></marker
            >
            <marker
                id="arwG"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#2f5d3a"></path></marker
            >
        </defs>
        <text x="320" y="18" text-anchor="middle" font-size="11.5" font-weight="700" fill="#111110"
            >Insert a transform step BEFORE retrieval</text
        >
        <!-- raw question -->
        <rect x="24" y="62" width="118" height="48" rx="8" fill="#fbecec" stroke="#9a2417"
        ></rect><text
            x="83"
            y="82"
            text-anchor="middle"
            font-size="10"
            font-weight="700"
            fill="#9a2417">Raw query</text
        ><text x="83" y="98" text-anchor="middle" font-size="8" fill="#6b675f"
            >"why is it slow?"</text
        >
        <!-- transform -->
        <rect
            x="200"
            y="46"
            width="150"
            height="80"
            rx="10"
            fill="#f6eef7"
            stroke="#b5179e"
            stroke-width="2"></rect><text
            x="275"
            y="68"
            text-anchor="middle"
            font-size="10.5"
            font-weight="700"
            fill="#b5179e">Pre-retrieval transform</text
        ><text x="275" y="86" text-anchor="middle" font-size="8" fill="#6b675f"
            >rewrite · expand · HyDE</text
        ><text x="275" y="100" text-anchor="middle" font-size="8" fill="#6b675f"
            >decompose · step-back</text
        ><text x="275" y="114" text-anchor="middle" font-size="8" fill="#6b675f"
            >route to the right index</text
        >
        <!-- better queries -->
        <rect x="410" y="40" width="150" height="26" rx="6" fill="#e9f3ec" stroke="#2f5d3a"
        ></rect><text x="485" y="57" text-anchor="middle" font-size="8.5" fill="#2f5d3a"
            >"latency p99 checkout API"</text
        >
        <rect x="410" y="74" width="150" height="26" rx="6" fill="#e9f3ec" stroke="#2f5d3a"
        ></rect><text x="485" y="91" text-anchor="middle" font-size="8.5" fill="#2f5d3a"
            >"db connection pool size"</text
        >
        <rect x="410" y="108" width="150" height="26" rx="6" fill="#e9f3ec" stroke="#2f5d3a"
        ></rect><text x="485" y="125" text-anchor="middle" font-size="8.5" fill="#2f5d3a"
            >hypothetical answer doc</text
        >
        <!-- retrieval -->
        <rect x="410" y="146" width="150" height="0" fill="none"></rect>
        <line x1="142" y1="86" x2="198" y2="86" stroke="#6b675f" marker-end="url(#arw)"></line>
        <line x1="352" y1="70" x2="406" y2="56" stroke="#2f5d3a" marker-end="url(#arwG)"></line>
        <line x1="352" y1="86" x2="406" y2="87" stroke="#2f5d3a" marker-end="url(#arwG)"></line>
        <line x1="352" y1="102" x2="406" y2="118" stroke="#2f5d3a" marker-end="url(#arwG)"></line>
        <text x="590" y="91" text-anchor="end" font-size="8" font-style="italic" fill="#b5179e"
            >&rarr; retrieve each, union</text
        >
    </svg>
    <figcaption>
        One vague query in, several precise queries (or a hypothetical answer) out. The model that
        answers is unchanged; you hand the index a better search than the user typed.<sup
            ><a href="#s2" id="r2">2</a></sup
        >
    </figcaption>
</figure>
