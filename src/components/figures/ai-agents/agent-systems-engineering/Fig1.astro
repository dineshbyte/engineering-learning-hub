---
/**
 * ai-agents · 0005 · Figure 1 — single prompt vs agent vs agent system.
 *
 * Copied VERBATIM from
 * docs/ai-agents/lessons/0005-agent-systems-engineering.html
 * (figure + svg + figcaption). It lives as an .astro component, NOT inline in
 * the MDX, because MDX's JSX parser is unreliable with raw inline SVG that uses
 * kebab-case attributes (text-anchor, font-size, stroke-width, marker-end, …).
 * In an .astro file the SVG is plain HTML, so it renders byte-for-byte. The
 * marker refs (url(#arw) etc.) resolve against the shared <defs> SVG emitted
 * once at the top of the lesson body.
 */
---

<figure>
    <svg
        viewBox="0 0 620 222"
        role="img"
        aria-label="Complexity growing across three stages: a single prompt, an agent, and an agent system"
    >
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <!-- Col labels -->
            <text
                x="105"
                y="15"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#6b675f"
                letter-spacing=".06em">SINGLE PROMPT</text
            >
            <text
                x="310"
                y="15"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#6b675f"
                letter-spacing=".06em">AGENT</text
            >
            <text
                x="515"
                y="15"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#6b675f"
                letter-spacing=".06em">AGENT SYSTEM</text
            >
            <!-- Col 1 -->
            <rect x="20" y="26" width="170" height="150" rx="8" fill="#fff" stroke="#d8d4c8"></rect>
            <text
                x="105"
                y="46"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#111110">f(text) &#8594; text</text
            >
            <text x="105" y="70" text-anchor="middle" font-size="10.5" fill="#6b675f"
                >1 LLM call</text
            >
            <text x="105" y="90" text-anchor="middle" font-size="10.5" fill="#6b675f"
                >stateless</text
            >
            <text x="105" y="110" text-anchor="middle" font-size="10.5" fill="#6b675f"
                >no tools</text
            >
            <text x="105" y="130" text-anchor="middle" font-size="10.5" fill="#6b675f">no loop</text
            >
            <!-- Col 2 -->
            <rect
                x="225"
                y="26"
                width="170"
                height="150"
                rx="8"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.4"></rect>
            <text
                x="310"
                y="46"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#7a1f12">LLM + tools + loop</text
            >
            <text x="310" y="70" text-anchor="middle" font-size="10.5" fill="#6b675f"
                >+ tool calling</text
            >
            <text x="310" y="90" text-anchor="middle" font-size="10.5" fill="#6b675f"
                >+ agent loop</text
            >
            <text x="310" y="110" text-anchor="middle" font-size="10.5" fill="#6b675f"
                >+ working state</text
            >
            <text x="310" y="130" text-anchor="middle" font-size="10.5" fill="#6b675f"
                >decides next step</text
            >
            <!-- Col 3 -->
            <rect
                x="430"
                y="26"
                width="170"
                height="150"
                rx="8"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="2"></rect>
            <text
                x="515"
                y="46"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#7a1f12">a production system</text
            >
            <text x="515" y="68" text-anchor="middle" font-size="10.5" fill="#6b675f"
                >+ planning</text
            >
            <text x="515" y="86" text-anchor="middle" font-size="10.5" fill="#6b675f"
                >+ orchestration</text
            >
            <text x="515" y="104" text-anchor="middle" font-size="10.5" fill="#6b675f"
                >+ failure recovery</text
            >
            <text x="515" y="122" text-anchor="middle" font-size="10.5" fill="#6b675f"
                >+ persistence</text
            >
            <text x="515" y="140" text-anchor="middle" font-size="10.5" fill="#6b675f"
                >+ cost &amp; observability</text
            >
            <!-- complexity meters -->
            <text
                x="310"
                y="194"
                text-anchor="middle"
                font-size="9"
                fill="#9c968a"
                letter-spacing=".05em">MOVING PARTS &#8594; OPERATIONAL SURFACE</text
            >
            <rect x="20" y="200" width="170" height="9" rx="4" fill="#ececdf"></rect><rect
                x="20"
                y="200"
                width="34"
                height="9"
                rx="4"
                fill="#2f7d4f"></rect>
            <rect x="225" y="200" width="170" height="9" rx="4" fill="#ececdf"></rect><rect
                x="225"
                y="200"
                width="92"
                height="9"
                rx="4"
                fill="#b07d18"></rect>
            <rect x="430" y="200" width="170" height="9" rx="4" fill="#ececdf"></rect><rect
                x="430"
                y="200"
                width="170"
                height="9"
                rx="4"
                fill="#9a2417"></rect>
        </g>
    </svg>
    <figcaption>
        Each step right adds a class of problem that did not exist before. ASE is everything in the
        third box &mdash; the part that is engineering, not prompting.
    </figcaption>
</figure>
