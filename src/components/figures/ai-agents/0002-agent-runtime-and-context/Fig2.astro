---
/**
 * ai-agents 0002 · Figure 2 — "The six runtime responsibilities".
 *
 * Copied VERBATIM from docs/ai-agents/lessons/0002-agent-runtime-and-context.html
 * (figure + svg + figcaption). Lives as an .astro component so the inline SVG with
 * kebab-case attributes renders byte-for-byte (MDX's JSX parser mangles it). This
 * figure uses no arrowhead markers — only plain connector <line>s — so no <defs>.
 */
---

<figure style="margin-top:1.4rem">
    <svg
        viewBox="0 0 560 160"
        role="img"
        aria-label="Six runtime responsibilities surrounding a central Runtime circle: Loop Orchestration, Tool Execution, State Management, Retry and Backoff, Cost Control, Safety Limits"
    >
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <!-- Central circle -->
            <circle cx="280" cy="80" r="38" fill="#f1eee2" stroke="#7a1f12" stroke-width="1.5"
            ></circle>
            <text
                x="280"
                y="77"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="12"
                font-weight="700"
                fill="#7a1f12">Runtime</text
            >
            <text
                x="280"
                y="93"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="9"
                fill="#6b675f">responsibilities</text
            >

            <!-- Top row boxes -->
            <rect x="20" y="12" width="130" height="38" rx="7" fill="#fbfaf2" stroke="#d8d4c8"
            ></rect>
            <text
                x="85"
                y="35"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="10.5"
                fill="#111110">Loop Orchestration</text
            >

            <rect x="215" y="12" width="130" height="38" rx="7" fill="#fbfaf2" stroke="#d8d4c8"
            ></rect>
            <text
                x="280"
                y="35"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="10.5"
                fill="#111110">Tool Execution</text
            >

            <rect x="410" y="12" width="130" height="38" rx="7" fill="#fbfaf2" stroke="#d8d4c8"
            ></rect>
            <text
                x="475"
                y="35"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="10.5"
                fill="#111110">State Management</text
            >

            <!-- Bottom row boxes -->
            <rect x="20" y="110" width="130" height="38" rx="7" fill="#fbfaf2" stroke="#d8d4c8"
            ></rect>
            <text
                x="85"
                y="133"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="10.5"
                fill="#111110">Retry &amp; Backoff</text
            >

            <rect x="215" y="110" width="130" height="38" rx="7" fill="#fbfaf2" stroke="#d8d4c8"
            ></rect>
            <text
                x="280"
                y="133"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="10.5"
                fill="#111110">Cost Control</text
            >

            <rect x="410" y="110" width="130" height="38" rx="7" fill="#fbfaf2" stroke="#d8d4c8"
            ></rect>
            <text
                x="475"
                y="133"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="10.5"
                fill="#111110">Safety Limits</text
            >

            <!-- Lines from center to boxes -->
            <line x1="245" y1="64" x2="150" y2="50" stroke="#d8d4c8"></line>
            <line x1="280" y1="42" x2="280" y2="50" stroke="#d8d4c8"></line>
            <line x1="315" y1="64" x2="410" y2="50" stroke="#d8d4c8"></line>
            <line x1="245" y1="96" x2="150" y2="110" stroke="#d8d4c8"></line>
            <line x1="280" y1="118" x2="280" y2="110" stroke="#d8d4c8"></line>
            <line x1="315" y1="96" x2="410" y2="110" stroke="#d8d4c8"></line>
        </g>
    </svg>
    <figcaption>
        The six responsibilities the runtime owns. None of these happen inside the LLM &#8212; they
        are all code you write or configure.
    </figcaption>
</figure>
