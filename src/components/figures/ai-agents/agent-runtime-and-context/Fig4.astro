---
/**
 * ai-agents 0002 · Figure 4 — "The three memory tiers".
 *
 * Copied VERBATIM from docs/ai-agents/lessons/0002-agent-runtime-and-context.html
 * (figure + svg + figcaption incl. the footnote <sup>). Lives as an .astro
 * component so the inline SVG renders byte-for-byte. The single arrowhead marker
 * it references (`arw`, defined once in the source document's shared <defs>) is
 * inlined into this figure's own <defs>. The figcaption keeps the #s4 footnote
 * back-ref so the body's Sources anchors still resolve.
 */
---

<figure>
    <svg
        viewBox="0 0 580 200"
        role="img"
        aria-label="Three memory tiers: Short-term conversation history, Working scratchpad, and Long-term knowledge base, all connected to a central Agent circle. Below each tier are human analogies: RAM, Notepad, Company Wiki"
    >
        <defs>
            <marker
                id="arw"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path></marker
            >
        </defs>
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <!-- Short-term tier -->
            <rect
                x="10"
                y="20"
                width="148"
                height="90"
                rx="9"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text
                x="84"
                y="42"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="12"
                font-weight="700"
                fill="#7a1f12">Short-term</text
            >
            <text
                x="84"
                y="62"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="10.5"
                fill="#111110">Conversation History</text
            >
            <text
                x="84"
                y="80"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="8.5"
                fill="#6b675f">RAM — lives in context window,</text
            >
            <text
                x="84"
                y="94"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="8.5"
                fill="#6b675f">gone on reset</text
            >

            <!-- Working tier -->
            <rect
                x="216"
                y="20"
                width="148"
                height="90"
                rx="9"
                fill="#eef2f5"
                stroke="#1f3a5a"
                stroke-width="1.5"></rect>
            <text
                x="290"
                y="42"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="12"
                font-weight="700"
                fill="#1f3a5a">Working</text
            >
            <text
                x="290"
                y="62"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="10.5"
                fill="#111110">Scratchpad / Plan</text
            >
            <text
                x="290"
                y="80"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="8.5"
                fill="#6b675f">CPU registers — current task</text
            >
            <text
                x="290"
                y="94"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="8.5"
                fill="#6b675f">notes, tool outputs</text
            >

            <!-- Long-term tier -->
            <rect
                x="422"
                y="20"
                width="148"
                height="90"
                rx="9"
                fill="#eef5ee"
                stroke="#2f5d3a"
                stroke-width="1.5"></rect>
            <text
                x="496"
                y="42"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="12"
                font-weight="700"
                fill="#2f5d3a">Long-term</text
            >
            <text
                x="496"
                y="62"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="10.5"
                fill="#111110">Knowledge Base / Facts</text
            >
            <text
                x="496"
                y="80"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="8.5"
                fill="#6b675f">Disk — survives sessions,</text
            >
            <text
                x="496"
                y="94"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="8.5"
                fill="#6b675f">retrieved on demand</text
            >

            <!-- Central Agent circle -->
            <circle cx="290" cy="148" r="28" fill="#f1eee2" stroke="#7a1f12" stroke-width="1.5"
            ></circle>
            <text
                x="290"
                y="145"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="12"
                font-weight="700"
                fill="#7a1f12">Agent</text
            >
            <text
                x="290"
                y="161"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="9"
                fill="#6b675f">runtime</text
            >

            <!-- Bidirectional arrows to Agent -->
            <line x1="120" y1="112" x2="265" y2="136" stroke="#6b675f" marker-end="url(#arw)"
            ></line>
            <line x1="262" y1="132" x2="116" y2="112" stroke="#6b675f" marker-end="url(#arw)"
            ></line>

            <line x1="290" y1="112" x2="290" y2="120" stroke="#6b675f" marker-end="url(#arw)"
            ></line>
            <line x1="290" y1="120" x2="290" y2="112" stroke="#6b675f" marker-end="url(#arw)"
            ></line>

            <line x1="460" y1="112" x2="315" y2="136" stroke="#6b675f" marker-end="url(#arw)"
            ></line>
            <line x1="318" y1="132" x2="464" y2="112" stroke="#6b675f" marker-end="url(#arw)"
            ></line>

            <!-- Human analogies below -->
            <text
                x="84"
                y="188"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="9.5"
                fill="#9a2417">RAM</text
            >
            <text
                x="290"
                y="188"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="9.5"
                fill="#1f3a5a">Notepad</text
            >
            <text
                x="496"
                y="188"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="9.5"
                fill="#2f5d3a">Company Wiki</text
            >
        </g>
    </svg>
    <figcaption>
        Three memory tiers &#8212; each with a different storage backend, durability, and retrieval
        cost.<sup><a href="#s4" id="r4">4</a></sup>
    </figcaption>
</figure>
