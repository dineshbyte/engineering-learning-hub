---
/**
 * ai-agents/0001 · Figure 10 — Level 9, Single vs Multi-agent
 * (single = one box; multi = an orchestrator delegating to parallel subagents
 * that synthesize an answer).
 * Verbatim from source; shared <marker>s inlined + namespaced (-f10). See Fig1.
 */
---

<figure>
    <svg
        viewBox="0 0 560 215"
        role="img"
        aria-label="Single agent is one box; multi-agent is an orchestrator delegating to parallel subagents that synthesize an answer"
    >
        <defs>
            <marker
                id="arw-f10"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
            >
                <path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path>
            </marker>
            <marker
                id="arwG-f10"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
            >
                <path d="M0,0 L10,5 L0,10 z" fill="#2f5d3a"></path>
            </marker>
        </defs>
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <text
                x="135"
                y="20"
                text-anchor="middle"
                font-size="11.5"
                font-weight="700"
                fill="#1f3a5a">SINGLE — monolith</text
            >
            <rect x="80" y="56" width="110" height="44" rx="9" fill="#f1eee2" stroke="#7a1f12"
            ></rect><text
                x="135"
                y="82"
                text-anchor="middle"
                font-size="12"
                font-weight="700"
                fill="#7a1f12">agent</text
            >
            <rect x="95" y="120" width="80" height="30" rx="7" fill="#fff" stroke="#d8d4c8"
            ></rect><text x="135" y="140" text-anchor="middle" font-size="10">tools</text>
            <line x1="135" y1="100" x2="135" y2="118" stroke="#6b675f" marker-end="url(#arw-f10)"
            ></line>
            <text x="135" y="180" text-anchor="middle" font-size="10" fill="#2f5d3a"
                >simple · cheap · easy to trace</text
            >
            <line x1="288" y1="8" x2="288" y2="200" stroke="#d8d4c8" stroke-dasharray="4 4"></line>
            <text
                x="430"
                y="20"
                text-anchor="middle"
                font-size="11.5"
                font-weight="700"
                fill="#7a1f12">MULTI — orchestrator-worker</text
            >
            <rect x="368" y="40" width="124" height="36" rx="9" fill="#f1eee2" stroke="#7a1f12"
            ></rect><text
                x="430"
                y="63"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#7a1f12">orchestrator</text
            >
            <g fill="#fff" stroke="#d8d4c8"
                ><rect x="338" y="108" width="56" height="32" rx="7"></rect><rect
                    x="402"
                    y="108"
                    width="56"
                    height="32"
                    rx="7"></rect><rect x="466" y="108" width="56" height="32" rx="7"></rect></g
            >
            <g font-size="10" text-anchor="middle" fill="#111110"
                ><text x="366" y="128">sub</text><text x="430" y="128">sub</text><text
                    x="494"
                    y="128">sub</text
                ></g
            >
            <g stroke="#6b675f"
                ><line x1="400" y1="76" x2="366" y2="106" marker-end="url(#arw-f10)"></line><line
                    x1="430"
                    y1="76"
                    x2="430"
                    y2="106"
                    marker-end="url(#arw-f10)"></line><line
                    x1="460"
                    y1="76"
                    x2="494"
                    y2="106"
                    marker-end="url(#arw-f10)"></line></g
            >
            <rect x="392" y="168" width="76" height="28" rx="14" fill="#eef5ee" stroke="#2f5d3a"
            ></rect><text
                x="430"
                y="186"
                text-anchor="middle"
                font-size="10"
                font-weight="700"
                fill="#2f5d3a">answer</text
            >
            <g stroke="#2f5d3a" stroke-dasharray="3 3"
                ><line x1="366" y1="140" x2="406" y2="167" marker-end="url(#arwG-f10)"></line><line
                    x1="430"
                    y1="140"
                    x2="430"
                    y2="167"
                    marker-end="url(#arwG-f10)"></line><line
                    x1="494"
                    y1="140"
                    x2="454"
                    y2="167"
                    marker-end="url(#arwG-f10)"></line></g
            >
        </g>
    </svg>
    <figcaption>
        Anthropic's research system: lead + 3–5 parallel subagents beat single-agent by 90.2% — at
        ~15× the tokens.<sup><a href="#s2" id="r2">2</a></sup>
    </figcaption>
</figure>
