---
/**
 * ai-agents/0001 · Figure 6 — Level 5, the Agent runtime
 * (a container holding the loop: LLM ⇄ tools ⇄ memory store, enforcing limits).
 * Verbatim from source; shared <marker> inlined + namespaced (-f6). See Fig1.
 */
---

<figure>
    <svg
        viewBox="0 0 520 180"
        role="img"
        aria-label="The runtime is a container holding the loop, calling the LLM, dispatching tools, enforcing limits"
    >
        <defs>
            <marker
                id="arw-f6"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
            >
                <path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path>
            </marker>
        </defs>
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <rect
                x="8"
                y="10"
                width="504"
                height="158"
                rx="12"
                fill="#fbfaf2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text x="24" y="32" font-size="12" font-weight="700" fill="#7a1f12"
                >AGENT RUNTIME — your ordinary code</text
            >
            <rect x="40" y="70" width="110" height="44" rx="9" fill="#f1eee2" stroke="#7a1f12"
            ></rect><text
                x="95"
                y="97"
                text-anchor="middle"
                font-size="13"
                font-weight="700"
                fill="#7a1f12">LLM</text
            >
            <rect x="205" y="70" width="110" height="44" rx="9" fill="#fff" stroke="#d8d4c8"
            ></rect><text x="260" y="97" text-anchor="middle" font-size="12" fill="#111110"
                >tools</text
            >
            <rect x="370" y="70" width="110" height="44" rx="9" fill="#fff" stroke="#d8d4c8"
            ></rect><text x="425" y="97" text-anchor="middle" font-size="12" fill="#111110"
                >memory store</text
            >
            <line x1="150" y1="92" x2="203" y2="92" stroke="#6b675f" marker-end="url(#arw-f6)"
            ></line><line
                x1="203"
                y1="86"
                x2="152"
                y2="86"
                stroke="#6b675f"
                marker-end="url(#arw-f6)"></line>
            <line x1="315" y1="92" x2="368" y2="92" stroke="#6b675f" marker-end="url(#arw-f6)"
            ></line><line
                x1="368"
                y1="86"
                x2="317"
                y2="86"
                stroke="#6b675f"
                marker-end="url(#arw-f6)"></line>
            <text x="260" y="142" text-anchor="middle" font-size="10.5" fill="#6b675f"
                >holds state · calls LLM · dispatches tools · enforces max-steps, timeouts, retries,
                permissions</text
            >
        </g>
    </svg>
    <figcaption>The model is a <em>guest</em> in this house; the house sets the rules.</figcaption>
</figure>
