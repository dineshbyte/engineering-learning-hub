---
/**
 * ai-agents · 0005 · Figure 6 — autonomy dial: blast radius → required human
 * gate, four columns. Verbatim from the source HTML (carries its own inline
 * <defs> linearGradient id="auton").
 */
---

<figure>
    <svg
        viewBox="0 0 620 178"
        role="img"
        aria-label="An autonomy dial mapping action blast radius to the required human gate, from auto-execute reads to mandatory approval for irreversible actions"
    >
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <text
                x="310"
                y="16"
                text-anchor="middle"
                font-size="10.5"
                font-weight="700"
                fill="#6b675f"
                letter-spacing=".05em">BLAST RADIUS &#8594; REQUIRED GATE</text
            >
            <!-- gradient bar -->
            <defs>
                <linearGradient id="auton" x1="0" y1="0" x2="1" y2="0">
                    <stop offset="0" stop-color="#2f7d4f"></stop><stop
                        offset="0.5"
                        stop-color="#b07d18"></stop><stop offset="1" stop-color="#9a2417"></stop>
                </linearGradient>
            </defs>
            <rect x="20" y="30" width="580" height="14" rx="7" fill="url(#auton)"></rect>
            <text x="30" y="41" font-size="9" font-weight="700" fill="#fff">LOW</text>
            <text x="570" y="41" text-anchor="end" font-size="9" font-weight="700" fill="#fff"
                >HIGH</text
            >
            <!-- four columns -->
            <g>
                <rect x="20" y="60" width="135" height="100" rx="8" fill="#eef5ee" stroke="#2f5d3a"
                ></rect>
                <text
                    x="87"
                    y="80"
                    text-anchor="middle"
                    font-size="10"
                    font-weight="700"
                    fill="#2f5d3a">Auto-execute</text
                >
                <text x="87" y="98" text-anchor="middle" font-size="8.5" fill="#2f5d3a"
                    >reversible reads</text
                >
                <text x="87" y="118" text-anchor="middle" font-size="9" fill="#111110"
                    >read logs</text
                >
                <text x="87" y="134" text-anchor="middle" font-size="9" fill="#111110"
                    >search KB</text
                >
                <text x="87" y="150" text-anchor="middle" font-size="9" fill="#111110"
                    >draft text</text
                >
            </g>
            <g>
                <rect x="163" y="60" width="135" height="100" rx="8" fill="#f3f7ec" stroke="#7a8a3f"
                ></rect>
                <text
                    x="230"
                    y="80"
                    text-anchor="middle"
                    font-size="10"
                    font-weight="700"
                    fill="#5c6a2a">Auto + log</text
                >
                <text x="230" y="98" text-anchor="middle" font-size="8.5" fill="#5c6a2a"
                    >low-value writes</text
                >
                <text x="230" y="118" text-anchor="middle" font-size="9" fill="#111110"
                    >refund &#8804; $25</text
                >
                <text x="230" y="134" text-anchor="middle" font-size="9" fill="#111110"
                    >restart pod</text
                >
                <text x="230" y="150" text-anchor="middle" font-size="9" fill="#111110"
                    >send draft email</text
                >
            </g>
            <g>
                <rect x="306" y="60" width="135" height="100" rx="8" fill="#fbf3e6" stroke="#b07d18"
                ></rect>
                <text
                    x="373"
                    y="80"
                    text-anchor="middle"
                    font-size="10"
                    font-weight="700"
                    fill="#8a5e0f">Approve first</text
                >
                <text x="373" y="98" text-anchor="middle" font-size="8.5" fill="#8a5e0f"
                    >high-value / scoped</text
                >
                <text x="373" y="118" text-anchor="middle" font-size="9" fill="#111110"
                    >deploy to prod</text
                >
                <text x="373" y="134" text-anchor="middle" font-size="9" fill="#111110"
                    >refund &gt; $100</text
                >
                <text x="373" y="150" text-anchor="middle" font-size="9" fill="#111110"
                    >email a customer</text
                >
            </g>
            <g>
                <rect x="449" y="60" width="151" height="100" rx="8" fill="#f7ecea" stroke="#9a2417"
                ></rect>
                <text
                    x="524"
                    y="80"
                    text-anchor="middle"
                    font-size="10"
                    font-weight="700"
                    fill="#9a2417">Mandatory gate</text
                >
                <text x="524" y="98" text-anchor="middle" font-size="8.5" fill="#9a2417"
                    >irreversible / mass</text
                >
                <text x="524" y="118" text-anchor="middle" font-size="9" fill="#111110"
                    >delete workspace</text
                >
                <text x="524" y="134" text-anchor="middle" font-size="9" fill="#111110"
                    >drop database</text
                >
                <text x="524" y="150" text-anchor="middle" font-size="9" fill="#111110"
                    >scale to zero</text
                >
            </g>
        </g>
    </svg>
    <figcaption>
        One agent, four gates &mdash; chosen per action by reversibility and blast radius. "Delete
        workspace" and "read logs" should never sit behind the same policy.
    </figcaption>
</figure>
