---
/**
 * ai-agents/0003 · Figure 3 — "MCP chain" (M6: business function → … → Agent LLM).
 *
 * Copied VERBATIM from docs/ai-agents/lessons/0003-how-coding-agents-work.html.
 * Kept as an .astro component (not inline MDX) so the kebab-case SVG attributes
 * render byte-for-byte. marker-end/marker-start url(#arw)/url(#arwA) reference the
 * shared <defs> arrowheads emitted once in the MDX body.
 */
---

<figure>
    <svg
        viewBox="0 0 620 220"
        role="img"
        aria-label="MCP chain diagram showing Business Function flowing down through Tool, Tool Registry, MCP Tool, MCP Server, then bidirectional with MCP Client in Agent runtime, then up to Agent LLM"
    >
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <!-- Business Function -->
            <rect
                x="180"
                y="10"
                width="260"
                height="32"
                rx="5"
                fill="#fff"
                stroke="#d8d4c8"
                stroke-width="1.3"></rect>
            <text x="310" y="25" text-anchor="middle" font-size="11" fill="#111110"
                >Business Function</text
            >
            <text x="310" y="38" text-anchor="middle" font-size="9" fill="#6b675f"
                >(e.g. Check Invoice Status)</text
            >

            <line
                x1="310"
                y1="42"
                x2="310"
                y2="57"
                stroke="#7a1f12"
                stroke-width="1.5"
                marker-end="url(#arwA)"></line>

            <!-- Tool -->
            <rect
                x="210"
                y="59"
                width="200"
                height="30"
                rx="5"
                fill="#fff"
                stroke="#d8d4c8"
                stroke-width="1.3"></rect>
            <text x="310" y="75" text-anchor="middle" font-size="11" fill="#111110">Tool</text>
            <text x="310" y="85" text-anchor="middle" font-size="9" fill="#6b675f"
                >(function / API wrapper)</text
            >

            <line
                x1="310"
                y1="89"
                x2="310"
                y2="104"
                stroke="#7a1f12"
                stroke-width="1.5"
                marker-end="url(#arwA)"></line>

            <!-- Tool Registry -->
            <rect
                x="210"
                y="106"
                width="200"
                height="30"
                rx="5"
                fill="#fff"
                stroke="#d8d4c8"
                stroke-width="1.3"></rect>
            <text x="310" y="120" text-anchor="middle" font-size="11" fill="#111110"
                >Tool Registry</text
            >
            <text x="310" y="131" text-anchor="middle" font-size="9" fill="#6b675f"
                >What tools exist?</text
            >

            <line
                x1="310"
                y1="136"
                x2="310"
                y2="151"
                stroke="#7a1f12"
                stroke-width="1.5"
                marker-end="url(#arwA)"></line>

            <!-- MCP Tool -->
            <rect
                x="210"
                y="153"
                width="200"
                height="30"
                rx="5"
                fill="#fff"
                stroke="#d8d4c8"
                stroke-width="1.3"></rect>
            <text x="310" y="167" text-anchor="middle" font-size="11" fill="#111110">MCP Tool</text>
            <text x="310" y="178" text-anchor="middle" font-size="9" fill="#6b675f"
                >Standardized description + schema</text
            >

            <line
                x1="310"
                y1="183"
                x2="310"
                y2="198"
                stroke="#7a1f12"
                stroke-width="1.5"
                marker-end="url(#arwA)"></line>

            <!-- MCP Server / Client row -->
            <rect
                x="50"
                y="200"
                width="200"
                height="16"
                rx="4"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text
                x="150"
                y="212"
                text-anchor="middle"
                font-size="10"
                fill="#111110"
                font-weight="600">MCP Server</text
            >

            <!-- Double-headed arrow between server and client -->
            <line
                x1="250"
                y1="208"
                x2="370"
                y2="208"
                stroke="#6b675f"
                stroke-width="1.5"
                marker-end="url(#arw)"
                marker-start="url(#arw)"></line>
            <text x="310" y="205" text-anchor="middle" font-size="8" fill="#6b675f"
                >JSON-RPC / stdio / SSE</text
            >

            <rect
                x="370"
                y="200"
                width="200"
                height="16"
                rx="4"
                fill="#fff"
                stroke="#d8d4c8"
                stroke-width="1.3"></rect>
            <text x="470" y="212" text-anchor="middle" font-size="10" fill="#111110"
                >MCP Client (Agent runtime)</text
            >

            <!-- MCP Client -> Agent LLM (top right) -->
            <line
                x1="520"
                y1="200"
                x2="560"
                y2="75"
                stroke="#6b675f"
                stroke-width="1.3"
                marker-end="url(#arw)"></line>

            <!-- Agent LLM -->
            <rect
                x="550"
                y="50"
                width="60"
                height="32"
                rx="5"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text x="580" y="64" text-anchor="middle" font-size="9" fill="#111110" font-weight="600"
                >Agent</text
            >
            <text x="580" y="76" text-anchor="middle" font-size="9" fill="#111110">LLM</text>
        </g>
    </svg>
    <figcaption>
        MCP standardizes the tool-agent interface. Write one MCP server; every MCP-compatible agent
        can use your tools without any additional integration.
    </figcaption>
</figure>
