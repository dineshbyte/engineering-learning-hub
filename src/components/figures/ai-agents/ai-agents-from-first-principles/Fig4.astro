---
/**
 * ai-agents/0001 · Figure 4 — Level 3, Agent
 * (Agent = LLM + tools + loop + goal; the model picks each step).
 * Verbatim from source; shared <marker> inlined + namespaced (-f4). See Fig1.
 */
---

<figure>
    <svg
        viewBox="0 0 520 150"
        role="img"
        aria-label="Agent equals LLM plus tools plus loop plus goal, choosing each step"
    >
        <defs>
            <marker
                id="arw-f4"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
            >
                <path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path>
            </marker>
        </defs>
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <rect
                x="8"
                y="44"
                width="150"
                height="62"
                rx="10"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text x="83" y="68" text-anchor="middle" font-size="13" font-weight="700" fill="#7a1f12"
                >AGENT</text
            >
            <text x="83" y="86" text-anchor="middle" font-size="9.5" fill="#6b675f"
                >LLM + tools + loop + goal</text
            >
            <line x1="158" y1="75" x2="196" y2="75" stroke="#6b675f" marker-end="url(#arw-f4)"
            ></line>
            <text x="177" y="66" text-anchor="middle" font-size="9" fill="#6b675f"
                >model picks each step</text
            >
            <g font-size="10.5" fill="#111110">
                <rect x="200" y="14" width="220" height="24" rx="6" fill="#fff" stroke="#d8d4c8"
                ></rect><text x="210" y="30">get_order(42) → charged twice</text>
                <rect x="200" y="44" width="220" height="24" rx="6" fill="#fff" stroke="#d8d4c8"
                ></rect><text x="210" y="60">get_payments(42) → 2 charges</text>
                <rect x="200" y="74" width="220" height="24" rx="6" fill="#fff" stroke="#d8d4c8"
                ></rect><text x="210" y="90">refund(payment 2) → ok</text>
                <rect x="200" y="104" width="220" height="24" rx="6" fill="#eef5ee" stroke="#2f5d3a"
                ></rect><text x="210" y="120" fill="#2f5d3a">notify_customer(42) → done ✓</text>
            </g>
        </g>
    </svg>
    <figcaption>
        Same LLM as Level 1 — the intelligence added is <em>structural</em>: a loop, tools, and a
        goal.
    </figcaption>
</figure>
