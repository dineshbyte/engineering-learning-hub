---
/**
 * ai-agents/0001 · Figure 1 — the HERO request path
 * (User → Agent → Tool → Billing → Database, with the result looping back).
 *
 * Copied VERBATIM from
 * docs/ai-agents/lessons/0001-ai-agents-from-first-principles.html, with two
 * faithful adjustments required to make it a self-contained MDX component:
 *   1. The shared arrowhead <marker>s (arw/arwA/arwG) that the source defines once
 *      in a top-level <svg> in <body> are inlined here as a per-figure <defs>.
 *   2. To keep ids unique across the 11 figures that all render on one page, the
 *      marker ids are namespaced (-f1) and the marker-end refs updated to match.
 * Geometry, colours and text are otherwise byte-for-byte the source. SVG lives in
 * an .astro file (not inline MDX) because MDX's JSX parser is unreliable with raw
 * inline SVG that uses kebab-case attributes.
 */
---

<figure style="margin-top:1.6rem">
    <svg
        viewBox="0 0 640 210"
        role="img"
        aria-label="Request path: User to Agent to Tool to Billing service to Database, with result looping back"
    >
        <defs>
            <marker
                id="arw-f1"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
            >
                <path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path>
            </marker>
            <marker
                id="arwA-f1"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
            >
                <path d="M0,0 L10,5 L0,10 z" fill="#7a1f12"></path>
            </marker>
        </defs>
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <g>
                <rect x="10" y="64" width="96" height="46" rx="9" fill="#fff" stroke="#d8d4c8"
                ></rect>
                <text
                    x="58"
                    y="84"
                    text-anchor="middle"
                    font-size="14"
                    font-weight="700"
                    fill="#111110">User</text
                >
                <text x="58" y="100" text-anchor="middle" font-size="10" fill="#6b675f">intent</text
                >
            </g>
            <g>
                <rect
                    x="142"
                    y="64"
                    width="96"
                    height="46"
                    rx="9"
                    fill="#f1eee2"
                    stroke="#7a1f12"
                    stroke-width="1.5"></rect>
                <text
                    x="190"
                    y="84"
                    text-anchor="middle"
                    font-size="14"
                    font-weight="700"
                    fill="#7a1f12">Agent</text
                >
                <text x="190" y="100" text-anchor="middle" font-size="10" fill="#6b675f"
                    >LLM + loop</text
                >
            </g>
            <g>
                <rect x="274" y="64" width="96" height="46" rx="9" fill="#fff" stroke="#d8d4c8"
                ></rect>
                <text
                    x="322"
                    y="84"
                    text-anchor="middle"
                    font-size="14"
                    font-weight="700"
                    fill="#111110">Tool</text
                >
                <text x="322" y="100" text-anchor="middle" font-size="10" fill="#6b675f"
                    >model asks</text
                >
            </g>
            <g>
                <rect x="406" y="64" width="96" height="46" rx="9" fill="#fff" stroke="#d8d4c8"
                ></rect>
                <text
                    x="454"
                    y="84"
                    text-anchor="middle"
                    font-size="13"
                    font-weight="700"
                    fill="#111110">Billing</text
                >
                <text x="454" y="100" text-anchor="middle" font-size="10" fill="#6b675f"
                    >service</text
                >
            </g>
            <g>
                <rect x="538" y="64" width="92" height="46" rx="9" fill="#fff" stroke="#d8d4c8"
                ></rect>
                <text
                    x="584"
                    y="84"
                    text-anchor="middle"
                    font-size="13"
                    font-weight="700"
                    fill="#111110">Database</text
                >
                <text x="584" y="100" text-anchor="middle" font-size="10" fill="#6b675f">state</text
                >
            </g>
            <line x1="108" y1="87" x2="140" y2="87" stroke="#6b675f" marker-end="url(#arw-f1)"
            ></line>
            <line x1="240" y1="87" x2="272" y2="87" stroke="#6b675f" marker-end="url(#arw-f1)"
            ></line>
            <line x1="372" y1="87" x2="404" y2="87" stroke="#6b675f" marker-end="url(#arw-f1)"
            ></line>
            <line x1="504" y1="87" x2="536" y2="87" stroke="#6b675f" marker-end="url(#arw-f1)"
            ></line>
            <path
                d="M 584 112 C 584 188, 190 188, 190 114"
                fill="none"
                stroke="#7a1f12"
                stroke-dasharray="4 3"
                marker-end="url(#arwA-f1)"></path>
            <text x="387" y="183" text-anchor="middle" font-size="11" fill="#7a1f12"
                >result flows back ↑ then the loop repeats</text
            >
            <text
                x="320"
                y="28"
                text-anchor="middle"
                font-size="12"
                font-weight="700"
                fill="#111110">THE REQUEST PATH — one pass of the agent loop</text
            >
        </g>
    </svg>
    <figcaption>
        Memorise this banner. Every level below adds or explains one box or the loop arrow.
    </figcaption>
</figure>
