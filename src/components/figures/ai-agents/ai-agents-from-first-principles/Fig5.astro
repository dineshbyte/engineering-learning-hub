---
/**
 * ai-agents/0001 · Figure 5 — Level 4, the Agent loop
 * (Observe → Think → Act, repeating until goal / max-steps; DONE).
 * Verbatim from source; shared <marker>s inlined + namespaced (-f5). See Fig1.
 */
---

<figure>
    <svg
        viewBox="0 0 440 210"
        role="img"
        aria-label="A cycle of Observe, Think, Act repeating until the goal is met"
    >
        <defs>
            <marker
                id="arw-f5"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
            >
                <path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path>
            </marker>
            <marker
                id="arwG-f5"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
            >
                <path d="M0,0 L10,5 L0,10 z" fill="#2f5d3a"></path>
            </marker>
        </defs>
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <circle cx="80" cy="64" r="44" fill="#fff" stroke="#7a1f12"></circle>
            <text x="80" y="60" text-anchor="middle" font-size="12" font-weight="700" fill="#7a1f12"
                >OBSERVE</text
            >
            <text x="80" y="76" text-anchor="middle" font-size="9" fill="#6b675f">last result</text>
            <circle cx="330" cy="64" r="44" fill="#fff" stroke="#7a1f12"></circle>
            <text
                x="330"
                y="60"
                text-anchor="middle"
                font-size="12"
                font-weight="700"
                fill="#7a1f12">THINK</text
            >
            <text x="330" y="76" text-anchor="middle" font-size="9" fill="#6b675f">LLM picks</text>
            <circle cx="205" cy="160" r="44" fill="#fff" stroke="#7a1f12"></circle>
            <text
                x="205"
                y="156"
                text-anchor="middle"
                font-size="12"
                font-weight="700"
                fill="#7a1f12">ACT</text
            >
            <text x="205" y="172" text-anchor="middle" font-size="9" fill="#6b675f">run a tool</text
            >
            <path
                d="M 122 50 C 180 28, 250 28, 288 50"
                fill="none"
                stroke="#6b675f"
                marker-end="url(#arw-f5)"></path>
            <path
                d="M 318 104 C 290 128, 262 140, 240 146"
                fill="none"
                stroke="#6b675f"
                marker-end="url(#arw-f5)"></path>
            <path
                d="M 170 146 C 148 140, 120 128, 92 104"
                fill="none"
                stroke="#6b675f"
                marker-end="url(#arw-f5)"></path>
            <text x="205" y="70" text-anchor="middle" font-size="11" fill="#111110"
                >↻ loop until</text
            >
            <text x="205" y="86" text-anchor="middle" font-size="11" fill="#111110"
                >goal / max-steps</text
            >
            <rect x="338" y="150" width="92" height="30" rx="15" fill="#eef5ee" stroke="#2f5d3a"
            ></rect>
            <text
                x="384"
                y="169"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#2f5d3a">DONE ✓</text
            >
            <path
                d="M 249 168 C 290 174, 310 167, 336 165"
                fill="none"
                stroke="#2f5d3a"
                stroke-dasharray="4 3"
                marker-end="url(#arwG-f5)"></path>
        </g>
    </svg>
    <figcaption>
        ≈ a <b>Kubernetes reconciliation loop</b>, but for <em>intent</em>: desired state = the
        goal.
    </figcaption>
</figure>
