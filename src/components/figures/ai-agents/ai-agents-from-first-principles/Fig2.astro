---
/**
 * ai-agents/0001 · Figure 2 — Level 1, the LLM (text in → LLM → text out; stateless).
 * Verbatim from the source HTML; shared <marker> inlined + namespaced (-f2) so the
 * 11 on-page figures keep unique ids. See Fig1 for the full rationale.
 */
---

<figure>
    <svg viewBox="0 0 460 130" role="img" aria-label="Text in, LLM, text out; stateless">
        <defs>
            <marker
                id="arw-f2"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
            >
                <path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path>
            </marker>
        </defs>
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <rect x="8" y="46" width="120" height="40" rx="8" fill="#fff" stroke="#d8d4c8"></rect>
            <text x="68" y="70" text-anchor="middle" font-size="12" fill="#111110">text in</text>
            <line x1="130" y1="66" x2="170" y2="66" stroke="#6b675f" marker-end="url(#arw-f2)"
            ></line>
            <rect
                x="172"
                y="38"
                width="116"
                height="56"
                rx="10"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text
                x="230"
                y="62"
                text-anchor="middle"
                font-size="15"
                font-weight="700"
                fill="#7a1f12">LLM</text
            >
            <text x="230" y="80" text-anchor="middle" font-size="9.5" fill="#6b675f"
                >predict next text</text
            >
            <line x1="290" y1="66" x2="330" y2="66" stroke="#6b675f" marker-end="url(#arw-f2)"
            ></line>
            <rect x="332" y="46" width="120" height="40" rx="8" fill="#fff" stroke="#d8d4c8"></rect>
            <text x="392" y="70" text-anchor="middle" font-size="12" fill="#111110">text out</text>
            <text x="230" y="118" text-anchor="middle" font-size="11" fill="#9a2417"
                >✗ no memory&#160;&#160;✗ no hands&#160;&#160;✗ no state between calls</text
            >
        </g>
    </svg>
    <figcaption>
        <code>f(text) → text</code>. A pure function: same call type, no side effects, nothing
        retained.
    </figcaption>
</figure>
