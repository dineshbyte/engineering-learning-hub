---
/**
 * ai-agents/0001 · Figure 3 — Level 2, Tool & tool calling
 * (LLM emits a tool-call request; runtime executes it; result fed back).
 * Verbatim from source; shared <marker>s inlined + namespaced (-f3). See Fig1.
 */
---

<figure>
    <svg
        viewBox="0 0 560 150"
        role="img"
        aria-label="LLM emits a tool-call request; runtime executes it against a service and returns the result"
    >
        <defs>
            <marker
                id="arw-f3"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
            >
                <path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path>
            </marker>
            <marker
                id="arwG-f3"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
            >
                <path d="M0,0 L10,5 L0,10 z" fill="#2f5d3a"></path>
            </marker>
        </defs>
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <rect
                x="8"
                y="50"
                width="92"
                height="46"
                rx="9"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text x="54" y="72" text-anchor="middle" font-size="14" font-weight="700" fill="#7a1f12"
                >LLM</text
            >
            <text x="54" y="87" text-anchor="middle" font-size="9" fill="#6b675f">only ASKS</text>
            <line x1="100" y1="73" x2="150" y2="73" stroke="#6b675f" marker-end="url(#arw-f3)"
            ></line>
            <text x="125" y="64" text-anchor="middle" font-size="9" fill="#6b675f">request</text>
            <rect x="152" y="44" width="150" height="58" rx="9" fill="#fff" stroke="#7a1f12"></rect>
            <text
                x="227"
                y="66"
                text-anchor="middle"
                font-size="11.5"
                font-weight="700"
                fill="#111110">runtime RUNS it</text
            >
            <text x="227" y="82" text-anchor="middle" font-size="9.5" fill="#6b675f"
                >get_invoice(id="42")</text
            >
            <line x1="302" y1="73" x2="352" y2="73" stroke="#6b675f" marker-end="url(#arw-f3)"
            ></line>
            <rect x="354" y="50" width="96" height="46" rx="9" fill="#fff" stroke="#d8d4c8"></rect>
            <text
                x="402"
                y="72"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#111110">Billing</text
            >
            <text x="402" y="87" text-anchor="middle" font-size="9" fill="#6b675f">API → DB</text>
            <line x1="450" y1="73" x2="500" y2="73" stroke="#6b675f" marker-end="url(#arw-f3)"
            ></line>
            <rect x="500" y="50" width="54" height="46" rx="9" fill="#fff" stroke="#d8d4c8"></rect>
            <text x="527" y="70" text-anchor="middle" font-size="10" fill="#111110">DB</text>
            <text x="527" y="85" text-anchor="middle" font-size="9" fill="#6b675f">$90</text>
            <path
                d="M 354 96 C 250 132, 150 132, 100 96"
                fill="none"
                stroke="#2f5d3a"
                stroke-dasharray="4 3"
                marker-end="url(#arwG-f3)"></path>
            <text x="227" y="132" text-anchor="middle" font-size="10" fill="#2f5d3a"
                >result {'{'}amount: 90{'}'} → fed back to the LLM</text
            >
        </g>
    </svg>
    <figcaption>
        <b>Tool</b> = a typed function (name + JSON schema). <b>Tool calling</b> = the model emitting
        the request your runtime fulfils.
    </figcaption>
</figure>
