---
/**
 * ai-agents/0004 · Figure 1 (Module 7) — Single Agent vs Multi-Agent.
 *
 * Copied VERBATIM from docs/ai-agents/lessons/0004-agent-systems-and-production.html
 * (figure + svg + figcaption). Lives as an .astro component, NOT inline in the
 * MDX, because MDX's JSX parser is unreliable with raw inline SVG that uses
 * kebab-case attributes (text-anchor, font-size, stroke-width, marker-end, …).
 * The marker ids (#arw, #arwA, #arwG) it references are defined once by Defs.astro,
 * rendered before this figure.
 */
---

<figure>
    <svg
        viewBox="0 0 620 240"
        role="img"
        aria-label="Two architectures side by side: Single Agent on the left, Multi-Agent on the right"
    >
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <!-- Dividing line -->
            <line
                x1="310"
                y1="10"
                x2="310"
                y2="230"
                stroke="#d8d4c8"
                stroke-width="1.5"
                stroke-dasharray="4 3"></line>
            <!-- LEFT: Single Agent label -->
            <text
                x="155"
                y="22"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#6b675f"
                letter-spacing=".06em">SINGLE AGENT</text
            >
            <!-- User -->
            <rect x="110" y="36" width="90" height="38" rx="8" fill="#fff" stroke="#d8d4c8"></rect>
            <text
                x="155"
                y="58"
                text-anchor="middle"
                font-size="13"
                font-weight="700"
                fill="#111110">User</text
            >
            <!-- Arrow down -->
            <line
                x1="155"
                y1="74"
                x2="155"
                y2="98"
                stroke="#6b675f"
                stroke-width="1.5"
                marker-end="url(#arw)"></line>
            <!-- Agent box -->
            <rect
                x="94"
                y="100"
                width="122"
                height="44"
                rx="8"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text
                x="155"
                y="119"
                text-anchor="middle"
                font-size="13"
                font-weight="700"
                fill="#7a1f12">Agent</text
            >
            <text x="155" y="135" text-anchor="middle" font-size="10" fill="#6b675f"
                >LLM + Tools</text
            >
            <!-- Arrow down -->
            <line
                x1="155"
                y1="144"
                x2="155"
                y2="168"
                stroke="#6b675f"
                stroke-width="1.5"
                marker-end="url(#arw)"></line>
            <!-- Result -->
            <rect x="110" y="170" width="90" height="38" rx="8" fill="#fff" stroke="#d8d4c8"></rect>
            <text
                x="155"
                y="192"
                text-anchor="middle"
                font-size="13"
                font-weight="700"
                fill="#111110">Result</text
            >

            <!-- RIGHT: Multi-Agent label -->
            <text
                x="465"
                y="22"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#6b675f"
                letter-spacing=".06em">MULTI-AGENT</text
            >
            <!-- User -->
            <rect x="420" y="36" width="90" height="38" rx="8" fill="#fff" stroke="#d8d4c8"></rect>
            <text
                x="465"
                y="58"
                text-anchor="middle"
                font-size="13"
                font-weight="700"
                fill="#111110">User</text
            >
            <!-- Arrow to Coordinator -->
            <line
                x1="465"
                y1="74"
                x2="465"
                y2="96"
                stroke="#6b675f"
                stroke-width="1.5"
                marker-end="url(#arw)"></line>
            <!-- Coordinator Agent -->
            <rect
                x="390"
                y="98"
                width="150"
                height="44"
                rx="8"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text
                x="465"
                y="117"
                text-anchor="middle"
                font-size="13"
                font-weight="700"
                fill="#7a1f12">Coordinator</text
            >
            <text x="465" y="133" text-anchor="middle" font-size="10" fill="#6b675f"
                >decomposes + delegates</text
            >
            <!-- Fan-out arrows to 3 workers -->
            <line
                x1="400"
                y1="142"
                x2="352"
                y2="164"
                stroke="#7a1f12"
                stroke-width="1.4"
                marker-end="url(#arwA)"></line>
            <line
                x1="465"
                y1="142"
                x2="465"
                y2="164"
                stroke="#7a1f12"
                stroke-width="1.4"
                marker-end="url(#arwA)"></line>
            <line
                x1="530"
                y1="142"
                x2="578"
                y2="164"
                stroke="#7a1f12"
                stroke-width="1.4"
                marker-end="url(#arwA)"></line>
            <!-- Worker 1: Research -->
            <rect x="318" y="166" width="68" height="36" rx="6" fill="#eef5ee" stroke="#2f5d3a"
            ></rect>
            <text
                x="352"
                y="181"
                text-anchor="middle"
                font-size="9"
                font-weight="700"
                fill="#2f5d3a">Research</text
            >
            <text x="352" y="195" text-anchor="middle" font-size="9" fill="#2f5d3a">Agent</text>
            <!-- Worker 2: Analysis -->
            <rect x="431" y="166" width="68" height="36" rx="6" fill="#eef5ee" stroke="#2f5d3a"
            ></rect>
            <text
                x="465"
                y="181"
                text-anchor="middle"
                font-size="9"
                font-weight="700"
                fill="#2f5d3a">Analysis</text
            >
            <text x="465" y="195" text-anchor="middle" font-size="9" fill="#2f5d3a">Agent</text>
            <!-- Worker 3: Writer -->
            <rect x="544" y="166" width="68" height="36" rx="6" fill="#eef5ee" stroke="#2f5d3a"
            ></rect>
            <text
                x="578"
                y="181"
                text-anchor="middle"
                font-size="9"
                font-weight="700"
                fill="#2f5d3a">Writer</text
            >
            <text x="578" y="195" text-anchor="middle" font-size="9" fill="#2f5d3a">Agent</text>
            <!-- Workers to Final Result arrows -->
            <line
                x1="352"
                y1="202"
                x2="432"
                y2="216"
                stroke="#2f5d3a"
                stroke-width="1.3"
                marker-end="url(#arwG)"></line>
            <line
                x1="465"
                y1="202"
                x2="465"
                y2="216"
                stroke="#2f5d3a"
                stroke-width="1.3"
                marker-end="url(#arwG)"></line>
            <line
                x1="578"
                y1="202"
                x2="498"
                y2="216"
                stroke="#2f5d3a"
                stroke-width="1.3"
                marker-end="url(#arwG)"></line>
            <!-- Final Result -->
            <rect x="408" y="218" width="114" height="16" rx="5" fill="#fff" stroke="#d8d4c8"
            ></rect>
            <text
                x="465"
                y="230"
                text-anchor="middle"
                font-size="10"
                font-weight="700"
                fill="#111110">Final Result</text
            >
        </g>
    </svg>
    <figcaption>
        Single agent: simple, predictable, cheap. Multi-agent: parallelism and specialization, at
        the cost of orchestration complexity and harder debugging.
    </figcaption>
</figure>
