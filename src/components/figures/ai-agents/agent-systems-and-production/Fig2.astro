---
/**
 * ai-agents/0004 · Figure 2 (Module 8) — Six production failure modes + fixes.
 *
 * Copied VERBATIM from docs/ai-agents/lessons/0004-agent-systems-and-production.html.
 * Component (not inline MDX) for the same kebab-case-SVG reason as Fig1; the
 * #arwR marker it uses is defined by Defs.astro.
 */
---

<figure>
    <svg
        viewBox="0 0 620 200"
        role="img"
        aria-label="Six failure modes of production agents with corresponding fixes below each"
    >
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <!-- Agent in Production bar -->
            <rect
                x="10"
                y="10"
                width="600"
                height="34"
                rx="7"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text
                x="310"
                y="32"
                text-anchor="middle"
                font-size="13"
                font-weight="700"
                fill="#7a1f12">Agent in Production</text
            >
            <!-- 6 failure boxes + fix boxes, evenly spaced -->
            <!-- Column 1: x=10 width=90 -->
            <line
                x1="55"
                y1="44"
                x2="55"
                y2="72"
                stroke="#9a2417"
                stroke-width="1.4"
                marker-end="url(#arwR)"></line>
            <rect x="10" y="74" width="90" height="52" rx="6" fill="#f7ecea" stroke="#9a2417"
            ></rect>
            <text x="55" y="93" text-anchor="middle" font-size="10" font-weight="700" fill="#9a2417"
