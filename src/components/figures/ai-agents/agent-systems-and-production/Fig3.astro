---
/**
 * ai-agents/0004 · Figure 3 (Module 9) — Five business agent roles, one loop.
 *
 * Copied VERBATIM from docs/ai-agents/lessons/0004-agent-systems-and-production.html.
 * Component (not inline MDX) for the same kebab-case-SVG reason as Fig1; the
 * #arwA marker it uses is defined by Defs.astro.
 */
---

<figure>
    <svg
        viewBox="0 0 620 180"
        role="img"
        aria-label="Five business agent roles all running on the same agent loop with different tools and job descriptions"
    >
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <!-- Center bar -->
            <rect
                x="60"
                y="10"
                width="500"
                height="34"
                rx="7"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text
                x="310"
                y="32"
                text-anchor="middle"
                font-size="12"
                font-weight="700"
                fill="#7a1f12">Same Agent Loop — Different Tools + Job Description</text
            >
            <!-- Arrows down from center bar to role boxes -->
            <line
                x1="110"
                y1="44"
                x2="110"
                y2="96"
                stroke="#7a1f12"
                stroke-width="1.3"
                marker-end="url(#arwA)"></line>
            <line
                x1="205"
                y1="44"
                x2="205"
                y2="96"
                stroke="#7a1f12"
                stroke-width="1.3"
                marker-end="url(#arwA)"></line>
            <line
                x1="310"
                y1="44"
                x2="310"
                y2="96"
                stroke="#7a1f12"
                stroke-width="1.3"
                marker-end="url(#arwA)"></line>
            <line
                x1="415"
                y1="44"
                x2="415"
                y2="96"
                stroke="#7a1f12"
                stroke-width="1.3"
                marker-end="url(#arwA)"></line>
            <line
                x1="510"
                y1="44"
                x2="510"
                y2="96"
                stroke="#7a1f12"
                stroke-width="1.3"
                marker-end="url(#arwA)"></line>
            <!-- Billing Agent -->
            <rect x="65" y="98" width="90" height="52" rx="7" fill="#fff" stroke="#d8d4c8"></rect>
            <text
                x="110"
                y="118"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#111110">Billing</text
            >
            <text
                x="110"
                y="133"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#111110">Agent</text
            >
            <text x="110" y="148" text-anchor="middle" font-size="14">$</text>
            <!-- Support Agent -->
            <rect x="160" y="98" width="90" height="52" rx="7" fill="#fff" stroke="#d8d4c8"></rect>
            <text
                x="205"
                y="118"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#111110">Support</text
            >
            <text
                x="205"
                y="133"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#111110">Agent</text
            >
            <text x="205" y="148" text-anchor="middle" font-size="14">💬</text>
            <!-- SRE Agent -->
            <rect x="265" y="98" width="90" height="52" rx="7" fill="#fff" stroke="#d8d4c8"></rect>
            <text
                x="310"
                y="118"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#111110">SRE</text
            >
            <text
                x="310"
                y="133"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#111110">Agent</text
            >
            <text x="310" y="148" text-anchor="middle" font-size="14">🔧</text>
            <!-- PM Agent -->
            <rect x="370" y="98" width="90" height="52" rx="7" fill="#fff" stroke="#d8d4c8"></rect>
            <text
                x="415"
                y="118"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#111110">PM</text
            >
            <text
                x="415"
                y="133"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#111110">Agent</text
            >
            <text x="415" y="148" text-anchor="middle" font-size="14">📋</text>
            <!-- Engineering Agent -->
            <rect x="465" y="98" width="90" height="52" rx="7" fill="#fff" stroke="#d8d4c8"></rect>
            <text
                x="510"
                y="118"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#111110">Engineering</text
            >
            <text
                x="510"
                y="133"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#111110">Agent</text
            >
            <text x="510" y="148" text-anchor="middle" font-size="14">⌨</text>
        </g>
    </svg>
    <figcaption>
        Five roles, one runtime, one loop. What differs: the tools registered, the permissions
        granted, and the human-oversight level required.
    </figcaption>
</figure>
