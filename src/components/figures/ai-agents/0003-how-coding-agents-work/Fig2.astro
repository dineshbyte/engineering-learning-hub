---
/**
 * ai-agents/0003 · Figure 2 — "How Cursor Actually Works" (M5 two-phase diagram).
 *
 * Copied VERBATIM from docs/ai-agents/lessons/0003-how-coding-agents-work.html.
 * Kept as an .astro component (not inline MDX) so the kebab-case SVG attributes
 * render byte-for-byte. marker-end url(#arw)/url(#arwA) reference the shared
 * <defs> arrowheads emitted once in the MDX body.
 */
---

<figure>
    <svg
        viewBox="0 0 620 200"
        role="img"
        aria-label="Cursor two-phase architecture: left phase shows index time from Repo files through Chunking and Embedding model to Vector index; right phase shows query time from User query through Embed query and Similarity search to Context assembly, then LLM, then Edit generation"
    >
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <!-- Phase labels -->
            <text
                x="140"
                y="18"
                text-anchor="middle"
                font-size="10"
                fill="#6b675f"
                font-weight="600">PHASE 1 — INDEX TIME</text
            >
            <text
                x="460"
                y="18"
                text-anchor="middle"
                font-size="10"
                fill="#6b675f"
                font-weight="600">PHASE 2 — QUERY TIME</text
            >

            <!-- Vertical divider -->
            <line
                x1="305"
                y1="24"
                x2="305"
                y2="192"
                stroke="#d8d4c8"
                stroke-width="1.5"
                stroke-dasharray="5 3"></line>
            <text
                x="305"
                y="110"
                text-anchor="middle"
                font-size="9"
                fill="#9c968a"
                transform="rotate(-90,305,110)">stored</text
            >

            <!-- Phase 1 boxes -->
            <rect
                x="20"
                y="30"
                width="110"
                height="32"
                rx="5"
                fill="#fff"
                stroke="#d8d4c8"
                stroke-width="1.3"></rect>
            <text x="75" y="50" text-anchor="middle" font-size="11" fill="#111110">Repo files</text>

            <line
                x1="130"
                y1="46"
                x2="148"
                y2="46"
                stroke="#6b675f"
                stroke-width="1.3"
                marker-end="url(#arw)"></line>

            <rect
                x="150"
                y="30"
                width="90"
                height="32"
                rx="5"
                fill="#fff"
                stroke="#d8d4c8"
                stroke-width="1.3"></rect>
            <text x="195" y="50" text-anchor="middle" font-size="11" fill="#111110">Chunking</text>

            <line
                x1="240"
                y1="46"
                x2="256"
                y2="46"
                stroke="#6b675f"
                stroke-width="1.3"
                marker-end="url(#arw)"></line>

            <!-- Arrow down to vector index -->
            <rect
                x="20"
                y="100"
                width="130"
                height="38"
                rx="5"
                fill="#eef5ee"
                stroke="#2f5d3a"
                stroke-width="1.3"></rect>
            <text x="85" y="117" text-anchor="middle" font-size="11" fill="#111110"
                >Vector index</text
            >
            <text x="85" y="130" text-anchor="middle" font-size="9" fill="#6b675f">(disk)</text>

            <rect
                x="158"
                y="100"
                width="130"
                height="38"
                rx="5"
                fill="#fff"
                stroke="#d8d4c8"
                stroke-width="1.3"></rect>
            <text x="223" y="117" text-anchor="middle" font-size="11" fill="#111110">Embedding</text
            >
            <text x="223" y="130" text-anchor="middle" font-size="11" fill="#111110">model</text>

            <line
                x1="223"
                y1="62"
                x2="223"
                y2="98"
                stroke="#6b675f"
                stroke-width="1.3"
                marker-end="url(#arw)"></line>
            <line
                x1="158"
                y1="119"
                x2="150"
                y2="119"
                stroke="#6b675f"
                stroke-width="1.3"
                marker-end="url(#arw)"></line>

            <!-- Phase 2 boxes -->
            <rect
                x="320"
                y="30"
                width="100"
                height="32"
                rx="5"
                fill="#fff"
                stroke="#d8d4c8"
                stroke-width="1.3"></rect>
            <text x="370" y="50" text-anchor="middle" font-size="11" fill="#111110">User query</text
            >

            <line
                x1="420"
                y1="46"
                x2="436"
                y2="46"
                stroke="#6b675f"
                stroke-width="1.3"
                marker-end="url(#arw)"></line>

            <rect
                x="438"
                y="30"
                width="100"
                height="32"
                rx="5"
                fill="#fff"
                stroke="#d8d4c8"
                stroke-width="1.3"></rect>
            <text x="488" y="50" text-anchor="middle" font-size="11" fill="#111110"
                >Embed query</text
            >

            <line
                x1="370"
                y1="62"
                x2="370"
                y2="98"
                stroke="#6b675f"
                stroke-width="1.3"
                marker-end="url(#arw)"></line>

            <rect
                x="320"
                y="100"
                width="120"
                height="32"
                rx="5"
                fill="#fff"
                stroke="#d8d4c8"
                stroke-width="1.3"></rect>
            <text x="380" y="116" text-anchor="middle" font-size="10" fill="#111110"
                >Similarity search</text
            >
            <text x="380" y="128" text-anchor="middle" font-size="9" fill="#6b675f"
                >vs vector index</text
            >

            <line
                x1="440"
                y1="116"
                x2="456"
                y2="116"
                stroke="#6b675f"
                stroke-width="1.3"
                marker-end="url(#arw)"></line>

            <rect
                x="458"
                y="100"
                width="120"
                height="32"
                rx="5"
                fill="#fff"
                stroke="#d8d4c8"
                stroke-width="1.3"></rect>
            <text x="518" y="116" text-anchor="middle" font-size="10" fill="#111110">Context</text>
            <text x="518" y="128" text-anchor="middle" font-size="10" fill="#111110">assembly</text>

            <line
                x1="518"
                y1="132"
                x2="518"
                y2="150"
                stroke="#6b675f"
                stroke-width="1.3"
                marker-end="url(#arw)"></line>

            <rect
                x="438"
                y="152"
                width="100"
                height="32"
                rx="5"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text
                x="488"
                y="172"
                text-anchor="middle"
                font-size="11"
                fill="#111110"
                font-weight="600">LLM</text
            >

            <line
                x1="438"
                y1="168"
                x2="414"
                y2="168"
                stroke="#6b675f"
                stroke-width="1.3"
                marker-end="url(#arwA)"></line>

            <rect
                x="314"
                y="152"
                width="100"
                height="32"
                rx="5"
                fill="#fff"
                stroke="#d8d4c8"
                stroke-width="1.3"></rect>
            <text x="364" y="168" text-anchor="middle" font-size="10" fill="#111110"
                >Edit generation</text
            >

            <!-- Similarity search embed arrow -->
            <line
                x1="488"
                y1="62"
                x2="430"
                y2="100"
                stroke="#6b675f"
                stroke-width="1.3"
                marker-end="url(#arw)"></line>
        </g>
    </svg>
    <figcaption>
        Cursor pre-computes relevance. When you ask a question, retrieval is a fast vector search —
        not a file-by-file read.
    </figcaption>
</figure>
