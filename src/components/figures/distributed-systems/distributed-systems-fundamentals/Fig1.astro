---
/**
 * distributed-systems/fundamentals · Figure 1 — HERO "the one hard truth".
 *
 * Copied VERBATIM from docs/distributed-systems/distributed-systems-fundamentals.html
 * (figure + svg + figcaption). It lives as an .astro component, NOT inline in the
 * MDX, because MDX's JSX parser is unreliable with raw inline SVG that uses
 * kebab-case attributes (text-anchor, font-size, marker-end, …). References the
 * shared #arw arrowhead marker rendered once by <Defs />.
 */
---

<figure style="margin-top:1.6rem">
    <svg
        viewBox="0 0 640 210"
        role="img"
        aria-label="Node A sends a request to Node B and hears nothing; the four causes — lost request, B slow, lost reply, B dead — all look identical: silence"
    >
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <text
                x="320"
                y="22"
                text-anchor="middle"
                font-size="12"
                font-weight="700"
                fill="#111110">THE ONE HARD TRUTH — no reply has four indistinguishable causes</text
            >
            <!-- A -->
            <rect
                x="18"
                y="76"
                width="96"
                height="46"
                rx="9"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text x="66" y="98" text-anchor="middle" font-size="14" font-weight="700" fill="#7a1f12"
                >Node A</text
            >
            <text x="66" y="113" text-anchor="middle" font-size="9.5" fill="#6b675f">waits…</text>
            <!-- B -->
            <rect x="526" y="76" width="96" height="46" rx="9" fill="#fff" stroke="#d8d4c8"></rect>
            <text
                x="574"
                y="98"
                text-anchor="middle"
                font-size="14"
                font-weight="700"
                fill="#111110">Node B</text
            >
            <text x="574" y="113" text-anchor="middle" font-size="9.5" fill="#6b675f">??</text>
            <!-- request arrow -->
            <line x1="116" y1="90" x2="524" y2="90" stroke="#6b675f" marker-end="url(#arw)"></line>
            <text x="320" y="84" text-anchor="middle" font-size="10" fill="#6b675f">request</text>
            <!-- four causes -->
            <g font-size="10" fill="#9a2417">
                <text x="320" y="142" text-anchor="middle"
                    >① request lost &#160;·&#160; ② B slow / paused (GC) &#160;·&#160; ③ reply lost
                    &#160;·&#160; ④ B dead</text
                >
            </g>
            <rect x="120" y="156" width="400" height="30" rx="8" fill="#f7ecea" stroke="#9a2417"
            ></rect>
            <text
                x="320"
                y="175"
                text-anchor="middle"
                font-size="11"
                font-weight="700"
                fill="#7a2218">from A's seat all four = identical silence</text
            >
            <text x="320" y="200" text-anchor="middle" font-size="10" fill="#7a1f12"
                >…and in ③ &amp; ④ the work may already be done</text
            >
        </g>
    </svg>
    <figcaption>
        Memorise this banner. Every level below is a tactic for making good decisions <em
            >despite</em
        >
        this permanent uncertainty.
    </figcaption>
</figure>
