---
/**
 * transactions-isolation-fundamentals · Figure 1 — the HERO isolation ladder.
 *
 * Copied VERBATIM from
 * docs/transactions-isolation/transactions-isolation-fundamentals.html (figure +
 * svg + figcaption). Lives as an .astro component, NOT inline in the MDX, because
 * MDX's JSX parser is unreliable with raw inline SVG that uses kebab-case attrs
 * (text-anchor, font-size, stroke-width, marker-end, …). In an .astro file the
 * SVG is plain HTML, so it renders byte-for-byte.
 *
 * The source page defines the arrowhead markers once in a top-of-body
 * <svg defs> (#arw grey, #arwA red, #arwG green). This figure references #arw and
 * #arwA, so they are inlined here in a local <defs> (verbatim from that defs
 * block) so the marker-end="url(#…)" references resolve standalone.
 */
---

<figure style="margin-top:1.6rem">
    <svg
        viewBox="0 0 640 220"
        role="img"
        aria-label="The isolation ladder from Read Uncommitted up to Serializable, trading speed for safety, with the anomalies each step closes"
    >
        <defs>
            <marker
                id="arw"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path></marker
            >
            <marker
                id="arwA"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#7a1f12"></path></marker
            >
        </defs>
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <text
                x="320"
                y="24"
                text-anchor="middle"
                font-size="12"
                font-weight="700"
                fill="#111110"
                >THE LADDER — every step up closes an anomaly, every step costs speed</text
            >
            <!-- arrow axes -->
            <line x1="40" y1="190" x2="600" y2="190" stroke="#6b675f" marker-end="url(#arw)"></line>
            <text x="600" y="206" text-anchor="end" font-size="10" fill="#6b675f"
                >more safety →</text
            >
            <line x1="600" y1="172" x2="40" y2="172" stroke="#9a2417" marker-end="url(#arwA)"
            ></line>
            <text x="40" y="166" font-size="10" fill="#9a2417">← more speed / concurrency</text>
            <!-- rungs -->
            <g>
                <rect x="44" y="48" width="120" height="44" rx="9" fill="#fff" stroke="#d8d4c8"
                ></rect>
                <text
                    x="104"
                    y="68"
                    text-anchor="middle"
                    font-size="10.5"
                    font-weight="700"
                    fill="#111110">Read Uncommitted</text
                >
                <text x="104" y="83" text-anchor="middle" font-size="9" fill="#9a2417"
                    >dirty reads OK</text
                >
            </g>
            <g>
                <rect x="180" y="48" width="120" height="44" rx="9" fill="#fff" stroke="#d8d4c8"
                ></rect>
                <text
                    x="240"
                    y="68"
                    text-anchor="middle"
                    font-size="10.5"
                    font-weight="700"
                    fill="#111110">Read Committed</text
                >
                <text x="240" y="83" text-anchor="middle" font-size="9" fill="#6b675f"
                    >no dirty reads</text
                >
            </g>
            <g>
                <rect
                    x="316"
                    y="48"
                    width="124"
                    height="44"
                    rx="9"
                    fill="#f1eee2"
                    stroke="#7a1f12"
                    stroke-width="1.5"></rect>
                <text
                    x="378"
                    y="65"
                    text-anchor="middle"
                    font-size="10.5"
                    font-weight="700"
                    fill="#7a1f12">Snapshot (RR)</text
                >
                <text x="378" y="79" text-anchor="middle" font-size="8.5" fill="#6b675f"
                    >consistent snapshot</text
                >
                <text x="378" y="90" text-anchor="middle" font-size="8.5" fill="#9a2417"
                    >write skew leaks</text
                >
            </g>
            <g>
                <rect x="456" y="48" width="140" height="44" rx="9" fill="#eef5ee" stroke="#2f5d3a"
                ></rect>
                <text
                    x="526"
                    y="68"
                    text-anchor="middle"
                    font-size="10.5"
                    font-weight="700"
                    fill="#2f5d3a">Serializable</text
                >
                <text x="526" y="83" text-anchor="middle" font-size="9" fill="#2f5d3a"
                    >no anomaly possible ✓</text
                >
            </g>
            <!-- step arrows -->
            <line x1="164" y1="70" x2="178" y2="70" stroke="#6b675f" marker-end="url(#arw)"></line>
            <line x1="300" y1="70" x2="314" y2="70" stroke="#6b675f" marker-end="url(#arw)"></line>
            <line x1="440" y1="70" x2="454" y2="70" stroke="#6b675f" marker-end="url(#arw)"></line>
            <text x="320" y="128" text-anchor="middle" font-size="10.5" fill="#1f3a5a"
                >Vendors mislabel the rungs — Postgres "Repeatable Read" <tspan font-weight="700"
                    >is</tspan
                > Snapshot; Oracle "Serializable" <tspan font-weight="700">is</tspan> Snapshot.</text
            >
        </g>
    </svg>
    <figcaption>
        Memorise this ladder. Levels 3–6 climb it; Levels 1–2 explain the rungs; Levels 7–9 leave
        the single node and reach across services.
    </figcaption>
</figure>
