---
/**
 * transactions-isolation · ssi-deep-dive · Figure 1 — "THE WHOLE ARGUMENT — four moves".
 *
 * Copied VERBATIM from docs/transactions-isolation/ssi-deep-dive.html (the hero
 * figure + svg + figcaption). It lives as an .astro component, NOT inline in the
 * MDX, because MDX's JSX parser is unreliable with raw inline SVG that uses
 * kebab-case attributes (text-anchor, font-size, stroke-width, marker-end, …).
 * In an .astro file the SVG is plain HTML, so it renders byte-for-byte.
 *
 * The source page defined the arrowhead markers once in a body-level
 * <svg width="0" height="0"> and referenced them via url(#arw). To keep each
 * figure self-contained (the bloom-0001 pattern), the #arw marker this figure
 * uses is inlined here in its own <defs>.
 */
---

<figure style="margin-top:1.6rem">
    <svg
        viewBox="0 0 640 200"
        role="img"
        aria-label="The SSI argument: snapshot isolation admits write skew; serializability equals an acyclic dependency graph; every anomaly hides a dangerous structure of two rw-edges; detect it and abort conservatively"
    >
        <defs>
            <marker
                id="arw"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
            >
                <path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path>
            </marker>
        </defs>
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <text
                x="320"
                y="22"
                text-anchor="middle"
                font-size="12"
                font-weight="700"
                fill="#111110">THE WHOLE ARGUMENT — four moves</text
            >
            <g>
                <rect
                    x="8"
                    y="58"
                    width="138"
                    height="58"
                    rx="10"
                    fill="#f7ecea"
                    stroke="#9a2417"
                    stroke-width="1.5"></rect>
                <text
                    x="77"
                    y="82"
                    text-anchor="middle"
                    font-size="12"
                    font-weight="700"
                    fill="#9a2417">SI is fast,</text
                >
                <text
                    x="77"
                    y="98"
                    text-anchor="middle"
                    font-size="12"
                    font-weight="700"
                    fill="#9a2417">not safe</text
                >
                <text x="77" y="112" text-anchor="middle" font-size="9" fill="#6b675f"
                    >write skew</text
                >
            </g>
            <g>
                <rect
                    x="172"
                    y="58"
                    width="138"
                    height="58"
                    rx="10"
                    fill="#fff"
                    stroke="#1f3a5a"
                    stroke-width="1.5"></rect>
                <text
                    x="241"
                    y="82"
                    text-anchor="middle"
                    font-size="12"
                    font-weight="700"
                    fill="#1f3a5a">anomaly =</text
                >
                <text
                    x="241"
                    y="98"
                    text-anchor="middle"
                    font-size="12"
                    font-weight="700"
                    fill="#1f3a5a">graph cycle</text
                >
                <text x="241" y="112" text-anchor="middle" font-size="9" fill="#6b675f"
                    >rw-edges only</text
                >
            </g>
            <g>
                <rect
                    x="336"
                    y="58"
                    width="138"
                    height="58"
                    rx="10"
                    fill="#fbfaf2"
                    stroke="#7a1f12"
                    stroke-width="1.5"></rect>
                <text
                    x="405"
                    y="82"
                    text-anchor="middle"
                    font-size="11.5"
                    font-weight="700"
                    fill="#7a1f12">one pivot,</text
                >
                <text
                    x="405"
                    y="98"
                    text-anchor="middle"
                    font-size="11.5"
                    font-weight="700"
                    fill="#7a1f12">two rw-edges</text
                >
                <text x="405" y="112" text-anchor="middle" font-size="9" fill="#6b675f"
                    >dangerous structure</text
                >
            </g>
            <g>
                <rect
                    x="500"
                    y="58"
                    width="132"
                    height="58"
                    rx="10"
                    fill="#eef5ee"
                    stroke="#2f5d3a"
                    stroke-width="1.5"></rect>
                <text
                    x="566"
                    y="82"
                    text-anchor="middle"
                    font-size="12"
                    font-weight="700"
                    fill="#2f5d3a">detect →</text
                >
                <text
                    x="566"
                    y="98"
                    text-anchor="middle"
                    font-size="12"
                    font-weight="700"
                    fill="#2f5d3a">abort</text
                >
                <text x="566" y="112" text-anchor="middle" font-size="9" fill="#6b675f"
                    >SQLSTATE 40001</text
                >
            </g>
            <line x1="146" y1="87" x2="170" y2="87" stroke="#6b675f" marker-end="url(#arw)"></line>
            <line x1="310" y1="87" x2="334" y2="87" stroke="#6b675f" marker-end="url(#arw)"></line>
            <line x1="474" y1="87" x2="498" y2="87" stroke="#6b675f" marker-end="url(#arw)"></line>
            <text x="320" y="160" text-anchor="middle" font-size="11" fill="#7a1f12"
                >cheap because it never builds the full graph — it watches for one local shape</text
            >
            <text x="320" y="180" text-anchor="middle" font-size="10.5" fill="#6b675f"
                >conservative: catches every anomaly, plus a few innocent transactions (the price)</text
            >
        </g>
    </svg>
    <figcaption>
        Memorise this banner. Levels 1&#8211;5 are exactly these four boxes plus the bill at the
        end.
    </figcaption>
</figure>
