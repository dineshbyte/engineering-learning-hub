---
/**
 * SocialLinks — the two social clusters in docs/index.html, ported verbatim.
 *
 *   variant="icon"     → the masthead `nav.soc-hdr` cluster (glyph pills).
 *                        FIVE links: Twitter / Medium / LinkedIn + Issues + Fork.
 *   variant="labelled" → the footer `.socrow` cluster (SVG + label pills).
 *                        FOUR links: Twitter / Medium / LinkedIn + GitHub.
 *
 * The two variants are deliberately NOT the same link set — that mirrors
 * index.html (the header surfaces Issues/Fork as quick-action glyphs; the footer
 * surfaces the GitHub repo with a brand SVG instead). hrefs / aria-labels / SVG
 * paths are copied byte-for-byte from the source so analytics click routing and
 * the rendered output are unchanged.
 *
 * NOTE (flagged in the return): the footer `.socrow` <a> elements do NOT carry
 * class="soclink" in index.html. That is preserved here on purpose so the
 * delegated analytics click listener keeps classifying these as the footer
 * social variant exactly as it does today. Do not "fix" it without auditing
 * analytics.js first.
 */
interface Props {
    variant: 'icon' | 'labelled';
}
const { variant } = Astro.props;
---

{
    variant === 'icon' && (
        <nav class="soc-hdr" aria-label="Social links">
            <a
                class="soclink"
                href="https://twitter.com/dineshxbyte"
                target="_blank"
                rel="noopener"
                title="Twitter / X"
                aria-label="Twitter / X"
            >
                𝕏
            </a>
            <a
                class="soclink"
                href="https://medium.com/@dineshbyte"
                target="_blank"
                rel="noopener"
                title="Medium"
                aria-label="Medium"
            >
                M
            </a>
            <a
                class="soclink"
                href="https://www.linkedin.com/in/dineshbyte/"
                target="_blank"
                rel="noopener"
                title="LinkedIn"
                aria-label="LinkedIn"
            >
                in
            </a>
            <a
                class="soclink"
                href="https://github.com/dineshbyte/engineering-learning-hub/issues"
                target="_blank"
                rel="noopener"
                title="Issues & ideas"
                aria-label="Issues and ideas"
            >
                🐛
            </a>
            <a
                class="soclink"
                href="https://github.com/dineshbyte/engineering-learning-hub/fork"
                target="_blank"
                rel="noopener"
                title="Fork the repo"
                aria-label="Fork the repository"
            >
                🍴
            </a>
        </nav>
    )
}
{
    variant === 'labelled' && (
        <div class="socrow">
            <a
                href="https://twitter.com/dineshxbyte"
                target="_blank"
                rel="noopener"
                aria-label="Twitter / X"
            >
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M18.9 1.15h3.68l-8.04 9.19L24 22.85h-7.41l-5.8-7.58-6.64 7.58H.47l8.6-9.83L0 1.15h7.59l5.24 6.93 6.07-6.93Zm-1.29 19.5h2.04L6.49 3.24H4.3l13.31 17.4Z" />
                </svg>
                Twitter / X
            </a>
            <a
                href="https://medium.com/@dineshbyte"
                target="_blank"
                rel="noopener"
                aria-label="Medium"
            >
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M13.54 12a6.8 6.8 0 0 1-6.77 6.82A6.8 6.8 0 0 1 0 12a6.8 6.8 0 0 1 6.77-6.82A6.8 6.8 0 0 1 13.54 12Zm7.42 0c0 3.54-1.51 6.42-3.38 6.42S14.2 15.54 14.2 12s1.51-6.42 3.38-6.42S20.96 8.46 20.96 12ZM24 12c0 3.17-.53 5.75-1.19 5.75S21.62 15.17 21.62 12s.53-5.75 1.19-5.75S24 8.83 24 12Z" />
                </svg>
                Medium
            </a>
            <a
                href="https://www.linkedin.com/in/dineshbyte/"
                target="_blank"
                rel="noopener"
                aria-label="LinkedIn"
            >
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z" />
                </svg>
                LinkedIn
            </a>
            <a
                href="https://github.com/dineshbyte/engineering-learning-hub"
                target="_blank"
                rel="noopener"
                aria-label="GitHub"
            >
                <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 .3a12 12 0 0 0-3.79 23.4c.6.1.82-.26.82-.58v-2.03c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.33-1.76-1.33-1.76-1.09-.74.08-.73.08-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.49 1 .11-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.69.83.57A12 12 0 0 0 12 .3Z" />
                </svg>
                GitHub
            </a>
        </div>
    )
}
