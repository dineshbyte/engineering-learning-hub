---
// Footnote sources, rendered from data. `html` is the citation line including its
// outbound link(s) and the ↩ back-reference, kept verbatim so existing footnotes
// port 1:1.
interface Source {
    id: string; // anchor id the body's <sup> links to, e.g. "s1"
    html: string; // citation text incl. links + the ↩ back-ref
}
const { items } = Astro.props as { items: Source[] };
---

<footer id="sources">
    <strong>Sources</strong><br />
    {
        items.map((s) => (
            <Fragment>
                <span id={s.id} set:html={s.html} />
                <br />
            </Fragment>
        ))
    }
</footer>
