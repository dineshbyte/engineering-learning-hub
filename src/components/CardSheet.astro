---
// Card detail sheet — the native <dialog> shell the ported client JS opens and
// fills (card_open). The .cs-name / .cs-tag / .cs-meta / ol.cs-lessons /
// .cs-foot are emptied here and populated at runtime; we render ONLY the shell,
// byte-for-byte from docs/index.html — no props, no interactivity. The
// id="cardsheet", id="cardsheet-title" and the class selectors are part of the
// DOM contract the ported JS queries; do NOT rename them. The close glyph is
// kept as the literal &#x2715; entity via set:html so it is not re-encoded.
---

<dialog id="cardsheet" class="cardsheet" aria-labelledby="cardsheet-title">
    <div class="cs-inner">
        <button class="cs-close" type="button" aria-label="Close" set:html="✕" />
        <div class="cs-head">
            <div class="cs-name" id="cardsheet-title"></div>
            <div class="cs-tag"></div>
            <div class="cs-meta"></div>
        </div>
        <ol class="cs-lessons"></ol>
        <div class="cs-foot"></div>
    </div>
</dialog>
