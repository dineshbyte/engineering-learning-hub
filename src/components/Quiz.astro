---
// Retrieval-practice quiz, rendered from data. Adding a question = adding one
// object to the `quiz` array in a lesson. The answer-checking JS is shared once
// in LessonLayout, so every lesson's quiz behaves identically with zero markup.
interface QuizItem {
    q: string;
    options: string[];
    correct: number; // index of the correct option
}
const { items, id } = Astro.props as { items: QuizItem[]; id?: string };
---

<div class="quiz" id={id}>
    {
        items.map((item, i) => (
            <div class="qitem" data-correct={item.correct}>
                <p class="q">
                    <span class="qn">Q{i + 1}.</span> {item.q}
                </p>
                {item.options.map((opt) => (
                    <button class="opt">{opt}</button>
                ))}
                <p class="fb" role="status" aria-live="polite" />
            </div>
        ))
    }
</div>
