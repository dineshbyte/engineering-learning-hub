---
/**
 * SiteHeader — <header class="topbar"> for the hub (docs/index.html).
 *
 * Composes the brand wordmark + the search combobox + the social cluster,
 * the "Star on GitHub" button, and the theme toggle. The search <input id="q">
 * and the surrounding markup are part of the DOM contract the ported client JS
 * (search + ARIA combobox wiring) depends on — selectors/attributes here are
 * reproduced byte-for-byte from docs/index.html; do NOT rename them.
 *
 * SocialLinks / GithubStar / ThemeToggle own their own internal markup (built
 * by a sibling agent); we only place them in the header in the source order.
 * The placeholder "&amp;" entity is emitted via the static string (Astro keeps
 * the attribute value verbatim — it is not double-encoded).
 */
import SocialLinks from '../components/SocialLinks.astro';
import GithubStar from '../components/GithubStar.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
---

<header class="topbar">
    <h1 class="brand">
        <span class="logo">▦</span>
        <span class="brandname">Engineering Vault</span>
    </h1>
    <div class="search">
        <input
            id="q"
            type="search"
            placeholder="Search tracks & lessons…"
            aria-label="Search tracks and lessons"
            autocomplete="off"
            role="combobox"
            aria-expanded="false"
            aria-controls="results"
            aria-autocomplete="list"
        />
    </div>
    <SocialLinks variant="icon" />
    <GithubStar />
    <ThemeToggle />
</header>
