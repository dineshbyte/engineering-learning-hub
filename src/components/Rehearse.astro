---
// "Rehearse out loud" widget: a prompt, a textarea, and a reveal-on-click model
// answer. The model answer is the <slot> (rich prose, so it can be Markdown in
// MDX). Reveal is wired by a shared, id-free handler in LessonLayout, so a page
// can have several of these without colliding (the old version used a fixed
// id="model" + inline onclick, which broke with more than one per page).
interface Props {
    promptHtml: string; // the "Interviewer: …" lead-in (HTML)
    placeholder?: string;
}
const { promptHtml, placeholder = 'Your answer, from memory…' } = Astro.props;
---

<p class="rehearse" set:html={promptHtml} />
<div class="rehearse">
    <textarea placeholder={placeholder}></textarea><br />
    <button class="btn ghost" data-reveal>Reveal model answer</button>
    <div class="model"><slot /></div>
</div>
