---
/**
 * GithubStar — the `a.ghbtn` "★ Star on GitHub" CTA, used in both the masthead
 * and the footer .fcta of docs/index.html.
 *
 * Structure (verbatim): a.ghbtn > "★ " + <span class="lbl">{label}</span>.
 * The `★ ` text node lives OUTSIDE the .lbl span on purpose — the
 * `@media(max-width:640px){ .ghbtn .lbl{display:none} }` rule hides the label on
 * phones, leaving the bare star. Keep that boundary.
 *
 * Source variants this covers:
 *   - masthead: has title="Star this repository on GitHub" (pass `title`).
 *   - footer:   no title attribute (omit `title`).
 *
 * Both source uses set target="_blank" rel="noopener"; both show the label
 * (showLabel defaults true). showLabel=false drops the span entirely for callers
 * that want the glyph only.
 */
interface Props {
    href: string;
    label?: string;
    showLabel?: boolean;
    title?: string;
}
const { href, label = 'Star on GitHub', showLabel = true, title } = Astro.props;
---

<a class="ghbtn" href={href} target="_blank" rel="noopener" title={title}
    >★ {showLabel && <span class="lbl">{label}</span>}</a
>
