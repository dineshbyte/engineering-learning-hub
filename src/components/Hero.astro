---
/**
 * Hero — the full-bleed <section class="hero"> intro band on the hub
 * (docs/index.html). Copy is reproduced verbatim from the source of truth.
 *
 * trackCount is rendered SERVER-SIDE into #hero-count (the old index.html set
 * this via JS — `heroCount.textContent = tiles.length` — once cards moved
 * server-side the count is known at build time, so the JS path is dropped).
 * The #hero-count id is kept so any analytics/JS that reads it still resolves.
 */
interface Props {
    trackCount: number;
}

const { trackCount } = Astro.props;
---

<section class="hero" aria-label="Intro">
    <div class="hero-in">
        <h2 class="hero-h">
            A public collection of engineering lessons, architecture reviews, AI systems notes,
            interview topics &amp; production learnings.
        </h2>
        <p class="hero-motto">Built while learning. Shared so others can learn.</p>
        <a href="#grid" class="start-here-link">Browse the vault ↓</a>
        <p class="hero-sub">
            <span id="hero-count">{trackCount}</span> curated tracks · free · no sign-up · nothing to
            sell
        </p>
        <!-- set:html keeps the prose + inline links byte-exact (single spaces, no
             Prettier-inserted {' '} glue) so it matches docs/index.html verbatim. -->
        <p
            class="hero-pick"
            set:html={'✦ Not sure where to start? <a href="ai-agents/lessons/0001-ai-agents-from-first-principles.html">AI Agents</a> or <a href="context-engineering/lessons/0001-what-is-context-and-context-as-query.html">Context Engineering</a> are great first picks ↓'}
        />
    </div>
</section>
