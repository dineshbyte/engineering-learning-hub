---
// Published / updated date line for article DETAIL pages (lesson, reference,
// interview, roadmap) — never used on hub cards. Renders only when a date is
// present ("if available"). Semantic <time datetime> for SEO / RSS / article
// metadata. Inline-styled with tokens so it reads correctly in BOTH the
// lesson.css context and the three Tufte serif inline-style contexts (every one
// defines --muted), without each layout needing its own .pubdates rule.
interface Props {
    publishedAt?: string;
    updatedAt?: string;
}
import { formatDate } from '../lib/formatDate';
const { publishedAt, updatedAt } = Astro.props;
---

{
    (publishedAt || updatedAt) && (
        <p class="pubdates" style="font-size:.78rem; color:var(--muted); margin:.32rem 0 0">
            {publishedAt && (
                <Fragment>
                    Published{' '}
                    <time datetime={publishedAt} style="font-weight:600">
                        {formatDate(publishedAt)}
                    </time>
                </Fragment>
            )}
            {publishedAt && updatedAt && ' · '}
            {updatedAt && (
                <Fragment>
                    Updated{' '}
                    <time datetime={updatedAt} style="font-weight:600">
                        {formatDate(updatedAt)}
                    </time>
                </Fragment>
            )}
        </p>
    )
}
