---
// The arrow-flow stat row (Structure → add(x) → query(x)). Data in, arrows
// inserted between steps automatically.
interface Step {
    lab: string;
    big: string;
    sub: string;
}
const { items } = Astro.props as { items: Step[] };
---

<div class="steps">
    {
        items.map((s, i) => (
            <Fragment>
                {i > 0 && <div class="arrow">&#8594;</div>}
                <div class="step">
                    <div class="lab" set:html={s.lab} />
                    <div class="big" set:html={s.big} />
                    <div class="sub" set:html={s.sub} />
                </div>
            </Fragment>
        ))
    }
</div>
