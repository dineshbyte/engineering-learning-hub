{
  "$ref": "#/definitions/interview",
  "definitions": {
    "interview": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 8
        },
        "description": {
          "type": "string",
          "minLength": 20
        },
        "keywords": {
          "type": "string",
          "minLength": 5
        },
        "path": {
          "type": "string",
          "minLength": 3
        },
        "ogImage": {
          "type": "string"
        },
        "ogImageAlt": {
          "type": "string"
        },
        "accentVar": {
          "type": "string",
          "pattern": "^\\-\\-track\\-"
        },
        "trackLabel": {
          "type": "string"
        },
        "kicker": {
          "type": "string"
        },
        "h1Html": {
          "type": "string"
        },
        "metaLine": {
          "type": "string"
        },
        "chips": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "topNav": {
          "type": "object",
          "properties": {
            "refHref": {
              "type": "string"
            },
            "refLabel": {
              "type": "string"
            },
            "prevHref": {
              "type": "string"
            },
            "prevLabel": {
              "type": "string"
            },
            "nextHref": {
              "type": "string"
            },
            "nextLabel": {
              "type": "string"
            }
          },
          "required": [
            "refHref",
            "refLabel"
          ],
          "additionalProperties": false
        },
        "footerHtml": {
          "type": "string"
        },
        "track": {
          "type": "string"
        },
        "number": {
          "type": "string"
        },
        "interview": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "level": {
                "type": "string",
                "enum": [
                  "core",
                  "senior",
                  "staff",
                  "design"
                ]
              },
              "q": {
                "type": "string"
              },
              "a": {
                "type": "string"
              }
            },
            "required": [
              "level",
              "q",
              "a"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "rubricIntro": {
          "type": "string"
        },
        "rubric": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description",
        "keywords",
        "path",
        "ogImage",
        "ogImageAlt",
        "accentVar",
        "trackLabel",
        "kicker",
        "h1Html",
        "metaLine",
        "chips",
        "topNav",
        "footerHtml",
        "track"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}