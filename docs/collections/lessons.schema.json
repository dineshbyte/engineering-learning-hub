{
  "$ref": "#/definitions/lessons",
  "definitions": {
    "lessons": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 8
        },
        "description": {
          "type": "string",
          "minLength": 20
        },
        "keywords": {
          "type": "string",
          "minLength": 5
        },
        "path": {
          "type": "string",
          "minLength": 3
        },
        "ogImage": {
          "type": "string"
        },
        "ogImageAlt": {
          "type": "string"
        },
        "accentVar": {
          "type": "string",
          "pattern": "^\\-\\-track\\-"
        },
        "jsonLd": {},
        "trackLabel": {
          "type": "string"
        },
        "kicker": {
          "type": "string"
        },
        "h1Html": {
          "type": "string"
        },
        "metaLine": {
          "type": "string"
        },
        "chips": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "prev": {
          "type": "object",
          "properties": {
            "href": {
              "type": "string"
            },
            "title": {
              "type": "string"
            }
          },
          "required": [
            "href",
            "title"
          ],
          "additionalProperties": false
        },
        "next": {
          "type": "object",
          "properties": {
            "href": {
              "type": "string"
            },
            "title": {
              "type": "string"
            }
          },
          "required": [
            "href",
            "title"
          ],
          "additionalProperties": false
        },
        "quiz": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "q": {
                "type": "string"
              },
              "options": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 2
              },
              "correct": {
                "type": "integer",
                "minimum": 0
              }
            },
            "required": [
              "q",
              "options",
              "correct"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "interview": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "level": {
                "type": "string",
                "enum": [
                  "core",
                  "senior",
                  "staff",
                  "design"
                ]
              },
              "q": {
                "type": "string"
              },
              "a": {
                "type": "string"
              }
            },
            "required": [
              "level",
              "q",
              "a"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "rubricIntro": {
          "type": "string"
        },
        "rubric": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "html": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "html"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "mc": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "q": {
                "type": "string"
              },
              "a": {
                "type": "string"
              }
            },
            "required": [
              "q",
              "a"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "lab": {
                "type": "string"
              },
              "big": {
                "type": "string"
              },
              "sub": {
                "type": "string"
              }
            },
            "required": [
              "lab",
              "big",
              "sub"
            ],
            "additionalProperties": false
          },
          "default": []
        },
        "track": {
          "type": "string"
        },
        "number": {
          "type": "string"
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description",
        "keywords",
        "path",
        "ogImage",
        "ogImageAlt",
        "accentVar",
        "trackLabel",
        "kicker",
        "h1Html",
        "metaLine",
        "chips",
        "track"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}