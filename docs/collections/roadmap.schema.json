{
  "$ref": "#/definitions/roadmap",
  "definitions": {
    "roadmap": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 5,
          "errorMessage": {
            "minItems": "roadmap keywords need at least 5 entries"
          }
        },
        "ogImage": {
          "type": "string"
        },
        "ogImageAlt": {
          "type": "string"
        },
        "chips": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "accentVar": {
          "type": "string",
          "pattern": "^\\-\\-track\\-"
        },
        "trackLabel": {
          "type": "string"
        },
        "kicker": {
          "type": "string",
          "default": "Learning track · Roadmap"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "description",
        "keywords",
        "ogImage",
        "ogImageAlt",
        "chips",
        "accentVar",
        "trackLabel",
        "path"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}