---
// "Memory check" recall disclosure (33/48 pages use it). Keeps class="mc" so
// analytics.js still fires disclosure_open{disclosure_type:'memory_check'} on the
// <details> toggle. Each item is a recall prompt + the answer revealed after it.
interface MCItem {
    q: string; // the prompt (may contain inline HTML)
    a: string; // the answer shown after the → arrow
}
const { items } = Astro.props as { items: MCItem[] };
---

<details class="mc">
    <summary>Memory check</summary>
    <ul>
        {
            items.map((it) => (
                <li>
                    <Fragment set:html={it.q} /> <span class="ans" set:html={`&rarr; ${it.a}`} />
                </li>
            ))
        }
    </ul>
</details>
