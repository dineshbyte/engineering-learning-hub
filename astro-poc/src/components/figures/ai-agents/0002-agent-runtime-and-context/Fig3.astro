---
/**
 * ai-agents 0002 · Figure 3 — "Context selection pipeline".
 *
 * Copied VERBATIM from docs/ai-agents/lessons/0002-agent-runtime-and-context.html
 * (figure + svg + figcaption). Lives as an .astro component so the inline SVG with
 * kebab-case attributes renders byte-for-byte. The single arrowhead marker it
 * references (`arw`, defined once in the source document's shared <defs>) is
 * inlined into this figure's own <defs>.
 */
---

<figure>
    <svg
        viewBox="0 0 600 180"
        role="img"
        aria-label="Pipeline: large Codebase box, then Context Selection box with Retrieve, Rank, Assemble, Compress steps, then a filled Context Window bar, then LLM"
    >
        <defs>
            <marker
                id="arw"
                viewBox="0 0 10 10"
                refX="8.5"
                refY="5"
                markerWidth="7"
                markerHeight="7"
                orient="auto-start-reverse"
                ><path d="M0,0 L10,5 L0,10 z" fill="#6b675f"></path></marker
            >
        </defs>
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <!-- Codebase box -->
            <rect x="8" y="58" width="108" height="64" rx="9" fill="#fff" stroke="#d8d4c8"></rect>
            <text
                x="62"
                y="82"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="11"
                font-weight="700"
                fill="#111110">Codebase</text
            >
            <text
                x="62"
                y="100"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="9.5"
                fill="#6b675f">(GB of text)</text
            >
            <text
                x="62"
                y="114"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="9"
                fill="#9a2417">too large to fit</text
            >

            <!-- Arrow: Codebase -> Context Selection -->
            <line x1="118" y1="90" x2="154" y2="90" stroke="#6b675f" marker-end="url(#arw)"></line>

            <!-- Context Selection box -->
            <rect
                x="156"
                y="22"
                width="166"
                height="136"
                rx="10"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text
                x="239"
                y="42"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="11.5"
                font-weight="700"
                fill="#7a1f12">Context Selection</text
            >
            <rect x="170" y="56" width="138" height="22" rx="5" fill="#fff" stroke="#d8d4c8"></rect>
            <text
                x="239"
                y="67"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="10"
                fill="#111110">&#9312; Retrieve</text
            >
            <rect x="170" y="84" width="138" height="22" rx="5" fill="#fff" stroke="#d8d4c8"></rect>
            <text
                x="239"
                y="95"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="10"
                fill="#111110">&#9313; Rank</text
            >
            <rect x="170" y="112" width="138" height="22" rx="5" fill="#fff" stroke="#d8d4c8"
            ></rect>
            <text
                x="239"
                y="123"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="10"
                fill="#111110">&#9314; Assemble</text
            >
            <rect x="170" y="140" width="138" height="10" rx="4" fill="#fff" stroke="#d8d4c8"
            ></rect>
            <text
                x="239"
                y="145"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="9"
                fill="#6b675f">&#9315; Compress (if needed)</text
            >

            <!-- Arrow: Context Selection -> Context Window -->
            <line x1="324" y1="90" x2="360" y2="90" stroke="#6b675f" marker-end="url(#arw)"></line>

            <!-- Context Window bar -->
            <rect x="362" y="58" width="96" height="64" rx="9" fill="#fff" stroke="#d8d4c8"></rect>
            <text
                x="410"
                y="72"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="9"
                font-weight="700"
                fill="#111110">Context Window</text
            >
            <rect x="370" y="82" width="80" height="14" rx="3" fill="#e8e4d8" stroke="#d8d4c8"
            ></rect>
            <rect x="370" y="82" width="52" height="14" rx="3" fill="#7a1f12"></rect>
            <text
                x="410"
                y="106"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="8.5"
                fill="#6b675f">52k / 80k tokens</text
            >

            <!-- Arrow: Context Window -> LLM -->
            <line x1="460" y1="90" x2="496" y2="90" stroke="#6b675f" marker-end="url(#arw)"></line>

            <!-- LLM box -->
            <rect
                x="498"
                y="66"
                width="90"
                height="48"
                rx="9"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text
                x="543"
                y="90"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="14"
                font-weight="700"
                fill="#7a1f12">LLM</text
            >
            <text
                x="543"
                y="106"
                text-anchor="middle"
                dominant-baseline="middle"
                font-size="9"
                fill="#6b675f">reasons here</text
            >
        </g>
    </svg>
    <figcaption>
        Context selection is the biggest lever in any coding agent. The right 8k tokens beat the
        wrong 200k tokens every time.
    </figcaption>
</figure>
