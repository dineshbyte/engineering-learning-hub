---
/**
 * ai-agents/0001 · Figure 9 — Level 8, MCP
 * (without MCP: N×M bespoke glue; with MCP: N+M via one standard bus).
 * Verbatim from source — this figure uses no <marker>s. See Fig1 for context.
 */
---

<figure>
    <svg
        viewBox="0 0 560 230"
        role="img"
        aria-label="Without MCP, N agents times M tools bespoke integrations; with MCP, N plus M via one standard bus"
    >
        <g font-family="ui-sans-serif,system-ui,sans-serif">
            <text
                x="135"
                y="20"
                text-anchor="middle"
                font-size="11.5"
                font-weight="700"
                fill="#9a2417">WITHOUT MCP · N × M glue</text
            >
            <g fill="#fff" stroke="#d8d4c8"
                ><circle cx="40" cy="70" r="15"></circle><circle cx="40" cy="120" r="15"
                ></circle><circle cx="40" cy="170" r="15"></circle></g
            >
            <g font-size="10" text-anchor="middle" fill="#111110"
                ><text x="40" y="74">A</text><text x="40" y="124">B</text><text x="40" y="174"
                    >C</text
                ></g
            >
            <g fill="#fff" stroke="#d8d4c8"
                ><circle cx="230" cy="70" r="15"></circle><circle cx="230" cy="120" r="15"
                ></circle><circle cx="230" cy="170" r="15"></circle></g
            >
            <g font-size="9" text-anchor="middle" fill="#111110"
                ><text x="230" y="73">git</text><text x="230" y="123">db</text><text x="230" y="173"
                    >slack</text
                ></g
            >
            <g stroke="#9a2417" stroke-width="0.8" opacity="0.5">
                <line x1="55" y1="70" x2="215" y2="70"></line><line
                    x1="55"
                    y1="70"
                    x2="215"
                    y2="120"></line><line x1="55" y1="70" x2="215" y2="170"></line>
                <line x1="55" y1="120" x2="215" y2="70"></line><line
                    x1="55"
                    y1="120"
                    x2="215"
                    y2="120"></line><line x1="55" y1="120" x2="215" y2="170"></line>
                <line x1="55" y1="170" x2="215" y2="70"></line><line
                    x1="55"
                    y1="170"
                    x2="215"
                    y2="120"></line><line x1="55" y1="170" x2="215" y2="170"></line>
            </g>
            <text x="135" y="208" text-anchor="middle" font-size="10" fill="#6b675f"
                >every pair hand-wired</text
            >
            <line x1="288" y1="8" x2="288" y2="216" stroke="#d8d4c8" stroke-dasharray="4 4"></line>
            <text
                x="430"
                y="20"
                text-anchor="middle"
                font-size="11.5"
                font-weight="700"
                fill="#2f5d3a">WITH MCP · N + M</text
            >
            <g fill="#fff" stroke="#d8d4c8"
                ><circle cx="330" cy="70" r="15"></circle><circle cx="330" cy="120" r="15"
                ></circle><circle cx="330" cy="170" r="15"></circle></g
            >
            <g font-size="10" text-anchor="middle" fill="#111110"
                ><text x="330" y="74">A</text><text x="330" y="124">B</text><text x="330" y="174"
                    >C</text
                ></g
            >
            <rect
                x="398"
                y="58"
                width="40"
                height="124"
                rx="8"
                fill="#f1eee2"
                stroke="#7a1f12"
                stroke-width="1.5"></rect>
            <text
                x="418"
                y="125"
                text-anchor="middle"
                font-size="12"
                font-weight="700"
                fill="#7a1f12"
                transform="rotate(-90 418 125)">MCP</text
            >
            <g fill="#fff" stroke="#d8d4c8"
                ><circle cx="510" cy="70" r="15"></circle><circle cx="510" cy="120" r="15"
                ></circle><circle cx="510" cy="170" r="15"></circle></g
            >
            <g font-size="8.5" text-anchor="middle" fill="#111110"
                ><text x="510" y="73">git</text><text x="510" y="123">db</text><text x="510" y="173"
                    >slack</text
                ></g
            >
            <g stroke="#6b675f" stroke-width="0.9">
                <line x1="345" y1="70" x2="397" y2="80"></line><line
                    x1="345"
                    y1="120"
                    x2="397"
                    y2="120"></line><line x1="345" y1="170" x2="397" y2="160"></line>
                <line x1="439" y1="80" x2="495" y2="70"></line><line
                    x1="439"
                    y1="120"
                    x2="495"
                    y2="120"></line><line x1="439" y1="160" x2="495" y2="170"></line>
            </g>
            <text x="430" y="208" text-anchor="middle" font-size="10" fill="#6b675f"
                >build once, plug in</text
            >
        </g>
    </svg>
    <figcaption>
        The <b>client</b> lives in the agent (the port); a <b>server</b> exposes each tool (the device);
        the <b>registry</b> is the catalog of what's plugged in.
    </figcaption>
</figure>
